# E2E 测试环境配置(提交进仓库,值全部公开)
# 任何修改必须保持以下不变式:
# - DATABASE_URL 必须指向 app_test 测试库,绝不复用开发库 app
# - JWT_SECRET 仅供 test 使用,production 启动校验会拒绝同一字符串
# - SUPER_ADMIN_* 在 APP_ENV=test 下默认值被放行(强校验只禁 production)

APP_ENV=test
# E2E 用 supertest 直连 app.getHttpServer(),不真 listen;
# 此值仅为通过启动强校验(parsePort 要求 1-65535),具体数字无意义,故意避开开发用 3000。
APP_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_test?schema=public
APP_CORS_ORIGIN=http://localhost:5173
ENABLE_SWAGGER=true
JWT_SECRET=test-secret-please-keep-this-string-long-enough-32-chars
JWT_EXPIRES_IN=1h
# P0-E PR-3:测试环境 refresh TTL 用 90d(与 production 默认对齐;
# absolute expiration 单测过期路径用 ms 字符串 '1ms' + sleep,不依赖此值)
JWT_REFRESH_EXPIRES_IN=90d
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=ChangeMe123456
SUPER_ADMIN_EMAIL=

# V1.1 §15.7:E2E 测试期间放宽登录限流,避免单 spec 内多次 loginAs
# (最大 18 次,users-admin-crud)触发 429 误伤已有 137 用例。
# auth-login-throttle.e2e-spec.ts 自身通过临时 process.env 覆盖把 LIMIT 调小到 5 触发限流场景。
# 生产 / 开发默认仍为 5/60(留空 → app.config.ts fallback)。
LOGIN_THROTTLE_LIMIT=50
LOGIN_THROTTLE_TTL_SECONDS=60

# P0-D PR-3:E2E 期间放宽改密限流(同 LOGIN_THROTTLE_* 原因):
# users-change-my-password.e2e-spec.ts 第一个 describe 块跑多次成功改密 / 失败 oldPassword,
# 易超过默认 5 次限制。限流验证用例在第二个独立 describe 通过临时 process.env 覆盖
# LIMIT=5 触发 TOO_MANY_REQUESTS 场景。生产 / 开发默认仍为 5/60(留空 → app.config.ts fallback)。
PASSWORD_CHANGE_THROTTLE_LIMIT=50
PASSWORD_CHANGE_THROTTLE_TTL_SECONDS=60

# P0-E PR-3:E2E 期间放宽 refresh 限流(同 LOGIN_THROTTLE_* / PASSWORD_CHANGE_THROTTLE_* 原因):
# 多 spec 跑多次 refresh,易超过默认 30 次限制。
# auth-refresh-throttle.e2e-spec.ts 自身通过临时 process.env 覆盖 LIMIT 触发 429 场景。
REFRESH_THROTTLE_LIMIT=100
REFRESH_THROTTLE_TTL_SECONDS=60

# V2.x C-7.5 实施 PR #10:upload-url + confirm-upload 用 HMAC-SHA256 签发 uploadToken;
# 复用 STORAGE_ENCRYPTION_KEY(沿评审 §8.3.4)。production 由运维注入(沿 v1 §14 JWT_SECRET 范式)。
# 测试 dummy 值(长度 ≥ 32 字符)。
STORAGE_ENCRYPTION_KEY=test-storage-encryption-key-please-32-chars-long-abcdef
STORAGE_CONSISTENCY_MODE=JIT

# SMS 基础设施 T3(2026-06-10):e2e 走 reset-credentials 正向链路需要可用 key(沿 STORAGE 范式;
# 仅测试值,不是真实凭证)。
SMS_ENCRYPTION_KEY=test-sms-encryption-key-please-32-chars-long-abcdef

# 微信小程序登录 T2(2026-06-12):e2e 走 wechat reset-credentials 正向链路需要可用 key
# (沿 SMS 范式;仅测试值,不是真实凭证)。
WECHAT_ENCRYPTION_KEY=test-wechat-encryption-key-please-32-chars-long-abc

# 招新一期 · 实名核验通道 T2(2026-06-18):e2e 走 realname reset-credentials 正向链路需要可用 key
# (沿 SMS/WeChat 范式;仅测试值,不是真实凭证)。
REALNAME_ENCRYPTION_KEY=test-realname-encryption-key-please-32-chars-long-a
