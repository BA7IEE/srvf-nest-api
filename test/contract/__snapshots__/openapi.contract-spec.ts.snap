      },
      "id": {
        "description": "主键(cuid)",
        "type": "string",
      },
      "reviewNote": {
        "description": "APD 一级审核备注 / 驳回理由",
        "nullable": true,
        "type": "object",
      },
      "reviewedAt": {
        "description": "APD 一级审核时间(pending 时 null)",
        "nullable": true,
        "type": "object",
      },
      "reviewerUserId": {
        "description": "APD 一级审核人 User.id(pending 时 null)",
        "nullable": true,
        "type": "object",
      },
      "statusCode": {
        "description": "审核状态字典 code(attendance_sheet_status,批次 4-B 升级为 5 态;**approved 语义为终审通过**)",
        "enum": [
          "pending",
          "pending_final_review",
          "approved",
          "rejected",
          "final_rejected",
        ],
        "type": "string",
      },
      "submittedAt": {
        "description": "提交时间",
        "format": "date-time",
        "type": "string",
      },
      "submitterUserId": {
        "description": "提交人 User.id",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "version": {
        "description": "版本号(D41;pending 编辑时 +1)",
        "type": "number",
      },
    },
    "required": [
      "id",
      "activityId",
      "submitterUserId",
      "submittedAt",
      "statusCode",
      "version",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
  "AttendanceSheetReviewDetailDto": {
    "properties": {
      "activity": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AttendanceSheetActivitySummaryDto",
          },
