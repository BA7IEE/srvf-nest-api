          "schema": {
            "default": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量(上限 50)",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "maximum": 50,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按状态过滤(draft/published/archived)",
          "in": "query",
          "name": "statusCode",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按内容类型过滤",
