                        "type": "object",
                      },
                    ],
                  },
                  "message": {
                    "example": "ok",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "",
