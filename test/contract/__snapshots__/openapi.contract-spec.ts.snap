        "nullable": true,
        "type": "array",
      },
      "memberId": {
        "description": "关联队员外键(指向 members.id;1:1)",
        "type": "string",
      },
      "mobile": {
        "description": "本人手机(MP-15;高敏感;默认掩码〔138****1234〕,持 member-profile.read.sensitive 见明文,§F&A-3)",
        "type": "string",
      },
      "noCriminalRecordSigned": {
        "description": "是否签署无违法犯罪声明(MP-29)",
        "nullable": true,
        "type": "object",
      },
      "otherSkills": {
        "description": "其他特长(MP-26;长文本)",
        "nullable": true,
        "type": "object",
      },
      "politicalStatusCode": {
        "description": "政治面貌字典 code(MP-7;字典 political_status)",
        "nullable": true,
        "type": "object",
      },
      "privacyConsentSigned": {
        "description": "是否授权个人信息使用(MP-30a)",
        "type": "boolean",
      },
      "privacyConsentSignedAt": {
        "description": "隐私授权时间(MP-30b)",
        "nullable": true,
        "type": "object",
      },
      "qq": {
        "description": "QQ(MP-18a;无 sensitive 码时为 null,刀D)",
        "nullable": true,
        "type": "object",
      },
      "realName": {
        "description": "真实姓名(MP-1)",
        "type": "string",
      },
      "residenceArea": {
        "description": "居住区行政区粒度(MP-13)",
        "nullable": true,
        "type": "object",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "vehicleType": {
        "description": "车辆类型(MP-22b;hasVehicle=true 时填)",
