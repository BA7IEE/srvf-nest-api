  "/api/admin/v1/members/{memberId}/registrations": {
    "get": {
      "operationId": "AdminMemberRegistrationsController_listForMember",
      "parameters": [
        {
          "in": "path",
          "name": "memberId",
          "required": true,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按报名状态过滤",
          "in": "query",
          "name": "statusCode",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(仅 admin/v1/registrations 全局横扫生效;命中 memberNo+memberDisplayName+activityTitle;contains + insensitive)",
          "in": "query",
          "name": "q",
          "required": false,
          "schema": {
            "maxLength": 200,
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(仅命中队员 memberNo+displayName;仅 admin/v1/registrations 全局横扫生效)",
          "in": "query",
          "name": "memberQ",
          "required": false,
          "schema": {
            "maxLength": 100,
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(仅命中活动 title;仅 admin/v1/registrations 全局横扫生效)",
          "in": "query",
          "name": "activityQ",
          "required": false,
          "schema": {
            "maxLength": 200,
            "type": "string",
          },
        },
        {
          "description": "按队员精确过滤(仅 admin/v1/registrations 全局横扫生效)",
          "in": "query",
          "name": "memberId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按活动精确过滤(仅 admin/v1/registrations 全局横扫生效)",
          "in": "query",
          "name": "activityId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按承办组织过滤(经活动 organizationId;仅 admin/v1/registrations 全局横扫生效)",
          "in": "query",
          "name": "organizationId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "配合 organizationId:是否展开其全部后代组织(默认 false)",
          "in": "query",
          "name": "includeDescendants",
          "required": false,
          "schema": {
            "default": false,
            "type": "boolean",
          },
        },
        {
          "description": "按 registeredAt 区间过滤(起,ISO8601,含边界)",
          "in": "query",
          "name": "dateFrom",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按 registeredAt 区间过滤(止,ISO8601,含边界)",
          "in": "query",
          "name": "dateTo",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按需展开关联字段(逗号分隔白名单:member,activity;默认不展开,响应形状不变;仅 admin/v1/registrations 全局横扫生效)",
          "in": "query",
          "name": "expand",
          "required": false,
          "schema": {
            "example": "member,activity",
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "业务码,0 表示成功",
                    "example": 0,
                    "type": "integer",
                  },
                  "data": {
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/PageResultDto",
                      },
                      {
                        "properties": {
                          "items": {
                            "items": {
                              "$ref": "#/components/schemas/AdminRegistrationListItemDto",
                            },
                            "type": "array",
                          },
                        },
                        "required": [
                          "items",
                          "total",
                          "page",
                          "pageSize",
                        ],
                        "type": "object",
                      },
                    ],
                  },
                  "message": {
                    "example": "ok",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "",
        },
        "400": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "40000: 请求参数错误",
                    "enum": [
                      40000,
                    ],
                    "example": 40000,
