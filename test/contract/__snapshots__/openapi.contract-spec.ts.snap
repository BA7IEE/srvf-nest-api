      },
      "credentialStatus": {
        "description": "凭证三态(沿 §6.6.3):configured=已配置+解密成功 / missing=未配置 / invalid=已配置但解密失败",
        "enum": [
          "configured",
          "missing",
          "invalid",
        ],
        "type": "string",
      },
