          "formal_member",
          "department",
          "management",
        ],
        "maxLength": 32,
        "type": "string",
      },
      "visibleOrganizationIds": {
        "description": "可见部门 orgId 数组(仅 department 档必填且须全为活跃部门;非 department 档须空;失败 → 31012)",
