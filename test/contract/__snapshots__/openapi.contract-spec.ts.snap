  "/api/admin/v1/role-bindings/page": {
    "get": {
      "operationId": "RoleBindingsController_page",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按主体类型过滤",
          "in": "query",
          "name": "principalType",
          "required": false,
          "schema": {
            "enum": [
              "USER",
              "MEMBER",
              "POSITION_ASSIGNMENT",
              "SYSTEM",
            ],
            "type": "string",
          },
        },
        {
          "description": "按主体 id 过滤",
          "in": "query",
          "name": "principalId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "minLength": 1,
            "type": "string",
          },
        },
        {
          "description": "按角色 id 过滤",
          "in": "query",
          "name": "roleId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "minLength": 8,
            "type": "string",
          },
        },
        {
          "description": "按 scope 类型过滤",
          "in": "query",
          "name": "scopeType",
          "required": false,
          "schema": {
            "enum": [
              "GLOBAL",
              "ORGANIZATION",
              "ORGANIZATION_TREE",
              "ACTIVITY",
              "RESOURCE",
              "SELF",
            ],
            "type": "string",
          },
        },
        {
          "description": "按绑定状态过滤(显式传本参数时优先于 includeExpired 的默认收窄 —— 如需查 ENDED/SUSPENDED 直接传本参数)",
          "in": "query",
          "name": "status",
          "required": false,
          "schema": {
            "enum": [
              "ACTIVE",
              "ENDED",
              "SUSPENDED",
            ],
            "type": "string",
          },
        },
        {
          "description": "按 scope 组织 id 精确过滤",
          "in": "query",
          "name": "scopeOrgId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按角色 code 精确过滤(如 ops-admin)",
          "in": "query",
          "name": "roleCode",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "主体模糊搜索(USER 命中 username+nickname;MEMBER 命中 memberNo+displayName;POSITION_ASSIGNMENT 命中其背后队员的 memberNo+displayName;contains + insensitive)",
          "in": "query",
          "name": "principalQ",
          "required": false,
          "schema": {
            "maxLength": 100,
            "type": "string",
          },
        },
        {
          "description": "是否包含已失效绑定(默认 false = 仅「当前生效」:status=ACTIVE 且未过任期;true 返回全部未软删绑定。显式传 status 参数时本参数的默认收窄不生效)",
          "in": "query",
          "name": "includeExpired",
          "required": false,
          "schema": {
            "default": false,
            "type": "boolean",
          },
        },
        {
          "description": "模糊搜索(命中 note + 角色 code + 角色显示名;contains + insensitive)",
          "in": "query",
          "name": "q",
          "required": false,
          "schema": {
            "maxLength": 200,
            "type": "string",
          },
        },
        {
          "description": "expand 展开(逗号分隔白名单:role,principal;缺省 = 不展开,响应形状与旧端点一致)",
          "in": "query",
          "name": "expand",
          "required": false,
          "schema": {
            "example": "role,principal",
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "业务码,0 表示成功",
                    "example": 0,
                    "type": "integer",
                  },
