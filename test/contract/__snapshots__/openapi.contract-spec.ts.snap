  "/api/admin/v1/position-assignments": {
    "get": {
      "operationId": "PositionAssignmentsController_page",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按组织节点精确过滤",
          "in": "query",
          "name": "organizationId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "配合 organizationId:是否展开其全部后代组织(默认 false)",
          "in": "query",
          "name": "includeDescendants",
          "required": false,
          "schema": {
            "default": false,
            "type": "boolean",
          },
        },
        {
          "description": "按队员精确过滤",
          "in": "query",
          "name": "memberId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按职务定义精确过滤",
          "in": "query",
          "name": "positionId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按任职状态过滤(缺省 = 全部未软删,含 REVOKED 历史 —— 总表口径,与组织轴「仅 ACTIVE」刻意不同)",
          "in": "query",
          "name": "status",
          "required": false,
          "schema": {
            "enum": [
              "ACTIVE",
              "ENDED",
              "REVOKED",
            ],
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(命中队员 memberNo+displayName + 职务 code+name + 组织 name+code;contains + insensitive)",
          "in": "query",
          "name": "q",
          "required": false,
          "schema": {
            "maxLength": 100,
            "type": "string",
          },
        },
        {
          "description": "expand 展开(逗号分隔白名单:member,position,organization;缺省 = 不展开,响应形状与既有端点一致)",
          "in": "query",
          "name": "expand",
          "required": false,
          "schema": {
            "example": "member,position,organization",
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "业务码,0 表示成功",
                    "example": 0,
                    "type": "integer",
                  },
                  "data": {
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/PageResultDto",
                      },
                      {
                        "properties": {
                          "items": {
                            "items": {
                              "$ref": "#/components/schemas/PositionAssignmentResponseDto",
                            },
                            "type": "array",
                          },
                        },
                        "required": [
                          "items",
                          "total",
                          "page",
                          "pageSize",
                        ],
                        "type": "object",
                      },
                    ],
                  },
                  "message": {
                    "example": "ok",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "",
        },
