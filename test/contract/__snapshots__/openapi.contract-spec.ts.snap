        "type": "string",
      },
    },
    "required": [
      "code",
    ],
    "type": "object",
  },
  "BulkGrantAccountItemDto": {
    "properties": {
      "memberId": {
        "description": "队员 id",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
