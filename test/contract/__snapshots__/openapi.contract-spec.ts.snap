        "description": "归属类型(PRIMARY 主 / SECONDARY 兼 / TEMPORARY 临时 / SUPPORT 支援)",
        "enum": [
          "PRIMARY",
          "SECONDARY",
          "TEMPORARY",
          "SUPPORT",
        ],
        "example": "PRIMARY",
        "type": "string",
      },
      "organization": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MembershipExpandedOrganizationDto",
          },
        ],
        "description": "组织摘要(仅 GET /memberships 分页总表且 ?expand 含 organization 时返回;默认省略)",
      },
      "organizationId": {
        "description": "组织节点外键(指向 organizations.id)",
        "type": "string",
      },
      "reason": {
        "description": "编入 / 调出原因(自由短串)",
        "nullable": true,
        "type": "object",
      },
      "startedAt": {
        "description": "任期起(归属生效时间)",
        "format": "date-time",
        "type": "string",
      },
      "status": {
        "description": "归属状态(ACTIVE 在任 / ENDED 已结束 / SUSPENDED 暂停)",
        "enum": [
          "ACTIVE",
          "ENDED",
          "SUSPENDED",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
    },
    "required": [
      "id",
      "memberId",
      "organizationId",
      "membershipType",
      "status",
      "startedAt",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
