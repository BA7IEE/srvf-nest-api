  "/api/admin/v1/supervision-assignments/page": {
    "get": {
      "operationId": "SupervisionAssignmentsController_page",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按分管人队员精确过滤",
          "in": "query",
          "name": "supervisorMemberId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按被分管组织精确过滤",
          "in": "query",
          "name": "organizationId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "配合 organizationId:是否展开其全部后代组织(默认 false)",
          "in": "query",
          "name": "includeDescendants",
          "required": false,
          "schema": {
            "default": false,
            "type": "boolean",
          },
        },
        {
          "description": "按范围模式过滤",
          "in": "query",
          "name": "scopeMode",
          "required": false,
          "schema": {
            "enum": [
              "EXACT",
              "TREE",
            ],
            "type": "string",
          },
        },
        {
          "description": "按分管状态过滤(缺省 = 全部未软删,含 REVOKED 历史 —— 总表口径,与旧数组端点「仅 ACTIVE」刻意不同)",
          "in": "query",
          "name": "status",
          "required": false,
          "schema": {
            "enum": [
              "ACTIVE",
              "ENDED",
              "REVOKED",
            ],
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(命中分管人 memberNo+displayName + 组织 name+code;contains + insensitive)",
          "in": "query",
          "name": "q",
          "required": false,
          "schema": {
            "maxLength": 100,
            "type": "string",
          },
        },
        {
          "description": "expand 展开(逗号分隔白名单:supervisor,organization;缺省 = 不展开,响应形状与旧端点一致)",
          "in": "query",
          "name": "expand",
          "required": false,
          "schema": {
            "example": "supervisor,organization",
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "业务码,0 表示成功",
                    "example": 0,
                    "type": "integer",
                  },
                  "data": {
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/PageResultDto",
                      },
                      {
                        "properties": {
                          "items": {
                            "items": {
                              "$ref": "#/components/schemas/SupervisionAssignmentResponseDto",
                            },
                            "type": "array",
                          },
                        },
                        "required": [
                          "items",
                          "total",
                          "page",
                          "pageSize",
                        ],
                        "type": "object",
                      },
                    ],
                  },
                  "message": {
                    "example": "ok",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "",
        },
        "400": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "40000: 请求参数错误",
                    "enum": [
                      40000,
                    ],
                    "example": 40000,
                    "type": "integer",
                  },
                  "data": {
                    "example": null,
                    "nullable": true,
                    "type": "object",
                  },
                  "message": {
                    "example": "请求参数错误",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "请求参数错误(code=40000)",
        },
        "401": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "40100: 未登录或登录已失效",
                    "enum": [
                      40100,
                    ],
                    "example": 40100,
                    "type": "integer",
                  },
                  "data": {
                    "example": null,
                    "nullable": true,
                    "type": "object",
                  },
                  "message": {
                    "example": "未登录或登录已失效",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "未登录或登录已失效(code=40100)",
        },
        "403": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "30100: 无权执行此操作",
                    "enum": [
                      30100,
