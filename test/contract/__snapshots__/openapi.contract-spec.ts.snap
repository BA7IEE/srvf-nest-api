      },
      "remarks": {
        "description": "运维备注",
        "nullable": true,
        "type": "object",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "updatedBy": {
        "description": "最近更新者 User.id(沿 §6.5.3 + V2 范式)",
