        "type": "object",
      },
      "status": {
        "enum": [
          "ok",
          "blocked",
        ],
        "type": "string",
      },
      "userId": {
        "description": "新建账号 id(仅 status=ok,否则 null)",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "memberId",
      "status",
    ],
    "type": "object",
  },
  "BulkGrantMemberAccountsDto": {
    "properties": {
