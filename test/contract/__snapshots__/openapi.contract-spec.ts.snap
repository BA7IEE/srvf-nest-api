            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按 Sheet 状态过滤",
          "in": "query",
          "name": "statusCode",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(仅 admin/v1/attendance-sheets 全局横扫生效;命中活动 title + 提交人 username/nickname;contains + insensitive)",
          "in": "query",
          "name": "q",
          "required": false,
          "schema": {
            "maxLength": 200,
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(仅命中活动 title;仅 admin/v1/attendance-sheets 全局横扫生效)",
          "in": "query",
          "name": "activityQ",
          "required": false,
          "schema": {
            "maxLength": 200,
            "type": "string",
          },
        },
        {
          "description": "按承办组织过滤(经活动 organizationId;仅 admin/v1/attendance-sheets 全局横扫生效)",
          "in": "query",
          "name": "organizationId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "配合 organizationId:是否展开其全部后代组织(默认 false)",
          "in": "query",
          "name": "includeDescendants",
          "required": false,
          "schema": {
            "default": false,
            "type": "boolean",
          },
        },
        {
          "description": "按 submittedAt 区间过滤(起,ISO8601,含边界)",
          "in": "query",
          "name": "dateFrom",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按 submittedAt 区间过滤(止,ISO8601,含边界)",
          "in": "query",
          "name": "dateTo",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按需展开关联字段(逗号分隔白名单:activity;默认不展开,响应形状不变;仅 admin/v1/attendance-sheets 全局横扫生效)",
          "in": "query",
