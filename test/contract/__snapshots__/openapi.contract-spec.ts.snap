  "/api/v2/dict-items": {
    "get": {
      "operationId": "DictItemsController_list",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "类型 id(必填)",
          "in": "query",
          "name": "typeId",
          "required": true,
          "schema": {
            "maxLength": 64,
            "minLength": 8,
            "type": "string",
          },
        },
        {
          "description": "父级 id(可选;过滤同级)",
          "in": "query",
          "name": "parentId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "minLength": 8,
            "type": "string",
          },
        },
        {
          "description": "按状态过滤(可选)",
