          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按可见档过滤",
          "in": "query",
          "name": "visibilityCode",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "关键词(标题 + 正文 ILIKE)",
          "in": "query",
          "name": "keyword",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
