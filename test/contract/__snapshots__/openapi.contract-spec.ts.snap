        "description": "下载 signed URL TTL(秒;沿 Q8)",
        "maximum": 1800,
        "minimum": 60,
        "type": "number",
      },
      "enableSignedUrl": {
        "description": "是否启用 signed URL(沿 F2)",
        "type": "boolean",
      },
      "enableVersioning": {
        "description": "versioning 业务侧引用(沿 Q11)",
        "type": "boolean",
      },
      "enabled": {
        "description": "全局启用开关",
        "type": "boolean",
      },
      "envPrefix": {
        "description": "key 环境前缀(dev / test / prod;沿 Q17 / Q18)",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "cuid 主键",
        "type": "string",
      },
      "lifecycleDays": {
        "description": "旧版本 expire 天数(沿 Q11;运维侧引用值)",
        "type": "number",
      },
      "maxObjectSizeBytes": {
        "description": "全局 size 兜底(BigInt 序列化为 string;沿 Q-11-10);null = 不限",
        "example": "104857600",
        "nullable": true,
        "type": "object",
      },
      "providerType": {
        "description": "Provider 类型",
        "enum": [
          "LOCAL",
          "COS",
        ],
        "type": "string",
      },
      "region": {
        "description": "COS region;Local 留空",
        "nullable": true,
        "type": "object",
      },
      "remarks": {
        "description": "运维备注",
        "nullable": true,
        "type": "object",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "updatedBy": {
        "description": "最近更新者 User.id(沿 §6.5.3 + V2 范式)",
        "nullable": true,
        "type": "object",
      },
      "uploadUrlTtlSeconds": {
        "description": "上传 signed URL TTL(秒;沿 Q8)",
        "maximum": 3600,
        "minimum": 60,
        "type": "number",
      },
    },
    "required": [
      "id",
      "providerType",
      "enabled",
      "uploadUrlTtlSeconds",
      "downloadUrlTtlSeconds",
      "lifecycleDays",
      "enableSignedUrl",
      "enableVersioning",
      "allowedMimePolicyMode",
      "credentialStatus",
      "credentialConfigured",
      "updatedAt",
      "createdAt",
    ],
    "type": "object",
  },
