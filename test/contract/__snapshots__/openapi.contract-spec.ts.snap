  "/api/open/v1/contents": {
    "get": {
      "operationId": "ContentPublicController_list",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量(上限 50)",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "maximum": 50,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按内容类型过滤",
          "in": "query",
          "name": "contentTypeCode",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "关键词(标题 + 正文 ILIKE)",
          "in": "query",
          "name": "keyword",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按标签过滤(含任意 tag 即命中;支持 ?tags=a&tags=b 或单值)",
          "in": "query",
          "name": "tags",
          "required": false,
          "schema": {
            "items": {
              "type": "string",
            },
            "maxItems": 16,
            "type": "array",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "业务码,0 表示成功",
                    "example": 0,
                    "type": "integer",
                  },
                  "data": {
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/PageResultDto",
