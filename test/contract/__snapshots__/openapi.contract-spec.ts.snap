        "example": "admin@example.com",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "用户主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "lastLoginAt": {
        "description": "最近一次登录时间",
        "nullable": true,
        "type": "object",
      },
      "nickname": {
        "description": "昵称",
        "nullable": true,
        "type": "object",
      },
      "role": {
        "description": "角色",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "example": "USER",
        "type": "string",
      },
      "status": {
        "description": "状态",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "username": {
        "description": "用户名(归一化为小写)",
        "example": "admin",
        "type": "string",
      },
    },
    "required": [
      "id",
      "username",
      "role",
      "status",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
  "UserRoleResponseDto": {
    "properties": {
      "createdAt": {
        "description": "关系创建时间",
        "format": "date-time",
        "type": "string",
      },
      "createdByUserId": {
        "description": "分配人 User.id(沿 D11 audit 字段;可空表示历史 seed 或 createdBy SetNull)",
        "nullable": true,
        "type": "string",
      },
      "id": {
        "description": "主键(UserRole.id;cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "roleCode": {
        "description": "角色 code(扁平化;沿 D7 §5.2.6)",
        "example": "apd-chief",
        "type": "string",
      },
      "roleDisplayName": {
        "description": "角色显示名(扁平化;沿 D7 §5.2.6)",
        "example": "部门部长",
        "type": "string",
      },
      "roleId": {
        "description": "角色 id(RbacRole.id;cuid)",
        "type": "string",
      },
    },
    "required": [
      "id",
      "roleId",
      "roleCode",
      "roleDisplayName",
      "createdAt",
      "createdByUserId",
    ],
    "type": "object",
  },
  "VerifyCertificateDto": {
    "properties": {
      "verifyNote": {
        "description": "核验备注(可选)",
        "maxLength": 500,
        "type": "string",
      },
    },
    "type": "object",
  },
  "WechatBindDto": {
    "properties": {
      "code": {
        "description": "微信小程序 wx.login() 产出的一次性 code(放最前换 openid,失败不烧短信验证码)",
        "maxLength": 128,
        "type": "string",
      },
      "phone": {
        "description": "账号绑定的大陆手机号(11 位;须与 send-code 时一致)",
        "example": "13800001234",
        "type": "string",
      },
      "smsCode": {
        "description": "6 位数字短信验证码(purpose=WECHAT_BIND)",
        "example": "123456",
        "type": "string",
      },
    },
    "required": [
      "code",
      "phone",
      "smsCode",
    ],
    "type": "object",
  },
  "WechatLoginResponseDto": {
    "properties": {
      "bindingRequired": {
        "description": "该微信 openid 是否尚未绑定账号:true = 未绑定(session=null,客户端引导走 wechat-bind 流程,届时重新 wx.login 取新 code);false = 已绑定并签发会话",
        "type": "boolean",
      },
      "session": {
        "allOf": [
          {
            "$ref": "#/components/schemas/LoginResponseDto",
          },
        ],
        "description": "已绑定时的会话(与密码登录同 LoginResponseDto / 同 refresh family);未绑定为 null",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "bindingRequired",
      "session",
    ],
    "type": "object",
  },
  "WechatSettingsResponseDto": {
    "properties": {
      "appId": {
        "description": "微信小程序 AppID(非 secret)",
        "nullable": true,
        "type": "object",
      },
      "createdAt": {
        "description": "创建时间",
        "format": "date-time",
        "type": "string",
      },
      "credentialConfigured": {
        "description": "DB 层是否已配置凭证(运行时状态看 credentialStatus)",
        "type": "boolean",
      },
      "credentialStatus": {
        "description": "凭证状态三档(configured / missing / invalid);appSecret 明文与密文永不回显",
        "enum": [
          "configured",
          "missing",
          "invalid",
        ],
        "type": "string",
      },
      "enabled": {
        "description": "全局启用开关",
        "type": "boolean",
      },
      "id": {
        "description": "cuid 主键",
        "type": "string",
      },
      "providerType": {
        "description": "通道类型(production-like 禁 DEV_STUB)",
        "enum": [
          "DEV_STUB",
          "WECHAT",
        ],
        "type": "string",
      },
      "remarks": {
        "description": "运维备注",
        "nullable": true,
        "type": "object",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "updatedBy": {
        "description": "最后更新人 User.id",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "id",
      "providerType",
      "enabled",
      "credentialStatus",
      "credentialConfigured",
      "updatedAt",
      "createdAt",
    ],
    "type": "object",
  },
}
`;

