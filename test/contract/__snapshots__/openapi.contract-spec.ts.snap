  "/api/admin/v1/role-bindings/preview": {
    "get": {
      "operationId": "RoleBindingsController_preview",
      "parameters": [
        {
          "description": "主体类型(USER / MEMBER / POSITION_ASSIGNMENT / SYSTEM)",
          "in": "query",
          "name": "principalType",
          "required": true,
          "schema": {
            "enum": [
              "USER",
              "MEMBER",
              "POSITION_ASSIGNMENT",
              "SYSTEM",
            ],
            "example": "USER",
            "type": "string",
          },
        },
        {
          "description": "主体 id(非 SYSTEM 必填;多态,随 principalType 指 user/member/position_assignment)",
          "in": "query",
