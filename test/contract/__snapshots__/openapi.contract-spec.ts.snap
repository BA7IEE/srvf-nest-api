                    "nullable": true,
                    "type": "object",
                  },
                  "message": {
                    "example": "请求参数错误",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "请求参数错误(code=40000)",
        },
        "429": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "42900: 请求过于频繁，请稍后再试",
