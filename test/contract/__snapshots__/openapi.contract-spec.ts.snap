  "ContributionRuleResponseDto": {
    "properties": {
      "activityTypeCode": {
        "description": "活动类型字典 code(typeCode=activity_type)",
        "example": "demo_type",
        "maxLength": 64,
        "type": "string",
      },
      "attendanceRoleCode": {
        "description": "考勤角色字典 code(typeCode=attendance_role)",
        "example": "commander",
        "maxLength": 64,
        "type": "string",
      },
      "createdAt": {
        "description": "创建时间",
        "format": "date-time",
        "type": "string",
      },
      "createdByUserId": {
        "description": "创建人 User.id",
        "nullable": true,
        "type": "object",
      },
      "dailyCap": {
        "description": "每日上限(Decimal(5,2);null = 由 attendance 预填走 DEFAULT_DAILY_CAP=1.5 兜底)",
        "example": 1.5,
        "nullable": true,
        "type": "number",
      },
      "durationThreshold": {
        "description": "时长档位阈值(小时;Decimal(5,2);null = 无档位,该规则对所有服务时长使用 pointsBelow)",
        "example": 2.5,
        "nullable": true,
        "type": "number",
      },
      "id": {
        "description": "主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "pointsAbove": {
        "description": "> 阈值的预填分值(Decimal(5,2);非 null 时要求 durationThreshold 非 null 且 pointsAbove > pointsBelow)",
        "example": 1.5,
        "nullable": true,
        "type": "number",
      },
      "pointsBelow": {
        "description": "≤ 阈值(或无档位)的预填分值(Decimal(5,2))",
        "example": 1,
        "type": "number",
      },
      "remark": {
        "description": "运营备注",
        "maxLength": 500,
        "nullable": true,
        "type": "object",
      },
      "status": {
        "description": "规则状态(ACTIVE 参与 attendance 预填;INACTIVE 不参与)",
        "enum": [
          "ACTIVE",
          "INACTIVE",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "updatedByUserId": {
        "description": "最近更新人 User.id",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "id",
      "activityTypeCode",
      "attendanceRoleCode",
      "pointsBelow",
      "status",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
  "CreateActivityDto": {
    "properties": {
      "activityTypeCode": {
        "description": "活动类型字典 code(必填;typeCode=activity_type)",
        "maxLength": 64,
        "type": "string",
      },
      "capacity": {
        "description": "名额上限(NULL = 不限名额;>= 1)",
        "type": "number",
      },
