        "description": "Records 完整数组(含 Member 嵌套)",
        "items": {
          "$ref": "#/components/schemas/AttendanceRecordResponseDto",
        },
        "type": "array",
      },
      "sheet": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AttendanceSheetResponseDto",
          },
        ],
        "description": "Sheet 详情",
      },
