        "description": "结束人 userId",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "主键(cuid 代理键)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "member": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MembershipExpandedMemberDto",
          },
        ],
        "description": "队员摘要(仅 GET /memberships 分页总表且 ?expand 含 member 时返回;默认省略)",
      },
      "memberId": {
        "description": "队员外键(指向 members.id)",
        "type": "string",
      },
