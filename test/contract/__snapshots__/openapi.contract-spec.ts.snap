  "/api/admin/v1/memberships": {
    "get": {
      "operationId": "MembershipsAdminController_page",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按队员精确过滤",
          "in": "query",
          "name": "memberId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按组织节点精确过滤",
          "in": "query",
          "name": "organizationId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "配合 organizationId:是否展开其全部后代组织(默认 false)",
          "in": "query",
          "name": "includeDescendants",
          "required": false,
          "schema": {
            "default": false,
            "type": "boolean",
          },
        },
        {
          "description": "按归属类型过滤",
          "in": "query",
          "name": "membershipType",
          "required": false,
          "schema": {
            "enum": [
              "PRIMARY",
              "SECONDARY",
              "TEMPORARY",
              "SUPPORT",
            ],
            "type": "string",
          },
        },
        {
          "description": "按归属状态过滤(缺省 = 全部未软删,含 ENDED 历史)",
          "in": "query",
          "name": "status",
          "required": false,
          "schema": {
            "enum": [
              "ACTIVE",
              "ENDED",
              "SUSPENDED",
            ],
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(命中队员 memberNo+displayName + 组织 name+code;contains + insensitive)",
          "in": "query",
          "name": "q",
          "required": false,
          "schema": {
            "maxLength": 100,
            "type": "string",
          },
        },
        {
          "description": "expand 展开(逗号分隔白名单:member,organization;缺省 = 不展开,响应形状与队员轴端点一致)",
          "in": "query",
          "name": "expand",
          "required": false,
          "schema": {
            "example": "member,organization",
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "业务码,0 表示成功",
                    "example": 0,
                    "type": "integer",
                  },
                  "data": {
                    "allOf": [
                      {
                        "$ref": "#/components/schemas/PageResultDto",
                      },
                      {
                        "properties": {
                          "items": {
                            "items": {
                              "$ref": "#/components/schemas/MembershipResponseDto",
                            },
                            "type": "array",
                          },
                        },
                        "required": [
                          "items",
                          "total",
                          "page",
                          "pageSize",
                        ],
                        "type": "object",
                      },
                    ],
                  },
                  "message": {
                    "example": "ok",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "",
        },
        "400": {
          "content": {
            "application/json": {
