                            },
                            "type": "array",
                          },
                        },
                        "required": [
                          "items",
                          "total",
                          "page",
                          "pageSize",
                        ],
                        "type": "object",
                      },
                    ],
                  },
                  "message": {
                    "example": "ok",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "",
        },
        "400": {
          "content": {
            "application/json": {
