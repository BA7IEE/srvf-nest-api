        "description": "旧版本 expire 天数",
        "maximum": 365,
        "minimum": 0,
        "type": "number",
      },
      "maxObjectSizeBytes": {
        "description": "全局 size 兜底(BigInt 用 string 入参;沿 Q-11-10;非负整数字符串 ^\\d+$;null 清空)",
        "example": "104857600",
        "nullable": true,
        "type": "object",
      },
      "providerType": {
        "description": "Provider 类型;PATCH 后 Router 动态切换(沿 Q-11-8;沿 PR #89 动态路由)",
        "enum": [
          "LOCAL",
          "COS",
        ],
        "type": "string",
      },
      "region": {
        "description": "COS region",
        "nullable": true,
        "type": "object",
      },
      "remarks": {
        "description": "运维备注",
        "nullable": true,
        "type": "object",
      },
      "uploadUrlTtlSeconds": {
        "description": "上传 signed URL TTL",
        "maximum": 3600,
        "minimum": 60,
        "type": "number",
      },
    },
    "type": "object",
  },
