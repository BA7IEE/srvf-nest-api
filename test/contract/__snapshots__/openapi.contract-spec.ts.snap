    ],
    "type": "object",
  },
  "UpdateMyProfileDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "maxLength": 255,
        "type": "string",
      },
      "nickname": {
        "description": "昵称",
        "maxLength": 50,
        "type": "string",
      },
    },
    "type": "object",
  },
  "UpdateOrganizationDto": {
    "properties": {
      "name": {
        "description": "节点名",
        "maxLength": 100,
        "type": "string",
      },
      "nodeTypeCode": {
        "description": "节点类别字典 code",
        "maxLength": 64,
        "type": "string",
      },
      "sortOrder": {
        "description": "同级排序权重",
        "minimum": 0,
        "type": "number",
      },
    },
    "type": "object",
  },
  "UpdateOrganizationStatusDto": {
    "properties": {
      "status": {
        "description": "目标状态",
        "enum": [
          "ACTIVE",
          "INACTIVE",
        ],
        "example": "INACTIVE",
        "type": "string",
      },
    },
    "required": [
      "status",
    ],
    "type": "object",
  },
  "UpdateUserDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "maxLength": 255,
        "type": "string",
      },
      "email": {
        "description": "邮箱;传空字符串视为清空(入库 null)",
        "type": "string",
      },
      "nickname": {
        "description": "昵称",
        "maxLength": 50,
        "type": "string",
      },
    },
    "type": "object",
  },
  "UpdateUserRoleDto": {
    "properties": {
      "role": {
        "description": "目标角色;不允许 SUPER_ADMIN(只有 seed 能创建)",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "example": "ADMIN",
        "type": "string",
      },
    },
    "required": [
      "role",
    ],
    "type": "object",
  },
  "UpdateUserStatusDto": {
    "properties": {
      "status": {
        "description": "目标状态",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "DISABLED",
        "type": "string",
      },
    },
    "required": [
      "status",
    ],
    "type": "object",
  },
  "UserResponseDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "nullable": true,
        "type": "object",
      },
      "createdAt": {
        "description": "创建时间",
        "format": "date-time",
        "type": "string",
      },
      "email": {
        "description": "邮箱",
        "example": "admin@example.com",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "用户主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "lastLoginAt": {
        "description": "最近一次登录时间",
        "nullable": true,
        "type": "object",
      },
      "nickname": {
        "description": "昵称",
        "nullable": true,
        "type": "object",
      },
      "role": {
        "description": "角色",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "example": "USER",
        "type": "string",
      },
      "status": {
        "description": "状态",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "username": {
        "description": "用户名(归一化为小写)",
        "example": "admin",
        "type": "string",
      },
    },
    "required": [
      "id",
      "username",
      "role",
      "status",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
  "VerifyCertificateDto": {
    "properties": {
      "verifyNote": {
        "description": "核验备注(可选)",
        "maxLength": 500,
        "type": "string",
      },
    },
    "type": "object",
  },
}
`;

