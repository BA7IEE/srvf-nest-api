                      },
                    ],
                  },
                  "message": {
                    "example": "ok",
                    "type": "string",
                  },
                },
                "required": [
                  "code",
                  "message",
                  "data",
                ],
                "type": "object",
              },
            },
          },
          "description": "",
        },
        "400": {
          "content": {
