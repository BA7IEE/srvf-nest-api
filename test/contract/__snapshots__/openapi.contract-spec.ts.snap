  "/api/admin/v1/organizations/{orgId}/memberships": {
    "get": {
      "operationId": "MembershipsAdminController_listForOrganization",
      "parameters": [
        {
          "in": "path",
          "name": "orgId",
          "required": true,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "是否展开该组织全部后代组织(默认 false = 仅该节点直属)",
          "in": "query",
          "name": "includeDescendants",
          "required": false,
          "schema": {
            "default": false,
            "type": "boolean",
          },
        },
        {
          "description": "按归属类型过滤",
          "in": "query",
          "name": "membershipType",
          "required": false,
          "schema": {
            "enum": [
              "PRIMARY",
              "SECONDARY",
              "TEMPORARY",
              "SUPPORT",
            ],
            "type": "string",
          },
        },
        {
          "description": "按归属状态过滤(缺省 = 全部未软删,含 ENDED/SUSPENDED 历史;组织成员页只看现有人员请传 status=ACTIVE)",
          "in": "query",
          "name": "status",
          "required": false,
          "schema": {
            "enum": [
              "ACTIVE",
              "ENDED",
              "SUSPENDED",
            ],
            "type": "string",
          },
        },
        {
          "description": "模糊搜索(命中队员 memberNo+displayName + 组织 name+code;contains + insensitive)",
          "in": "query",
          "name": "q",
          "required": false,
          "schema": {
            "maxLength": 100,
            "type": "string",
          },
        },
        {
          "description": "expand 展开(逗号分隔白名单:member,organization;缺省 = 不展开,响应形状与队员轴端点一致)",
          "in": "query",
          "name": "expand",
          "required": false,
          "schema": {
            "example": "member,organization",
            "type": "string",
          },
        },
      ],
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
