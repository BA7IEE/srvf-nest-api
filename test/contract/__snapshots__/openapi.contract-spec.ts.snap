        },
        "409": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "code": {
                    "description": "28030: 当前没有开放报名的招新轮次; 28031: 本轮招新名额已满; 28003: 本轮招新你已提交报名,请勿重复报名; 28004: 该微信本轮已有报名进行中,请直接查询报名进度;如非本人操作请联系管理员; 28005: 该手机号本轮已有报名进行中,请查询报名进度;如需共用手机报名请联系管理员协助; 28050: 手机验证已失效,请重新获取验证码",
                    "enum": [
                      28030,
                      28031,
                      28003,
                      28004,
                      28005,
