        "description": "规则状态(ACTIVE 参与 attendance 预填;INACTIVE 不参与)",
        "enum": [
          "ACTIVE",
          "INACTIVE",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "updatedByUserId": {
        "description": "最近更新人 User.id",
        "nullable": true,
        "type": "object",
      },
    },
