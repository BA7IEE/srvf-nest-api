        "type": "object",
      },
      "realName": {
        "description": "真实姓名(身份字段;仅 manual_review 或非大陆证件记录可改)",
        "type": "string",
      },
      "sourceChannel": {
        "description": "来源渠道(非身份字段)",
        "type": "string",
      },
