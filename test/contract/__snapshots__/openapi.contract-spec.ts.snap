        "nullable": true,
        "type": "object",
      },
      "ocrSupported": {
        "description": "该证件类型本期是否走 OCR(身份证/护照/回乡证 true;其余 false→前端手填)",
        "type": "boolean",
      },
      "recognized": {
        "description": "OCR 识别出的姓名 / 证件号(供前端回填;申请人本人 PII,不入日志)",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "ocrSupported",
      "clarityOk",
      "antiForgeryWarnings",
    ],
    "type": "object",
  },
