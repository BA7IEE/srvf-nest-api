  "AuditContextDto": {
    "properties": {
      "after": {
        "additionalProperties": true,
        "description": "操作后的资源快照(softDelete 场景无;敏感字段已由 service 调用方打码)",
        "nullable": true,
        "type": "object",
      },
      "before": {
        "additionalProperties": true,
        "description": "操作前的资源快照(create 场景无;敏感字段已由 service 调用方打码)",
        "nullable": true,
        "type": "object",
      },
      "extra": {
        "additionalProperties": true,
        "description": "调用方自定义 metadata(targetMemberId / operation 等;非敏感字段)",
        "nullable": true,
        "type": "object",
      },
      "ip": {
        "description": "请求来源 IP(request.ip;测试 / 内部调用可能为 null)",
        "example": "127.0.0.1",
        "nullable": true,
        "type": "object",
      },
      "requestId": {
        "description": "请求 ID(nestjs-pino req.id;非空字符串),用于跨日志关联",
        "example": "c1xqgkb0000001abcdef234567",
        "type": "string",
      },
      "ua": {
        "description": "User-Agent(request.headers["user-agent"];curl / 内部调用可能为 null)",
        "example": "Mozilla/5.0 ...",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "requestId",
    ],
    "type": "object",
  },
  "AuditLogResponseDto": {
    "properties": {
      "actorRoleSnap": {
        "description": "操作时的角色快照(Role enum;事后查 user 表取最新角色不可靠,审计取快照)",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "nullable": true,
        "type": "string",
      },
      "actorUserId": {
        "description": "操作人 User.id;系统操作 / 未登录场景为 null",
        "nullable": true,
        "type": "object",
      },
      "context": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AuditContextDto",
          },
        ],
        "description": "审计上下文(AuditContext 锁形 6 字段:3 必填 + 3 可选)",
      },
      "createdAt": {
        "description": "审计记录写入时间(=操作发生时间,审计记录不可改不可删)",
        "format": "date-time",
        "type": "string",
      },
      "event": {
        "description": "审计事件(AuditLogEvent union 同值;String 不用 Prisma enum)",
        "example": "emergency-contact.write",
        "type": "string",
      },
      "id": {
        "description": "主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "resourceId": {
        "description": "资源 ID(create 失败时可为 null)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "nullable": true,
        "type": "object",
      },
      "resourceType": {
        "description": "资源类型(第一批枚举值:emergency_contact / certificate;String,不用 Prisma enum)",
        "example": "emergency_contact",
        "type": "string",
      },
      "success": {
        "description": "操作是否成功(D-B fail-fast:audit 与业务同事务,失败回滚整体;现仅 true)",
        "example": true,
        "type": "boolean",
      },
    },
    "required": [
      "id",
      "createdAt",
      "resourceType",
      "event",
      "context",
      "success",
    ],
    "type": "object",
  },
  "AuthzDecisionDto": {
    "properties": {
      "allow": {
        "description": "是否允许(deny 是数据不是错误 —— 入参合法即 200 返 decision)",
        "type": "boolean",
      },
      "matchedGrant": {
        "allOf": [
          {
            "$ref": "#/components/schemas/MatchedGrantDto",
          },
        ],
        "description": "命中授权(allow 时必有 —— 每个 allow 必能指出命中的授权行;deny 时缺省)",
      },
      "reason": {
        "description": "决断原因(稳定枚举,§9 行 20 契约锁):allow ∈ {super_admin_pass, matched};其余为 deny 归因,resource_not_found 亦是 200 的 decision reason(诊断端点回答"为什么",不抛业务错)",
        "enum": [
          "super_admin_pass",
          "matched",
          "no_permission",
          "out_of_scope",
          "out_of_supervised_scope",
          "expired_grant",
          "inactive_org",
          "self_approval_forbidden",
          "same_reviewer_forbidden",
          "sensitive_denied",
          "resource_not_found",
        ],
        "type": "string",
      },
      "resource": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ResolvedResourceDto",
          },
        ],
        "description": "解析后的资源归属(有 ref 且解析成功时返;resource_not_found / 无 ref 时缺省)",
      },
    },
    "required": [
      "allow",
      "reason",
    ],
    "type": "object",
  },
  "BatchCreateRoleBindingsDto": {
    "properties": {
      "items": {
