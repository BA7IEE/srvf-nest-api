  "/api/admin/v1/attachments": {
    "get": {
      "operationId": "AttachmentsController_list",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按 ownerType 过滤(精确匹配)",
          "in": "query",
          "name": "ownerType",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按 ownerId 过滤(精确匹配)",
          "in": "query",
          "name": "ownerId",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按 uploadedBy 过滤(精确匹配)",
          "in": "query",
          "name": "uploadedBy",
          "required": false,
          "schema": {
            "type": "string",
          },
        },
        {
          "description": "按 MIME 过滤(精确匹配)",
          "in": "query",
          "name": "mime",
          "required": false,
          "schema": {
            "maxLength": 128,
            "type": "string",
          },
        },
        {
          "description": "按访问级别过滤",
          "in": "query",
          "name": "accessLevel",
          "required": false,
          "schema": {
            "enum": [
              "PUBLIC",
              "INTERNAL",
              "SENSITIVE",
            ],
            "type": "string",
          },
        },
        {
          "description": "按 tag 过滤(含任意 tag 即命中 OR 语义;沿 D7 v0.2 锁;支持单值 \`?tags=foo\` 或多值 \`?tags=a&tags=b\`)",
          "in": "query",
          "name": "tags",
          "required": false,
          "schema": {
            "items": {
              "type": "string",
            },
            "maxItems": 20,
            "type": "array",
          },
        },
      ],
