    "required": [
      "activity",
      "sheet",
      "records",
    ],
    "type": "object",
  },
  "AuditContextDto": {
    "properties": {
      "after": {
        "additionalProperties": true,
        "description": "操作后的资源快照(softDelete 场景无;敏感字段已由 service 调用方打码)",
        "nullable": true,
        "type": "object",
      },
      "before": {
        "additionalProperties": true,
        "description": "操作前的资源快照(create 场景无;敏感字段已由 service 调用方打码)",
        "nullable": true,
        "type": "object",
      },
      "extra": {
        "additionalProperties": true,
        "description": "调用方自定义 metadata(targetMemberId / operation 等;非敏感字段)",
        "nullable": true,
        "type": "object",
      },
      "ip": {
        "description": "请求来源 IP(request.ip;测试 / 内部调用可能为 null)",
        "example": "127.0.0.1",
        "nullable": true,
        "type": "object",
      },
      "requestId": {
        "description": "请求 ID(nestjs-pino req.id;非空字符串),用于跨日志关联",
        "example": "c1xqgkb0000001abcdef234567",
        "type": "string",
      },
      "ua": {
        "description": "User-Agent(request.headers["user-agent"];curl / 内部调用可能为 null)",
        "example": "Mozilla/5.0 ...",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "requestId",
    ],
    "type": "object",
  },
  "AuditLogResponseDto": {
    "properties": {
      "actorRoleSnap": {
        "description": "操作时的角色快照(Role enum;事后查 user 表取最新角色不可靠,审计取快照)",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "nullable": true,
        "type": "string",
      },
      "actorUserId": {
        "description": "操作人 User.id;系统操作 / 未登录场景为 null",
        "nullable": true,
        "type": "object",
      },
      "context": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AuditContextDto",
          },
        ],
        "description": "审计上下文(AuditContext 锁形 6 字段:3 必填 + 3 可选)",
      },
      "createdAt": {
        "description": "审计记录写入时间(=操作发生时间,审计记录不可改不可删)",
        "format": "date-time",
        "type": "string",
      },
      "event": {
        "description": "审计事件(AuditLogEvent union 同值;String 不用 Prisma enum)",
        "example": "emergency-contact.write",
        "type": "string",
      },
      "id": {
        "description": "主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "resourceId": {
        "description": "资源 ID(create 失败时可为 null)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "nullable": true,
        "type": "object",
      },
      "resourceType": {
        "description": "资源类型(第一批枚举值:emergency_contact / certificate;String,不用 Prisma enum)",
        "example": "emergency_contact",
        "type": "string",
      },
      "success": {
        "description": "操作是否成功(D-B fail-fast:audit 与业务同事务,失败回滚整体;现仅 true)",
        "example": true,
        "type": "boolean",
      },
    },
    "required": [
      "id",
      "createdAt",
      "resourceType",
      "event",
      "context",
      "success",
    ],
    "type": "object",
  },
  "BatchMarkThresholdDto": {
    "properties": {
      "completed": {
        "description": "true=标记完成;false=清除标记(逐行幂等,复用单行 markThreshold)",
        "type": "boolean",
      },
      "cycleId": {
        "description": "限定轮次(**强烈建议**:手机/姓名跨轮去歧义;缺省跨全部未软删报名匹配)",
        "type": "string",
      },
      "matches": {
        "description": "匹配项数组(临时编号 / 手机 / 姓名+手机;「签到记录导入」= 前端解析签到表为本数组,后端不碰文件)",
        "items": {
          "$ref": "#/components/schemas/BatchMarkThresholdMatchDto",
        },
        "type": "array",
      },
      "thresholdCode": {
        "description": "门槛 code",
        "enum": [
          "patrol1",
          "patrol2",
          "training",
          "redCross",
          "bsafe",
        ],
        "type": "string",
      },
    },
    "required": [
      "thresholdCode",
      "completed",
      "matches",
    ],
    "type": "object",
  },
  "BatchMarkThresholdMatchDto": {
    "properties": {
      "phone": {
        "description": "手机号(配合 realName = 姓名+手机;单用须本轮唯一命中,否则 ambiguous)",
        "type": "string",
      },
      "realName": {
        "description": "真实姓名(须配合 phone;姓名单键不作为匹配键)",
        "type": "string",
      },
      "tempNo": {
        "description": "临时编号 T{year}{seq}(最精确匹配键;优先)",
        "type": "string",
      },
    },
    "type": "object",
  },
  "BatchMarkThresholdResultDto": {
    "properties": {
      "autoAdvanced": {
        "description": "本批标记后处于待综合评定态的行数(末次门槛完成自动推进)",
        "type": "number",
      },
      "failed": {
        "description": "命中但标记失败数(状态非法等;逐行容错,不整批回滚)",
        "type": "number",
      },
      "marked": {
        "description": "已标记数(含幂等重标)",
        "type": "number",
      },
      "results": {
        "description": "逐行结果(与入参 matches 同序)",
        "items": {
          "$ref": "#/components/schemas/BatchMarkThresholdRowResultDto",
        },
        "type": "array",
      },
      "total": {
        "description": "入参总行数",
        "type": "number",
      },
      "unmatched": {
        "description": "匹配不上数(no-match / ambiguous / insufficient-key)",
        "type": "number",
      },
    },
    "required": [
      "results",
      "total",
      "marked",
      "unmatched",
      "failed",
      "autoAdvanced",
    ],
    "type": "object",
  },
  "BatchMarkThresholdRowResultDto": {
    "properties": {
      "applicationId": {
        "description": "命中的报名 id(matched/failed 时)",
        "nullable": true,
        "type": "object",
      },
      "errorCode": {
        "description": "failed 业务错误码(如 28041 状态非法)",
        "nullable": true,
        "type": "object",
      },
      "index": {
        "description": "对应入参 matches 的下标(前端按此回填行)",
        "type": "number",
      },
      "matchedBy": {
        "description": "匹配方式 tempNo / name+phone / phone(命中时)",
        "nullable": true,
        "type": "object",
      },
      "status": {
        "description": "逐行结果:marked(已标,幂等)/ unmatched(匹配不上)/ failed(命中但标记失败,如状态非法)",
        "type": "string",
      },
      "statusCode": {
        "description": "标记后报名态(marked 时;= pending_evaluation 即末次门槛完成自动推进)",
        "nullable": true,
        "type": "object",
      },
      "thresholdsComplete": {
        "description": "门槛是否全完成(marked 时)",
        "nullable": true,
        "type": "object",
      },
      "unmatchedReason": {
        "description": "unmatched 原因:no-match(0 命中)/ ambiguous(多命中)/ insufficient-key(缺匹配键)",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "index",
      "status",
    ],
    "type": "object",
  },
  "BindMyPhoneDto": {
    "properties": {
      "code": {
        "description": "6 位数字验证码",
