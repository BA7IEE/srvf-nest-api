  "CertificateListItemDto": {
    "properties": {
      "certStatusCode": {
        "description": "核验状态字典 code(4 态闭集)",
        "type": "string",
      },
      "certSubTypeCode": {
        "description": "证书子类型 / 等级字典 code",
        "nullable": true,
        "type": "object",
      },
      "certTypeCode": {
        "description": "证书大类字典 code",
        "type": "string",
      },
      "createdAt": {
        "description": "创建时间",
        "format": "date-time",
        "type": "string",
      },
      "expiredAt": {
        "description": "到期日(NULL = 终身有效)",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "主键(cuid)",
        "type": "string",
      },
      "isInternal": {
        "description": "是否本会颁发",
        "type": "boolean",
      },
      "issuedAt": {
        "description": "颁发日期",
        "format": "date-time",
        "type": "string",
      },
      "issuingOrg": {
        "description": "颁发机构",
        "type": "string",
      },
      "memberId": {
        "description": "关联队员外键",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
    },
    "required": [
      "id",
      "memberId",
      "certTypeCode",
      "issuingOrg",
      "issuedAt",
      "certStatusCode",
      "isInternal",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
  "CertificateResponseDto": {
    "properties": {
      "certNumber": {
        "description": "证书编号(CT-5;中敏感;详情接口才返回)",
        "nullable": true,
        "type": "object",
      },
      "certStatusCode": {
        "description": "核验状态字典 code(CT-8;4 态闭集 pending / verified / expired / rejected)",
        "type": "string",
      },
      "certSubTypeCode": {
        "description": "证书子类型 / 等级字典 code(CT-3;字典 cert_sub_type;Q-D4 schema 可空)",
        "nullable": true,
        "type": "object",
      },
      "certTypeCode": {
        "description": "证书大类字典 code(CT-2;字典 cert_type)",
        "type": "string",
      },
      "createdAt": {
        "description": "创建时间",
        "format": "date-time",
        "type": "string",
      },
      "expiredAt": {
        "description": "到期日(CT-7;NULL = 终身有效;Q-S4)",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "isInternal": {
        "description": "是否本会颁发(CT-11;本批次 service 始终写 false)",
        "type": "boolean",
      },
      "issuedAt": {
        "description": "颁发日期(CT-6;ISO 8601)",
        "format": "date-time",
        "type": "string",
      },
      "issuingOrg": {
        "description": "颁发机构(CT-4;自由文本)",
        "type": "string",
      },
      "memberId": {
        "description": "关联队员外键(指向 members.id;N:1)",
        "type": "string",
      },
      "supersededByCertId": {
        "description": "替代关系:被替代的旧证书 id(CT-12;不做反向冗余,Q-S6 / Q-D2)",
        "nullable": true,
        "type": "object",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "verifiedAt": {
        "description": "核验时间(CT-9b)",
        "nullable": true,
        "type": "object",
      },
      "verifiedBy": {
        "description": "核验人 Member.id(CT-9a;待核验态空;Q-I2:user 无 memberId 时为 null)",
        "nullable": true,
        "type": "object",
      },
      "verifyNote": {
        "description": "核验备注(CT-9c;中敏感;长度 ≤ 500)",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "id",
      "memberId",
      "certTypeCode",
      "issuingOrg",
      "issuedAt",
      "certStatusCode",
      "isInternal",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
  "ChangeMyPasswordDto": {
    "properties": {
