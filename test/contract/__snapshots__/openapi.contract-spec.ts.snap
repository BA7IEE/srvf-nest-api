  "ExplainAuthzBatchDto": {
    "properties": {
      "items": {
        "description": "待解释项列表(≤200;逐条独立判定,decision 互不影响)",
        "items": {
          "$ref": "#/components/schemas/ExplainBatchItemDto",
        },
        "type": "array",
      },
    },
    "required": [
      "items",
    ],
    "type": "object",
  },
  "ExplainAuthzBatchResponseDto": {
    "properties": {
      "items": {
        "items": {
          "$ref": "#/components/schemas/ExplainBatchResultItemDto",
        },
        "type": "array",
      },
    },
    "required": [
      "items",
    ],
    "type": "object",
  },
  "ExplainAuthzDto": {
    "properties": {
      "action": {
        "description": "action 权限码,格式 <module>.<action>.<resource_type>[.<scope>](D2 v1.2 正则口径;不要求码存在 —— 不存在的码返 no_permission 即诊断结论)",
        "example": "attendance.final-approve.sheet",
        "type": "string",
      },
      "resourceRef": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ExplainResourceRefDto",
          },
        ],
        "description": "可选资源引用;缺省 = 无 ref 退化路径(等价 rbac.can 全局判定)",
      },
      "userId": {
        "description": "目标用户 id(被解释判权的人,非调用者);不存在/已软删 → 10001",
        "type": "string",
      },
    },
    "required": [
      "userId",
      "action",
    ],
    "type": "object",
  },
  "ExplainAuthzResponseDto": {
    "properties": {
      "decision": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AuthzDecisionDto",
          },
        ],
        "description": "判权决断(PR8 AuthzService.explain 原样输出:allow + reason + matchedGrant? + resource?)",
      },
      "targetUser": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ExplainTargetUserDto",
          },
        ],
        "description": "目标用户快照(id / username / role / status / memberId)",
      },
    },
    "required": [
      "targetUser",
      "decision",
    ],
    "type": "object",
  },
  "ExplainBatchItemDto": {
    "properties": {
      "action": {
        "description": "action 权限码(D2 v1.2 正则口径;不要求码存在,同单条 explain)",
        "example": "attendance.final-approve.sheet",
        "type": "string",
      },
      "resourceRef": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ExplainResourceRefDto",
          },
        ],
        "description": "可选资源引用;缺省 = 无 ref 退化路径(等价 rbac.can 全局判定)",
      },
      "userId": {
        "description": "目标用户 id(被解释判权的人,非调用者)",
        "type": "string",
      },
    },
    "required": [
      "userId",
      "action",
    ],
    "type": "object",
  },
  "ExplainBatchResultItemDto": {
    "properties": {
      "action": {
        "description": "action 权限码(入参回显)",
        "type": "string",
      },
      "decision": {
        "allOf": [
          {
            "$ref": "#/components/schemas/AuthzDecisionDto",
          },
        ],
        "description": "判权决断(同单条 explain:reason 同一套 11 值稳定枚举;deny 是 200 数据)",
      },
      "resourceRef": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ExplainResourceRefDto",
          },
        ],
        "description": "资源引用(入参回显;未传则缺省)",
      },
      "userId": {
        "description": "目标用户 id(入参回显)",
        "type": "string",
      },
    },
    "required": [
      "userId",
      "action",
      "decision",
    ],
    "type": "object",
  },
  "ExplainResourceRefDto": {
    "properties": {
      "id": {
        "description": "资源主键 id",
        "type": "string",
      },
      "type": {
        "description": "资源类型(ResourceResolver 支持的 11 类;冻结稿 §5.1)",
        "enum": [
          "activity",
          "attendance_sheet",
          "attendance_record",
          "activity_registration",
          "member",
          "member_profile",
          "certificate",
          "team_join_application",
          "recruitment_application",
          "notification",
          "attachment",
        ],
        "example": "attendance_sheet",
        "type": "string",
      },
    },
    "required": [
      "type",
      "id",
    ],
    "type": "object",
  },
  "ExplainTargetUserDto": {
    "properties": {
      "id": {
        "description": "目标用户 id",
        "type": "string",
      },
      "memberId": {
        "description": "绑定的 member id(未绑定为 null)",
        "nullable": true,
        "type": "object",
      },
      "role": {
        "description": "内置角色",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "example": "USER",
        "type": "string",
      },
      "status": {
        "description": "账号状态(原样返;DISABLED 用户也可 explain —— 线上真实请求会先被 JwtStrategy 挡,此字段让运营看清这一层)",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "username": {
        "description": "用户名",
        "type": "string",
      },
    },
    "required": [
      "id",
      "username",
      "role",
      "status",
    ],
    "type": "object",
  },
  "ExportRecruitmentApplicationsDto": {
    "properties": {
      "cycleId": {
        "description": "限定轮次(缺省导出全部未软删报名)",
        "type": "string",
      },
      "filter": {
        "description": "筛选:all 全部 / manual 待人工 / verified 已初审 / threshold-incomplete 门槛未完成 / pending-evaluation 待评定 / publicity 公示 / promoted 发号 / rejected 淘汰;缺省 all",
        "enum": [
          "all",
          "manual",
          "verified",
          "threshold-incomplete",
          "pending-evaluation",
          "publicity",
          "promoted",
          "rejected",
          "withdrawn",
        ],
        "type": "string",
      },
    },
    "type": "object",
  },
