        "description": "备注",
        "maxLength": 500,
        "type": "string",
      },
      "registrationId": {
        "description": "关联报名 ActivityRegistration.id(可空;有报名来源时关联;R23 跨表校验)",
        "maxLength": 64,
        "minLength": 8,
