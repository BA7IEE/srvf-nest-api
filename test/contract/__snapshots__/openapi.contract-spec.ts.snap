        "type": "string",
      },
      "username": {
        "description": "用户名(归一化为小写)",
        "example": "admin",
        "type": "string",
      },
    },
    "required": [
      "id",
      "username",
      "role",
      "status",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
  "UserRoleResponseDto": {
    "properties": {
      "createdAt": {
        "description": "关系创建时间",
        "format": "date-time",
        "type": "string",
      },
      "createdByUserId": {
        "description": "分配人 User.id(沿 D11 audit 字段;可空表示历史 seed 或 createdBy SetNull)",
        "nullable": true,
        "type": "string",
      },
      "id": {
        "description": "主键(UserRole.id;cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "roleCode": {
        "description": "角色 code(扁平化;沿 D7 §5.2.6)",
        "example": "apd-chief",
        "type": "string",
      },
      "roleDisplayName": {
        "description": "角色显示名(扁平化;沿 D7 §5.2.6)",
        "example": "部门部长",
        "type": "string",
      },
      "roleId": {
        "description": "角色 id(RbacRole.id;cuid)",
        "type": "string",
      },
    },
    "required": [
      "id",
      "roleId",
      "roleCode",
      "roleDisplayName",
      "createdAt",
      "createdByUserId",
    ],
    "type": "object",
  },
  "VerifyCertificateDto": {
    "properties": {
      "verifyNote": {
        "description": "核验备注(可选)",
        "maxLength": 500,
        "type": "string",
      },
    },
    "type": "object",
  },
}
`;

