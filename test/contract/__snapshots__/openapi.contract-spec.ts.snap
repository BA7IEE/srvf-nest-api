        "type": "object",
      },
      "id": {
        "description": "主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "isVeteran": {
        "description": "是否退伍军人(MP-8)",
        "nullable": true,
        "type": "object",
      },
      "joinSourceCode": {
        "description": "加入来源字典 code(MP-28;候选字典 join_source)",
        "type": "string",
      },
      "joinedDate": {
        "description": "加入日期(MP-27;ISO 8601)",
        "format": "date-time",
        "type": "string",
      },
      "landline": {
        "description": "座机(MP-16;选填;无 sensitive 码时为 null,十项收口刀D)",
