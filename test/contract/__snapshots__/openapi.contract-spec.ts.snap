  "BatchMarkThresholdDto": {
    "properties": {
      "completed": {
        "description": "true=标记完成;false=清除标记(逐行幂等,复用单行 markThreshold)",
        "type": "boolean",
      },
      "cycleId": {
        "description": "限定轮次(**强烈建议**:手机/姓名跨轮去歧义;缺省跨全部未软删报名匹配)",
        "type": "string",
      },
      "matches": {
        "description": "匹配项数组(临时编号 / 手机 / 姓名+手机;「签到记录导入」= 前端解析签到表为本数组,后端不碰文件)",
        "items": {
          "$ref": "#/components/schemas/BatchMarkThresholdMatchDto",
        },
        "type": "array",
      },
      "thresholdCode": {
        "description": "门槛 code",
        "enum": [
          "patrol1",
          "patrol2",
          "training",
          "redCross",
          "bsafe",
        ],
        "type": "string",
      },
    },
    "required": [
      "thresholdCode",
      "completed",
      "matches",
    ],
    "type": "object",
  },
  "BatchMarkThresholdMatchDto": {
    "properties": {
      "phone": {
        "description": "手机号(配合 realName = 姓名+手机;单用须本轮唯一命中,否则 ambiguous)",
        "type": "string",
      },
      "realName": {
        "description": "真实姓名(须配合 phone;姓名单键不作为匹配键)",
        "type": "string",
      },
      "tempNo": {
        "description": "临时编号 T{year}{seq}(最精确匹配键;优先)",
        "type": "string",
      },
    },
    "type": "object",
  },
  "BatchMarkThresholdResultDto": {
    "properties": {
      "autoAdvanced": {
        "description": "本批标记后处于待综合评定态的行数(末次门槛完成自动推进)",
        "type": "number",
      },
      "failed": {
        "description": "命中但标记失败数(状态非法等;逐行容错,不整批回滚)",
        "type": "number",
      },
      "marked": {
        "description": "已标记数(含幂等重标)",
        "type": "number",
      },
      "results": {
        "description": "逐行结果(与入参 matches 同序)",
        "items": {
          "$ref": "#/components/schemas/BatchMarkThresholdRowResultDto",
        },
        "type": "array",
      },
      "total": {
        "description": "入参总行数",
        "type": "number",
      },
      "unmatched": {
        "description": "匹配不上数(no-match / ambiguous / insufficient-key)",
        "type": "number",
      },
    },
    "required": [
      "results",
      "total",
      "marked",
      "unmatched",
      "failed",
      "autoAdvanced",
    ],
    "type": "object",
  },
  "BatchMarkThresholdRowResultDto": {
    "properties": {
      "applicationId": {
        "description": "命中的报名 id(matched/failed 时)",
        "nullable": true,
        "type": "object",
      },
      "errorCode": {
        "description": "failed 业务错误码(如 28041 状态非法)",
        "nullable": true,
        "type": "object",
      },
      "index": {
        "description": "对应入参 matches 的下标(前端按此回填行)",
        "type": "number",
      },
      "matchedBy": {
        "description": "匹配方式 tempNo / name+phone / phone(命中时)",
        "nullable": true,
        "type": "object",
      },
      "status": {
        "description": "逐行结果:marked(已标,幂等)/ unmatched(匹配不上)/ failed(命中但标记失败,如状态非法)",
        "type": "string",
      },
      "statusCode": {
        "description": "标记后报名态(marked 时;= pending_evaluation 即末次门槛完成自动推进)",
        "nullable": true,
        "type": "object",
      },
      "thresholdsComplete": {
        "description": "门槛是否全完成(marked 时)",
        "nullable": true,
        "type": "object",
      },
      "unmatchedReason": {
        "description": "unmatched 原因:no-match(0 命中)/ ambiguous(多命中)/ insufficient-key(缺匹配键)",
        "nullable": true,
        "type": "object",
      },
    },
    "required": [
      "index",
      "status",
    ],
    "type": "object",
  },
  "BindMemberAccountDto": {
    "properties": {
      "userId": {
        "description": "待绑定的既有账号 id(必须 live 且当前 memberId 为 null)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "maxLength": 64,
        "minLength": 8,
        "type": "string",
      },
    },
    "required": [
      "userId",
    ],
    "type": "object",
  },
  "BindMyPhoneDto": {
    "properties": {
      "code": {
        "description": "6 位数字验证码",
        "example": "123456",
        "type": "string",
      },
      "phone": {
        "description": "要绑定的大陆手机号(11 位;须与 send-code 时一致)",
        "example": "13800001234",
        "type": "string",
      },
    },
    "required": [
      "phone",
      "code",
    ],
    "type": "object",
  },
  "BindMyWechatDto": {
    "properties": {
