  "LoginDto": {
    "properties": {
      "password": {
        "description": "密码(明文,服务端用 bcrypt 比对);此接口刻意不做长度规则校验",
        "example": "YourPassword123",
        "format": "password",
        "type": "string",
      },
      "username": {
        "description": "用户名(允许字母 / 数字 / 下划线 / 中横线,长度 3-32);service 内部统一 trim + lowercase 后用于查询",
