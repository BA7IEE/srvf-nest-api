  "UpdateStorageSettingsDto": {
    "properties": {
      "allowedMimePolicyMode": {
        "description": "mime 策略模式(INHERIT / OVERRIDE;沿 Q-11-12)",
        "enum": [
          "INHERIT",
          "OVERRIDE",
