          "ADMIN",
          "USER",
        ],
        "example": "USER",
        "type": "string",
      },
      "status": {
        "description": "状态",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "username": {
        "description": "用户名(归一化为小写)",
        "example": "admin",
        "type": "string",
      },
    },
    "required": [
      "id",
      "username",
      "role",
      "status",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
}
`;

