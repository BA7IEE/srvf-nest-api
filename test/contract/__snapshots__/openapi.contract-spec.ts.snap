            "wechat",
            "sms",
          ],
          "type": "string",
        },
        "type": "array",
      },
      "notificationTypeCode": {
        "description": "通知类型(notification_type 字典 ACTIVE item;失败 → 31010)",
        "maxLength": 64,
        "type": "string",
      },
      "pinned": {
        "default": false,
        "description": "是否置顶",
        "type": "boolean",
      },
      "title": {
        "description": "标题",
        "maxLength": 200,
        "type": "string",
      },
      "visibilityCode": {
        "description": "可见档(每条选一,去 public = 4 档;失败 → 31011)",
        "enum": [
