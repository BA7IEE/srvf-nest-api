        "type": "string",
      },
    },
    "required": [
      "status",
    ],
    "type": "object",
  },
  "UserResponseDto": {
    "properties": {
      "avatarKey": {
        "description": "头像 key",
        "nullable": true,
        "type": "object",
      },
      "createdAt": {
        "description": "创建时间",
        "format": "date-time",
        "type": "string",
      },
      "email": {
        "description": "邮箱",
        "example": "admin@example.com",
        "nullable": true,
        "type": "object",
      },
      "id": {
        "description": "用户主键(cuid)",
        "example": "cl9z3a8b00000abcd1234efgh",
        "type": "string",
      },
      "lastLoginAt": {
        "description": "最近一次登录时间",
        "nullable": true,
        "type": "object",
      },
      "nickname": {
        "description": "昵称",
        "nullable": true,
        "type": "object",
      },
      "role": {
        "description": "角色",
        "enum": [
          "SUPER_ADMIN",
          "ADMIN",
          "USER",
        ],
        "example": "USER",
        "type": "string",
      },
      "status": {
        "description": "状态",
        "enum": [
          "ACTIVE",
          "DISABLED",
        ],
        "example": "ACTIVE",
        "type": "string",
      },
      "updatedAt": {
        "description": "更新时间",
        "format": "date-time",
        "type": "string",
      },
      "username": {
        "description": "用户名(归一化为小写)",
        "example": "admin",
        "type": "string",
      },
    },
    "required": [
      "id",
      "username",
      "role",
      "status",
      "createdAt",
      "updatedAt",
    ],
    "type": "object",
  },
}
`;

