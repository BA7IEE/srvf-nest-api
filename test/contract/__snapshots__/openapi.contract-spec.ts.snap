          "description": "按承办组织过滤(经活动 organizationId;仅 admin/v1/registrations 全局横扫生效)",
          "in": "query",
          "name": "organizationId",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
