          "schema": {
            "maxLength": 64,
            "minLength": 8,
            "type": "string",
          },
        },
        {
          "description": "scope 类型(GLOBAL / ORGANIZATION / ORGANIZATION_TREE / ACTIVITY / RESOURCE / SELF)",
          "in": "query",
          "name": "scopeType",
          "required": true,
          "schema": {
            "enum": [
              "GLOBAL",
              "ORGANIZATION",
              "ORGANIZATION_TREE",
              "ACTIVITY",
              "RESOURCE",
              "SELF",
            ],
            "example": "GLOBAL",
            "type": "string",
          },
        },
        {
          "description": "scope 组织 id(ORGANIZATION / ORGANIZATION_TREE 必填)",
          "in": "query",
