  "/api/v2/activities": {
    "get": {
      "operationId": "ActivitiesController_list",
      "parameters": [
        {
          "description": "页码",
          "in": "query",
          "name": "page",
          "required": false,
          "schema": {
            "default": 1,
            "example": 1,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "每页数量",
          "in": "query",
          "name": "pageSize",
          "required": false,
          "schema": {
            "default": 20,
            "example": 20,
            "maximum": 100,
            "minimum": 1,
            "type": "number",
          },
        },
        {
          "description": "按活动状态过滤(USER 角色 service 层忽略)",
          "in": "query",
          "name": "statusCode",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
        {
          "description": "按活动类型字典 code 过滤",
          "in": "query",
          "name": "activityTypeCode",
          "required": false,
          "schema": {
            "maxLength": 64,
            "type": "string",
          },
        },
