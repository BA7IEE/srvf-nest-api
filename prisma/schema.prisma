// AI 友好 NestJS API 底座 — Prisma schema
// 本文件按 ARCHITECTURE.md §5 1:1 落地,任何字段调整必须先回到 ARCHITECTURE.md 评审。
// V2 第一阶段(ARCHITECTURE.md §12.8)新增 5 model + User.memberId 兼容性追加,
// 详见 docs/v2-data-model.md / docs/v2-plan.md §2.1。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String?    @unique
  passwordHash String
  nickname     String?
  avatarKey    String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  deletedAt    DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  memberId String? @unique
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  // V2 第一阶段批次 3 反向 relation(详见 docs:批次3_schema草案_*.md §12.1)
  // 沿批次 1 / 批次 2 R2 范式:Prisma 关系映射不算业务字段新增。
  activitiesPublished       Activity[]             @relation("ActivityPublisher")
  activitiesCancelled       Activity[]             @relation("ActivityCanceller")
  registrationsReviewed     ActivityRegistration[] @relation("RegistrationReviewer")
  registrationsCancelled    ActivityRegistration[] @relation("RegistrationCanceller")
  attendanceSheetsSubmitted AttendanceSheet[]      @relation("SheetSubmitter")
  attendanceSheetsReviewed  AttendanceSheet[]      @relation("SheetReviewer")

  @@index([deletedAt])
  @@index([status])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

// ===== V2 第一阶段:dictionaries 双表 =====

model DictType {
  id        String         @id @default(cuid())
  code      String         @unique
  label     String
  status    DictTypeStatus @default(ACTIVE)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  items DictItem[]

  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum DictTypeStatus {
  ACTIVE
  INACTIVE
}

model DictItem {
  id        String         @id @default(cuid())
  typeId    String
  code      String
  label     String
  parentId  String?
  sortOrder Int            @default(0)
  status    DictItemStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  type     DictType   @relation(fields: [typeId], references: [id], onDelete: Restrict)
  parent   DictItem?  @relation("DictItemTree", fields: [parentId], references: [id], onDelete: Restrict)
  children DictItem[] @relation("DictItemTree")

  @@unique([typeId, code])
  @@index([typeId])
  @@index([parentId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum DictItemStatus {
  ACTIVE
  INACTIVE
}

// ===== V2 第一阶段:organizations =====

model Organization {
  id           String             @id @default(cuid())
  name         String
  parentId     String?
  nodeTypeCode String
  sortOrder    Int                @default(0)
  status       OrganizationStatus @default(ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  parent            Organization?      @relation("OrganizationTree", fields: [parentId], references: [id], onDelete: Restrict)
  children          Organization[]     @relation("OrganizationTree")
  memberDepartments MemberDepartment[]

  // V2 第一阶段批次 3 反向 relation(沿批次 1 / 批次 2 R2 范式)
  activities Activity[]

  @@index([parentId])
  @@index([nodeTypeCode])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

// ===== V2 第一阶段:members =====

model Member {
  id          String       @id @default(cuid())
  memberNo    String       @unique
  displayName String
  gradeCode   String?
  status      MemberStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  user                 User?
  memberDepartments    MemberDepartment[]
  // V2 第一阶段批次 1:扩展模块反向 relation;主表既有业务字段语义不变,
  // 不在 Member 主表新增任何业务字段(顶层 §11 K1 + 批次 1 schema 草案 R2)。
  memberProfile        MemberProfile?
  emergencyContacts    EmergencyContact[]
  // V2 第一阶段批次 2:Certificate 两条反向 relation;同样仅 Prisma 关系映射,
  // 不算业务字段新增(批次 2 schema 草案 v1.0 §7 / R2);
  // verifier 角色由 service 层判定,schema 不约束。
  certificates         Certificate[]      @relation("CertificateMember")
  certificatesVerified Certificate[]      @relation("CertificateVerifier")

  // V2 第一阶段批次 3 反向 relation(沿批次 1 / 批次 2 R2 范式)
  activityRegistrations ActivityRegistration[]
  attendanceRecords     AttendanceRecord[]

  @@index([gradeCode])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

// ===== V2 第一阶段:member_departments =====
//
// 单归属唯一约束(memberId 在 deletedAt IS NULL 范围内唯一)由 migration.sql
// 末尾手动追加 partial unique index 实现 — Prisma DSL 至 6.x 不支持
// 在 @@unique 中表达带 WHERE 的部分唯一索引。详见 docs/v2-data-model.md §6.3
// 与 docs/v2-plan.md §2.1 决策点 D-1。

model MemberDepartment {
  id             String    @id @default(cuid())
  memberId       String
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([memberId])
  @@index([organizationId])
  @@index([deletedAt])
  @@index([createdAt])
}

// ===== V2 第一阶段批次 1:member_profiles =====
//
// 1:1 with Member;承载实名 / 联系方式 / 医疗类等敏感资料。
// 详见 docs:批次1_schema草案_member_profiles_emergency_contacts.md (v1.0 冻结版)。
//
// 设计选择(B 路径,2026-05-10):
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担(与 v0.2.0 现有模型一致)。
// - 纯日期字段(birthDate / joinedDate / privacyConsentSignedAt)统一 DateTime,
//   业务层按 00:00:00.000Z 规范化处理(不落 @db.Date)。
//
// NOT NULL 字段(草案 §7 第一档):realName / genderCode / birthDate / documentTypeCode /
//   documentNumber / mobile / email / joinedDate / joinSourceCode / privacyConsentSigned。
// 其余字段 schema 可空(兼容 3000+ 历史档案缺字段);DTO 层按"业务必填"严格校验。

model MemberProfile {
  id        String    @id @default(cuid())
  memberId  String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ===== 报名表必填基础信息 =====
  realName            String // MP-1
  genderCode          String // MP-2 字典 gender
  birthDate           DateTime // MP-3 业务层按日期 00:00:00.000Z 规范化
  documentTypeCode    String // MP-4 字典 document_type
  documentNumber      String // MP-5 高敏感
  ethnicityCode       String? // MP-6 字典 ethnicity(候选,运营层后录入)
  politicalStatusCode String? // MP-7 字典 political_status
  isVeteran           Boolean? // MP-8
  maritalStatusCode   String? // MP-9 字典 marital_status(候选)
  educationCode       String? // MP-10 字典 education(候选)
  major               String? // MP-11 自由文本
  workNatureCode      String? // MP-12 字典 work_nature(只存性质,不存单位)
  residenceArea       String? // MP-13 行政区粒度
  workArea            String? // MP-14 行政区粒度
  mobile              String // MP-15 高敏感
  landline            String? // MP-16 报名表选填
  email               String // MP-17
  qq                  String? // MP-18a
  wechat              String? // MP-18b

  // ===== 报名表必填医疗类(高敏感) =====
  heightCm      Int? // MP-19a 自填,不强制体测核验
  weightKg      Int? // MP-19b
  bloodTypeCode String? // MP-19c 字典 blood_type
  eyesight      String? // MP-20 报名表选填
  medicalNotes  Json? // MP-21 JSON 数组,元素 {categoryCode, note}(Q-S01)

  // ===== 报名表必填能力特长 =====
  hasVehicle            Boolean? // MP-22a
  vehicleType           String? // MP-22b
  exerciseFrequencyCode String? // MP-23a 字典 exercise_frequency(候选)
  exerciseSportCode     String? // MP-23b 字典 exercise_sport(候选)
  exerciseMethods       String[] // MP-23c PG 原生数组,字典 exercise_method codes(Q-S02)
  firstAidKnowledgeCode String? // MP-24 字典 first_aid_knowledge(候选)
  firstAidSkills        String[] // MP-25 PG 原生数组,字典 first_aid_skill codes(Q-S03)
  otherSkills           String? // MP-26 长文本

  // ===== 内部档案补充 =====
  joinedDate             DateTime // MP-27 加入日期,业务层按日期规范化
  joinSourceCode         String // MP-28 字典 join_source(候选)
  noCriminalRecordSigned Boolean? // MP-29 是否签署无违法犯罪声明
  privacyConsentSigned   Boolean // MP-30a 是否授权(NOT NULL)
  privacyConsentSignedAt DateTime? // MP-30b 授权时间(Q-S05 保留)

  // ===== 外部记录字段 =====
  volunteerNo String? // MP-31 义工号,不参与登录/权限/身份识别(草案 §3)

  member Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([volunteerNo])
  @@index([deletedAt])
  @@index([createdAt])
}

// ===== V2 第一阶段批次 1:emergency_contacts =====
//
// N:1 with Member;不限数量,priority 整数排序(允许并列,Q-S09)。
// 联系人不视为系统用户,不需联系人单独签授权(EC-8 不做,Q025)。
// 软删走 deletedAt,不物理删(Q-S10)。

model EmergencyContact {
  id        String    @id @default(cuid())
  memberId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contactName  String // EC-2
  relationCode String // EC-3 字典 emergency_relation
  phonePrimary String // EC-4
  phoneBackup  String? // EC-5
  address      String? // EC-6
  priority     Int     @default(0) // EC-7 0 = 最高;允许并列

  member Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([memberId])
  @@index([memberId, priority])
  @@index([deletedAt])
  @@index([createdAt])
}

// ===== V2 第一阶段批次 2:certificates =====
//
// N:1 with Member;承载外部资质 + 本会颁发证书(同表承载,CT-11)。
// 详见 docs:
//   - 批次2_schema草案_certificates.md (v1.0 冻结版)
//   - 批次2_schema草案评审决议表.md (Q-S1~Q-S10)
//   - 批次2_schema草案评审决议表_v0.1.md (Q-D1~Q-D8)
//
// 设计选择(沿批次 1 B 路径):
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担。
// - 纯日期字段(issuedAt / expiredAt / verifiedAt / expireNotifyDueAt)统一 DateTime,
//   业务层按 00:00:00.000Z 规范化处理(不落 @db.Date)。
// - 字典 code 字段(certTypeCode / certSubTypeCode / certStatusCode)schema 不做 FK,
//   业务层校验字典存在性(沿 v0.2.0 gradeCode / nodeTypeCode 模式)。
//
// FK(全部 ON DELETE Restrict,与 v0.2.0 + 批次 1 一致):
// - memberId           → Member.id            (CT-1)
// - verifiedBy         → Member.id            (CT-9a, Q-D1 已决议)
// - supersededByCertId → Certificate.id 自引用 (CT-12, Q-D2 已决议)
//
// 状态机:4 态闭集 (pending / verified / expired / rejected);
//   schema 不固化,由 service 层映射代码常量与 cert_status 字典 code。
//
// 索引:7 个单列;
//   Q-D6 不加 (expireNotifyDueAt) 单列索引;
//   Q-D8 不加 (memberId, certTypeCode, certStatusCode, expiredAt) 4 列复合索引;
//   Q-S6 不加 (memberId, certTypeCode) 联合索引。
//
// 业务唯一约束:无(草案 §11.2);仅 id 主键唯一。
//
// 软删:走 deletedAt;禁用 hard delete(R12)。
//
// CT-10 attachmentKey 仅占位字段,本批次始终 NULL;批次 6a 协议三要素接入(Q-S10)。

model Certificate {
  id        String    @id @default(cuid())
  memberId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ===== 业务字段(CT-2 ~ CT-12 + HK-1) =====
  certTypeCode       String // CT-2 字典 cert_type
  certSubTypeCode    String? // CT-3 字典 cert_sub_type;Q-D4 schema 可空
  issuingOrg         String // CT-4 自由文本;长度 128 由 DTO 约束
  certNumber         String? // CT-5 Q-D5 schema 可空;长度 128(Q-D3)由 DTO 约束
  issuedAt           DateTime // CT-6 业务层日期规范化
  expiredAt          DateTime? // CT-7 NULL = 终身有效(Q-S4)
  certStatusCode     String // CT-8 字典 cert_status;无 default,service 填 pending
  verifiedBy         String? // CT-9a FK→Member.id 可空(Q-D1)
  verifiedAt         DateTime? // CT-9b
  verifyNote         String? // CT-9c 长度 500(Q-S5)由 DTO 约束
  attachmentKey      String? // CT-10 长度 256;批次 6a 协议接入,本批次始终 NULL
  isInternal         Boolean   @default(false) // CT-11 是否本会颁发
  supersededByCertId String? // CT-12 自引用 FK 可空(Q-D2)
  expireNotifyDueAt  DateTime? // HK-1 60 天提醒 hook;Q-D6 不加索引

  member       Member        @relation("CertificateMember", fields: [memberId], references: [id], onDelete: Restrict)
  verifier     Member?       @relation("CertificateVerifier", fields: [verifiedBy], references: [id], onDelete: Restrict)
  supersededBy Certificate?  @relation("CertificateSupersession", fields: [supersededByCertId], references: [id], onDelete: Restrict)
  supersedes   Certificate[] @relation("CertificateSupersession")

  @@index([memberId])
  @@index([certTypeCode])
  @@index([certStatusCode])
  @@index([expiredAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([supersededByCertId])
}

// ===== V2 第一阶段批次 3:activities =====
//
// 详见 docs:
//   - 批次3_schema前评审.md v0.2.4 修正版
//   - 批次3_schema前评审决议表.md v1.0 定稿
//   - 批次3_schema草案_activities_attendances.md v0.5 草案版
//   - 批次3_schema草案评审决议表.md v1.4
//
// 设计选择(沿批次 1 / 批次 2 B 路径):
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担。
// - 字典 code 字段(activityTypeCode / statusCode 等)schema 不做 FK,
//   业务层校验字典存在性(沿 v0.2.0 范式)。
//
// FK(全部 ON DELETE Restrict):
// - organizationId  → Organization.id  (NOT NULL,service 校验禁根节点 R8 / D17)
// - publishedBy     → User.id          (可空,Q-S1 audit 字段落表)
// - cancelledBy     → User.id          (可空)
//
// 显式 @db.Decimal 注解(Q-D2 + Q-D19):
// - locationLongitude / locationLatitude → Decimal(10, 7)(WGS84 ~1.1 cm 精度)
//
// description 必须 String?(Q-D14 v1.4 必填性澄清,v0.5 修订):
// - 从 v0.1 沿用的 NOT NULL 改为 String? 可空
// - 语义:列表展示短说明 / 摘要;详情页正文走 content
//
// 索引:7 单列;v0.2 / v0.4 新增 5 字段(content / galleryImageUrls /
//   coverImageUrl / locationLongitude / locationLatitude)不加索引(沿 Q-D11/12/13/19)。
// 无唯一约束。

model Activity {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title                 String
  activityTypeCode      String
  organizationId        String
  startAt               DateTime
  endAt                 DateTime
  location              String
  description           String? // v0.5 修订(Q-D14 v1.4):NOT NULL → String? 可空
  capacity              Int?
  genderRequirementCode String?
  registrationDeadline  DateTime?
  registrationNotes     String?
  statusCode            String
  publishedBy           String?
  publishedAt           DateTime?
  cancelledBy           String?
  cancelledAt           DateTime?
  cancelReason          String?
  isPublicRegistration  Boolean   @default(true)
  registrationSchema    Json? // v0.2 D12 报名表自定义字段 schema 字段位预留

  // v0.2 展示内容字段(Q-D11 / Q-D12 / Q-D13)
  coverImageUrl    String?
  galleryImageUrls Json?
  content          Json?

  // v0.4 经纬度字段(Q-D19;显式 @db.Decimal(10, 7),WGS84 ~1.1 cm 精度)
  locationLongitude Decimal? @db.Decimal(10, 7)
  locationLatitude  Decimal? @db.Decimal(10, 7)

  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  publisher        User?                  @relation("ActivityPublisher", fields: [publishedBy], references: [id], onDelete: Restrict)
  canceller        User?                  @relation("ActivityCanceller", fields: [cancelledBy], references: [id], onDelete: Restrict)
  registrations    ActivityRegistration[]
  attendanceSheets AttendanceSheet[]

  @@index([deletedAt])
  @@index([createdAt])
  @@index([statusCode])
  @@index([organizationId])
  @@index([activityTypeCode])
  @@index([startAt])
  @@index([isPublicRegistration])
}

// ===== V2 第一阶段批次 3:activity_registrations =====
//
// statusCode 字典 4 态(Q-D15 v0.3):pending / pass / reject / cancelled
//
// FK(全部 ON DELETE Restrict):
// - activityId         → Activity.id           (NOT NULL)
// - memberId           → Member.id             (NOT NULL)
// - reviewedBy         → User.id               (可空,沿 Q-S4)
// - cancelledByUserId  → User.id               (可空,Q-D16 v0.3)
//
// 业务唯一约束(partial unique;Q-D4 + Q-D17 v1.2 修订):
// - (activityId, memberId) WHERE deleted_at IS NULL AND status_code != 'cancelled'
// - 索引名 activity_registrations_activity_member_active_unique
// - Prisma DSL 不支持带 WHERE,migration.sql 末尾手动追加(沿 MemberDepartment 范式)
//
// extras Json?(D12 字段位预留)。
//
// 索引:6 单列(activityId / memberId / statusCode / deletedAt / createdAt / registeredAt)。

model ActivityRegistration {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityId   String
  memberId     String
  statusCode   String
  registeredAt DateTime  @default(now())
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  extras       Json?

  // v0.3 新增 取消留痕(Q-D16)
  cancelledByUserId String?
  cancelledAt       DateTime?
  cancelReason      String?

  activity          Activity           @relation(fields: [activityId], references: [id], onDelete: Restrict)
  member            Member             @relation(fields: [memberId], references: [id], onDelete: Restrict)
  reviewer          User?              @relation("RegistrationReviewer", fields: [reviewedBy], references: [id], onDelete: Restrict)
  canceller         User?              @relation("RegistrationCanceller", fields: [cancelledByUserId], references: [id], onDelete: Restrict)
  attendanceRecords AttendanceRecord[]

  @@index([activityId])
  @@index([memberId])
  @@index([statusCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([registeredAt])
}

// ===== V2 第一阶段批次 3:attendance_sheets =====
//
// statusCode 字典 3 态(D18):pending / approved / rejected。
// version Int @default(1)(Q-D8 不做乐观锁,仅展示用)。
// previousSnapshot Json?(D38 / Q-D1 后端事务内自动生成)。
//
// FK(全部 ON DELETE Restrict):
// - activityId       → Activity.id  (NOT NULL,D47 一 Activity 多 Sheet / R30)
// - submitterUserId  → User.id      (NOT NULL,Q-S4 系统操作人)
// - reviewerUserId   → User.id      (可空,APD 审核员)
//
// 索引:7 单列。

model AttendanceSheet {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityId       String
  submitterUserId  String
  submittedAt      DateTime  @default(now())
  statusCode       String
  reviewerUserId   String?
  reviewedAt       DateTime?
  reviewNote       String?
  previousSnapshot Json? // D38 后端事务内自动生成
  version          Int       @default(1) // Q-D8 不做乐观锁;服务端版本号

  activity  Activity           @relation(fields: [activityId], references: [id], onDelete: Restrict)
  submitter User               @relation("SheetSubmitter", fields: [submitterUserId], references: [id], onDelete: Restrict)
  reviewer  User?              @relation("SheetReviewer", fields: [reviewerUserId], references: [id], onDelete: Restrict)
  records   AttendanceRecord[]

  @@index([activityId])
  @@index([submitterUserId])
  @@index([reviewerUserId])
  @@index([statusCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([submittedAt])
}

// ===== V2 第一阶段批次 3:attendance_records =====
//
// attendanceStatusCode 字典 3 态(D44 / D51 v0.2.4 撤销 absent / leave):
//   present / late / early_leave。
//
// roleCode 字典 7 项(D13):member / instructor / assistant / coach /
//   front_command / back_command / info。
//
// 显式 @db.Decimal 注解(Q-D2):
// - serviceHours        → Decimal(5, 2) NOT NULL,业务必填且 > 0,允许 < 跨度(D46)
// - contributionPoints  → Decimal(5, 2)? 字段层可空,业务 approved 前必填(R31)
//
// FK:
// - sheetId         → AttendanceSheet.id        (NOT NULL, Restrict, R20)
// - memberId        → Member.id                 (NOT NULL, Restrict)
// - registrationId  → ActivityRegistration.id   (可空,**Restrict** 不是 SetNull,Q-S21)
//
// 索引:7 单列 + 1 复合(memberId, deletedAt)用于时间不重叠校验性能(R16)。
// 业务唯一约束:无(D8 撤销 v0.1 AT-9)。

model AttendanceRecord {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sheetId              String
  memberId             String
  roleCode             String
  checkInAt            DateTime
  checkOutAt           DateTime
  serviceHours         Decimal   @db.Decimal(5, 2) // Q-D2 显式注解;必填且 > 0(D45/D51)
  attendanceStatusCode String
  note                 String?
  registrationId       String? // Q-D26 / D27 可空(临时参加 / 非公开报名)
  contributionPoints   Decimal?  @db.Decimal(5, 2) // Q-D2 + R31;字段层可空,APD approved 前必填

  sheet        AttendanceSheet       @relation(fields: [sheetId], references: [id], onDelete: Restrict)
  member       Member                @relation(fields: [memberId], references: [id], onDelete: Restrict)
  registration ActivityRegistration? @relation(fields: [registrationId], references: [id], onDelete: Restrict) // Q-S21:Restrict 不是 SetNull

  @@index([sheetId])
  @@index([memberId])
  @@index([registrationId])
  @@index([attendanceStatusCode])
  @@index([roleCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([memberId, deletedAt]) // R16 时间不重叠校验性能
}
