// AI 友好 NestJS API 底座 — Prisma schema
// 本文件按 ARCHITECTURE.md §5 1:1 落地,任何字段调整必须先回到 ARCHITECTURE.md 评审。
// V2 第一阶段(ARCHITECTURE.md §12.8)新增 5 model + User.memberId 兼容性追加,
// 详见 docs/v2-data-model.md / docs/v2-plan.md §2.1。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  email        String?    @unique
  passwordHash String
  nickname     String?
  avatarKey    String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  deletedAt    DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // SMS 基础设施 T1(2026-06-10;评审稿 docs/archive/reviews/sms-verification-infra-review.md §3.1):
  // 账号级手机号(非 Member.phonePrimary 队员联系电话,互不相干)。
  // @unique 全局唯一**含软删占用**(沿 AGENTS §10 username/email 不复用范式;
  // 预检查必须 findUnique 含软删,评审稿 E-7);admin 清除后两字段同置 null。
  phone           String?   @unique
  phoneVerifiedAt DateTime?

  // 微信小程序登录 T1(2026-06-12;评审稿 docs/archive/reviews/wechat-mini-login-review.md §3.1):
  // 微信小程序 openid,账号级身份字段(D-W2 最小字段集:不存 unionid / session_key / 绑定时间戳)。
  // @unique 全局唯一**含软删占用**(沿 phone/username 不复用范式;预检查必须 findUnique 含软删,
  // 评审稿 E-19);admin 清除置 null(解除绑定唯一路径,D-W3)。
  openid String? @unique

  // 队员账号闭环 v2(2026-07-07;评审稿 docs/archive/reviews/member-account-loop-v2-review.md
  // §3.1/E-1/E-2):去 @unique,改手写 partial unique index `User_memberId_active_key`
  // WHERE "deletedAt" IS NULL(migration 末尾追加,沿 role_bindings / member_organization_memberships
  // 等既有范式)——同一 memberId 至多 1 条"活跃"关联,软删后释放槽位供重新绑定/开号/重开。
  // 普通 @@index([memberId]) 兜底覆盖跨软删状态的既有查询(existingLink 预检查等)。
  memberId String?
  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  // V2 第一阶段批次 3 反向 relation(详见 docs:批次3_schema草案_*.md §12.1)
  // 沿批次 1 / 批次 2 R2 范式:Prisma 关系映射不算业务字段新增。
  activitiesPublished           Activity[]             @relation("ActivityPublisher")
  activitiesCancelled           Activity[]             @relation("ActivityCanceller")
  registrationsReviewed         ActivityRegistration[] @relation("RegistrationReviewer")
  registrationsCancelled        ActivityRegistration[] @relation("RegistrationCanceller")
  attendanceSheetsSubmitted     AttendanceSheet[]      @relation("SheetSubmitter")
  attendanceSheetsReviewed      AttendanceSheet[]      @relation("SheetReviewer")
  // V2 第一阶段批次 4-A:终审反向 relation。详见 docs/批次4_贡献值业务规则_schema草案评审决议表 D-S5。
  // APD 部门部长 / 副部长终审通过 / 驳回时填入 AttendanceSheet.finalReviewerUserId。
  attendanceSheetsFinalReviewed AttendanceSheet[]      @relation("SheetFinalReviewer")
  // V2 第一阶段批次 4-A:ContributionRule 审计字段反向 relation(沿 baseline §2.1 createdByUserId 等)。
  // 三条均为可空 + Restrict,运营后台审计责任字段。
  contributionRulesCreated      ContributionRule[]     @relation("ContributionRuleCreator")
  contributionRulesUpdated      ContributionRule[]     @relation("ContributionRuleUpdater")
  contributionRulesDeleted      ContributionRule[]     @relation("ContributionRuleDeleter")

  // V2 第一阶段批次 6 audit_logs 反向 relation(D6 v1.1 §4.2)。
  // 仅 Prisma 关系映射,不算业务字段新增(沿批次 1 / 2 / 3 R2 范式)。
  // actorUser FK 在 AuditLog 侧用 onDelete: Restrict,与 v1 user 软删契约一致
  // (user 永远软删 deletedAt,不物理删除,引用悬空仅理论风险)。
  auditLogs AuditLog[]

  // V2.x C-6 RBAC 反向 relation(D7 v1.1 §4.5)。
  // 仅 Prisma 关系映射,不算业务字段新增(沿批次 1 / 2 / 3 / 6 R2 范式;A-2 zero drift)。
  // rolePermissionsCreated = 由本人分配的审计字段反向。
  // v1.1 命名:RBAC model 名为 RbacRole(避开 v1 enum Role 冲突;DB 表名仍 roles 沿 @@map)。
  rolePermissionsCreated RolePermission[] @relation("RolePermissionCreator")

  // V2.x C-7 attachments 反向 relation(D7 v1.0 §4.5)。
  // 仅 Prisma 关系映射,不算业务字段新增(沿 batch 1 / 2 / 3 / 6 / 8 R2 范式;A-2 zero drift)。
  // uploadedBy FK 在 Attachment 侧用 onDelete: Restrict(沿 D7 v1.0 §4.1 Q4)。
  attachmentsUploaded Attachment[] @relation("AttachmentUploader")

  // V2.x P0-E PR-3 反向 relation(沿 docs/first-release-p0e-refresh-token-review.md §5.2)。
  // 仅 Prisma 关系映射,不算业务字段新增(沿 batch 1 / 2 / 3 / 6 / 7 / 8 R2 范式;A-2 zero drift)。
  // 撤销路径:logout / logout-all / 改密 / 重置 / 禁用 / 软删 → updateMany;
  // User 软删走 deletedAt 不物理删除,refresh_tokens.userId FK Restrict 仅理论风险。
  refreshTokens RefreshToken[]

  // D-INSURANCE v3 PR1 expand:审核人与 eligibility evidence 快照审核人的反向关系。
  // 仅增加 schema/FK 骨架；审核与 evidence 生成行为在后续 PR 启用。
  memberInsurancesReviewed          MemberInsurance[]             @relation("MemberInsuranceReviewer")
  insuranceEvidenceSourcesReviewed InsuranceEligibilityEvidence[] @relation("InsuranceEvidenceSourceReviewer")

  @@index([deletedAt])
  @@index([status])
  @@index([memberId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

// ===== V2 第一阶段:dictionaries 双表 =====

model DictType {
  id        String         @id @default(cuid())
  code      String         @unique
  label     String
  status    DictTypeStatus @default(ACTIVE)
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  items DictItem[]

  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum DictTypeStatus {
  ACTIVE
  INACTIVE
}

model DictItem {
  id        String         @id @default(cuid())
  typeId    String
  code      String
  label     String
  parentId  String?
  sortOrder Int            @default(0)
  status    DictItemStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  type     DictType   @relation(fields: [typeId], references: [id], onDelete: Restrict)
  parent   DictItem?  @relation("DictItemTree", fields: [parentId], references: [id], onDelete: Restrict)
  children DictItem[] @relation("DictItemTree")

  @@unique([typeId, code])
  @@index([typeId])
  @@index([parentId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum DictItemStatus {
  ACTIVE
  INACTIVE
}

// ===== V2 第一阶段:organizations =====

model Organization {
  id                      String             @id @default(cuid())
  name                    String
  // 组织缩写(可空 + 全局唯一,含软删历史占用)。seed 内置 16 个真实缩写(SRVF / SMRT …),
  // 运行时建的节点可由运营后台补填。Postgres @unique 容多 NULL,无需 partial index。
  code                    String?            @unique
  parentId                String?
  nodeTypeCode            String
  // 终态 scoped-authz PR1(2026-07-01 goal「组织基座」;冻结稿 §3.0.1 R1/R3):两 additive 可空列,
  // 纯加列 / 无 default / 无回填。establishmentStatusCode → 设立状态字典 org_establishment_status
  //(空 / `formal`=正式;`provisional`=筹备组);groupFunctionCode → 组功能留口字典 group_function
  //(v1 只占列、不写业务逻辑)。本刀 schema-only,不进 Create/Update DTO 与响应(冻结稿「只占列」)。
  establishmentStatusCode String?
  groupFunctionCode       String?
  sortOrder               Int                @default(0)
  status                  OrganizationStatus @default(ACTIVE)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  deletedAt               DateTime?

  parent   Organization?  @relation("OrganizationTree", fields: [parentId], references: [id], onDelete: Restrict)
  children Organization[] @relation("OrganizationTree")

  // 终态 scoped-authz PR2(2026-07-01;冻结稿 §3.1):组织归属反向 relation(仅关系映射,无列)。
  // MemberDepartment(冻结表 cleanup 已 DROP,第 39 migration)的升级表:主/兼/临时/支援归属 + 任期。
  // **本刀绝不被任何模块读作授权**(AuthzService 是 PR8)。
  memberOrganizationMemberships MemberOrganizationMembership[]

  // 终态 scoped-authz PR4(2026-07-01;冻结稿 §3.4):任职反向 relation(仅关系映射,无列)。
  // **assignment 只是数据 + 任命校验,绝不被任何判权路径读**(AuthzService 是 PR8)。
  positionAssignments OrganizationPositionAssignment[]

  // 终态 scoped-authz PR5(2026-07-01;冻结稿 §3.5):被分管反向 relation(仅关系映射,无列)。
  // **分管只是数据 + 展示,绝不被任何判权路径读**(AuthzService 是 PR8)。
  supervisedBy OrganizationSupervisionAssignment[] @relation("OrgSupervised")

  // V2 第一阶段批次 3 反向 relation(沿批次 1 / 批次 2 R2 范式)
  activities Activity[]

  // 招新三期入队(2026-06-19):selectedOrganizationId 反向 relation(评审稿 §3.1;仅关系映射)
  teamJoinApplications TeamJoinApplication[]

  // 终态 scoped-authz PR1(2026-07-01;冻结稿 §3.8):closure 闭包表反向 relation(仅关系映射,无列)。
  closureAncestors   OrganizationClosure[] @relation("ClosureAncestor")
  closureDescendants OrganizationClosure[] @relation("ClosureDescendant")

  // 终态 scoped-authz PR6(2026-07-01;冻结稿 §3.6):RoleBinding scope=ORGANIZATION/ORGANIZATION_TREE 的真 FK 反向
  // relation(仅关系映射,无列)。**scoped 绑定入库即止,RbacService 只读 GLOBAL、绝不判 scoped**(判权是 PR8)。
  roleBindingScopes RoleBinding[] @relation("RoleBindingScopeOrg")

  @@index([parentId])
  @@index([nodeTypeCode])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

// 终态 scoped-authz PR1(2026-07-01 goal「组织基座」;冻结稿 §3.8):组织闭包表 —— 高效上下级判定。
// 每节点含 depth-0 自身行;(ancestor,descendant,depth) 表达祖先→后代距离(0=自身 / 1=直接子 / …)。
// 维护:create 事务内继承父全部祖先 +1 / move 事务内删旧祖先→子树边后按新父插入(PK 兜底防重)/
// migration WITH RECURSIVE 一次性回填现有树 / seed 幂等补齐内置 16 节点。
// **本刀只建 + 维护,绝不被任何模块读作授权**(AuthzService 是 PR8)。
model OrganizationClosure {
  ancestorId   String
  descendantId String
  depth        Int

  ancestor   Organization @relation("ClosureAncestor", fields: [ancestorId], references: [id], onDelete: Cascade)
  descendant Organization @relation("ClosureDescendant", fields: [descendantId], references: [id], onDelete: Cascade)

  @@id([ancestorId, descendantId])
  @@index([descendantId])
  @@index([ancestorId, depth])
  @@map("organization_closure")
}

// ===== 终态 scoped-authz PR3:organization_positions + organization_position_rules =====
//
// 职务定义面(冻结稿 §3.2 / §3.3 / §11 PR3;goal 2026-07-01)。语义:
// - OrganizationPosition = 全局复用的职务定义(一个"部长"职务不为每个部建一份);目录 v1 收敛为
//   6 领导职务(队长/副队长/部长/副部长/组长/副组长;R4,PositionCategory.STAFF 干事留口不 seed)。
// - OrganizationPositionRule = 某类组织(node_type)可设哪些职务的规则(R6 一类多领导称谓 +
//   R8 requireMembership 按 (nodeType, position) 可配:总队级领导免根归属)。
// **纯配置定义:只建 + seed + CRUD,绝不被任何判权路径读**(消费它的 assignment=PR4 /
//   policy=PR7 / authz=PR8;`assignments` 反向 relation 由 PR4 补挂,`rolePolicies` 反向 relation 由 PR7 补挂〔见下〕)。
model OrganizationPosition {
  id              String           @id @default(cuid())
  code            String           @unique // kebab,如 team-leader / dept-deputy / group-leader
  name            String // 显示名:队长 / 副部长 / 组长 …
  categoryCode    PositionCategory // LEADER 正职 / DEPUTY 副职 / STAFF 干事
  rank            Int              @default(0) // 层级排序权重(正职 < 副职 < 组长 < 副组长;数值越小越资深)
  isLeadership    Boolean          @default(false) // 是否领导职务
  allowMultiple   Boolean          @default(false) // 同组织同职务是否允许多人在任(如总队 6 副队长)
  allowConcurrent Boolean          @default(true) // 是否允许一人兼任多职务(如副队长甲兼 SAMT 队长)
  sortOrder       Int              @default(0)
  status          PolicyStatus     @default(ACTIVE)
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  rules        OrganizationPositionRule[]
  // 终态 scoped-authz PR4(2026-07-01;冻结稿 §3.4):任职反向 relation(仅关系映射,无列)。
  // 消费它的 policy=PR7 / authz=PR8;**本刀 assignment 只是数据 + 任命校验,绝不被任何判权路径读**。
  assignments  OrganizationPositionAssignment[]
  // 终态 scoped-authz PR7(2026-07-01;冻结稿 §3.7):职务→角色映射反向 relation(仅关系映射,无列)。
  // 消费它的是 PR8 AuthzService;**本表 rolePolicies = 纯配置,绝不被任何判权路径读**。
  rolePolicies OrganizationPositionRolePolicy[]

  @@index([categoryCode])
  @@index([status])
  @@index([deletedAt])
  @@map("organization_positions")
}

// 结构闭集用 enum(沿冻结稿 §3.0 / PR2 MembershipType 范式;区别于运营可扩的字典码如 nodeTypeCode)。
enum PositionCategory {
  LEADER
  DEPUTY
  STAFF
}

// 配置态闭集用 enum(沿 §3.0;与 ContributionRuleStatus 同形 ACTIVE/INACTIVE,语义独立命名 PolicyStatus;
// 冻结稿终态 OrganizationPositionRule / OrganizationPositionRolePolicy〔PR7〕共用)。
enum PolicyStatus {
  ACTIVE
  INACTIVE
}

model OrganizationPositionRule {
  id                String       @id @default(cuid())
  nodeTypeCode      String // 关联 node_type 字典:headquarters / rescue-team / functional-dept / group / …
  positionId        String
  required          Boolean      @default(false) // 该类组织是否必须有此职务
  minCount          Int? // 最少在任人数(null=不限)
  maxCount          Int? // 最多在任人数(null=不限;与 position.allowMultiple 协同)
  requireMembership Boolean      @default(true) // 任此职务是否要求先有该组织 active 归属(R8:总队级 → false)
  allowConcurrent   Boolean      @default(true) // 该类组织内是否允许兼任
  status            PolicyStatus @default(ACTIVE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?

  position OrganizationPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)

  @@unique([nodeTypeCode, positionId]) // 同类组织对同职务一条规则
  @@index([positionId])
  @@index([deletedAt])
  @@map("organization_position_rules")
}

// ===== 终态 scoped-authz PR4:organization_position_assignments =====
//
// 任职(冻结稿 §3.4 / §7.3 / §4.3 / R2;goal 2026-07-01 PR4)。语义:
// - 一条 = 人(memberId)× 组织(organizationId)× 职务(positionId)× 任期(startedAt/endedAt)× 状态。
// - status ACTIVE / ENDED / REVOKED;撤销 = 写 REVOKED + revokedByUserId + endedAt(保留行做历史)。
// - isConcurrent(R2 兼任标记):忠实回填公告"（兼）"(如副队长甲兼 SAMT 队长);**纯标记,不影响授权、不进任命校验**。
// - 任命校验(service 层):职务适配(org.nodeType × position 须有 active OrganizationPositionRule)/
//   单人独占(position.allowMultiple=false)/ 兼任(position.allowConcurrent=false)/ requireMembership
//   (匹配规则要求时,member 须在本组织或其祖先有 active membership —— 读 closure 求祖先集 + memberships
//   active 判定,**属任命业务合法性,绝非判权;closure 不进任何判权路径**)/ 任期(endedAt>startedAt)。
// **本表 = 数据 + 任命校验:绝不被任何 rbac.can / AuthzService 判权路径读**(判权是 PR8;RoleBinding 是 PR6,
//   故此处**不**挂 roleBindings 反向 relation)。三 FK onDelete Restrict;(org,position,member) active
//   由 migration.sql 末尾手写 partial unique 兜底(P2002 → ASSIGNMENT_ALREADY_EXISTS)。任职历史 = 软删行 +
//   ENDED/REVOKED 行全保留,可追溯。
model OrganizationPositionAssignment {
  id                String           @id @default(cuid())
  organizationId    String
  positionId        String
  memberId          String
  status            AssignmentStatus @default(ACTIVE)
  startedAt         DateTime // 任期起(公告任期起,如 2026-07-01)
  endedAt           DateTime? // 任期止(公告任期止,如 2027-06-30;有值须 > startedAt)
  appointedByUserId String? // 任命人 userId
  revokedByUserId   String? // 撤销人 userId
  appointmentSource String? // 任命来源:announcement-2026 / manual / import
  isConcurrent      Boolean          @default(false) // R2:兼任标记(回填公告"（兼）";不影响授权,并存 PA 都生效)
  note              String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  position     OrganizationPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)
  member       Member               @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@index([positionId])
  @@index([memberId])
  @@index([organizationId, status])
  @@index([status])
  @@index([deletedAt])
  @@map("organization_position_assignments")
}

// 结构闭集用 enum(沿冻结稿 §3.0 / PR2 MembershipStatus 范式;区别于运营可扩的字典码)。
enum AssignmentStatus {
  ACTIVE
  ENDED
  REVOKED
}

// ===== 终态 scoped-authz PR5:organization_supervision_assignments =====
//
// 分管关系(冻结稿 §3.5 / §7.4 / §4.3;goal 2026-07-01 PR5)。语义:
// - 分管 = 与职务(§3.4 assignment)**正交**的独立范围监督关系。一条 = 分管人(supervisorMemberId)×
//   被分管组织(organizationId)× 范围模式(scopeMode:EXACT 仅该节点 / TREE 含全部下级)× 任期 × 状态。
// - **副队长乙分管 SECT、SSD = 两行;与他的「副队长」职务(assignment)互不为前提** —— create 分管绝不要求
//   supervisor 持有任何职务/领导头衔,运营自由指派「谁分管哪个组织」(R5:副职头衔零推导,管辖来自分管/显式绑定)。
// - status ACTIVE / ENDED / REVOKED;撤销 = 写 REVOKED + revokedByUserId + endedAt(保留行做历史)。
// - 分管范围展开(supervision-scope 查询)/ 被谁分管(supervisors 查询)**读 organization_closure 仅作展示/报表**
//   (TREE 展开求后代集 / inherited 求祖先集);**绝非判权**。
// **本表 = 数据 + 展示:绝不被任何 rbac.can / AuthzService 判权路径读**(判权是 PR8 才把分管推导成只读监督 scope;
//   RoleBinding 是 PR6)。2 FK onDelete Restrict;(supervisor,org) active 由 migration.sql 末尾手写 partial unique
//   兜底(P2002 → SUPERVISION_ALREADY_EXISTS)。分管历史 = 软删行 + ENDED/REVOKED 行全保留,可追溯。
model OrganizationSupervisionAssignment {
  id                 String               @id @default(cuid())
  supervisorMemberId String // 分管人(副队长/队长本人;正交于职务,不要求持职务)
  organizationId     String // 被分管组织
  scopeMode          SupervisionScopeMode @default(TREE) // EXACT 仅该节点 / TREE 含全部下级
  status             SupervisionStatus    @default(ACTIVE)
  startedAt          DateTime // 分管任期起(必填)
  endedAt            DateTime? // 分管任期止(有值须 > startedAt)
  appointedByUserId  String? // 指派人 userId
  revokedByUserId    String? // 撤销人 userId
  note               String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?

  supervisor   Member       @relation("MemberSupervision", fields: [supervisorMemberId], references: [id], onDelete: Restrict)
  organization Organization @relation("OrgSupervised", fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([supervisorMemberId])
  @@index([organizationId])
  @@index([supervisorMemberId, status])
  @@index([deletedAt])
  @@map("organization_supervision_assignments")
}

// 结构闭集用 enum(沿冻结稿 §3.0 / PR2 范式;区别于运营可扩的字典码)。
enum SupervisionScopeMode {
  EXACT
  TREE
}

enum SupervisionStatus {
  ACTIVE
  ENDED
  REVOKED
}

// ===== V2 第一阶段:members =====

model Member {
  id          String       @id @default(cuid())
  memberNo    String       @unique
  displayName String
  gradeCode   String?
  status      MemberStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  // 队员账号闭环 v2(2026-07-07):User.memberId 去 @unique 改一对多——Prisma 要求
  // 一对一关系的 FK 侧字段必须 schema 级 @unique,而 partial unique(仅 DB 层约束
  // "至多 1 条 live")无法在 Prisma DSL 表达,故 Prisma 类型系统诚实反映"1 个 member
  // 可对应多条历史 User(软删)+ 至多 1 条 live"。消费方(resource-resolver.service.ts /
  // birthday-greeting.service.ts)已同步改为按 `where: { deletedAt: null }, take: 1` 取用。
  users                          User[]
  // 终态 scoped-authz PR2(2026-07-01;冻结稿 §3.1):组织归属反向 relation(仅关系映射,不算业务字段新增,沿 R2 范式)。
  memberOrganizationMemberships MemberOrganizationMembership[]
  // 终态 scoped-authz PR4(2026-07-01;冻结稿 §3.4):任职反向 relation(仅关系映射,不算业务字段新增,沿 R2 范式)。
  positionAssignments           OrganizationPositionAssignment[]
  // 终态 scoped-authz PR5(2026-07-01;冻结稿 §3.5):分管反向 relation(该 member 作为分管人;仅关系映射,不算业务字段新增,沿 R2 范式)。
  supervisions                  OrganizationSupervisionAssignment[] @relation("MemberSupervision")
  // V2 第一阶段批次 1:扩展模块反向 relation;主表既有业务字段语义不变,
  // 不在 Member 主表新增任何业务字段(顶层 §11 K1 + 批次 1 schema 草案 R2)。
  memberProfile                 MemberProfile?
  emergencyContacts             EmergencyContact[]
  // V2 第一阶段批次 2:Certificate 两条反向 relation;同样仅 Prisma 关系映射,
  // 不算业务字段新增(批次 2 schema 草案 v1.0 §7 / R2);
  // verifier 角色由 service 层判定,schema 不约束。
  certificates                  Certificate[]                       @relation("CertificateMember")
  certificatesVerified          Certificate[]                       @relation("CertificateVerifier")

  // V2 第一阶段批次 3 反向 relation(沿批次 1 / 批次 2 R2 范式)
  activityRegistrations ActivityRegistration[]
  activityCheckIns      ActivityCheckIn[]
  activityFeedbacks     ActivityFeedback[]
  attendanceRecords     AttendanceRecord[]

  // 保险模块反向 relation(2026-06-13;沿 R2 范式,仅关系映射不算业务字段;
  // 冻结评审稿 docs/archive/reviews/insurance-module-review.md §3.1)
  memberInsurances       MemberInsurance[]
  teamInsuranceCoverages TeamInsuranceCoverage[]

  // 招新三期入队(2026-06-19;沿 R2 范式,仅关系映射不算业务字段;
  // 冻结评审稿 docs/archive/reviews/recruitment-phase3-review.md §3.1)
  teamJoinApplications TeamJoinApplication[]

  // 统一通知模块 S1 站内信渠道(2026-06-25;沿 R2 范式,仅关系映射不算业务字段;
  // 冻结评审稿 docs/archive/reviews/unified-notification-dispatcher-review.md §5 / member-notification-review.md §3)
  notificationReads     NotificationRead[]
  // 统一通知模块 S3 producer 定向(2026-06-25;Notification.recipientMemberId 反向 relation,仅关系映射)
  directedNotifications Notification[]

  @@index([gradeCode])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

// ===== 终态 scoped-authz PR2:member_organization_memberships =====
//
// MemberDepartment(裸单归属;冻结表 cleanup 已 DROP,第 39 migration)的升级表
// (冻结稿 §3.1 / §8.1;goal 2026-07-01 PR2)。语义:
// - membershipType=PRIMARY 至多 1 条 active(= 旧"单部门"语义的升级,只约束主归属);
//   partial unique `member_org_membership_primary_active_unique` 由 migration.sql 末尾手写
//   (Prisma DSL 至 6.x 不支持带 WHERE 的部分唯一索引,沿旧 MemberDepartment / ContributionRule 范式)。
// - SECONDARY/TEMPORARY/SUPPORT 可并存多条 = 跨部门 / 兼属 / 临时编入 / 支援。
// - 任期 startedAt/endedAt + status 表达历史;软删行保留留痕。
// 迁移:每条 active MemberDepartment 回填为 (PRIMARY, ACTIVE, startedAt=createdAt);旧表已 DROP(冻结表 cleanup,第 39 migration)。
// **本表只建 + 回填 + CRUD,绝不被任何模块读作授权**(AuthzService 是 PR8)。
model MemberOrganizationMembership {
  id              String           @id @default(cuid())
  memberId        String
  organizationId  String
  membershipType  MembershipType   @default(PRIMARY)
  status          MembershipStatus @default(ACTIVE)
  startedAt       DateTime         @default(now())
  // DB CHECK (20260718230000):endedAt >= startedAt;且仅 ENDED 可有 endedAt。
  endedAt         DateTime?
  reason          String? // 编入 / 调出原因(自由短串)
  createdByUserId String?
  endedByUserId   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  member       Member       @relation(fields: [memberId], references: [id], onDelete: Restrict)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([memberId])
  @@index([organizationId])
  @@index([memberId, status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("member_organization_memberships")
}

// 结构闭集用 enum(沿冻结稿 §3.1;区别于 PR1 运营可扩的字典码如 establishmentStatusCode)。
enum MembershipType {
  PRIMARY
  SECONDARY
  TEMPORARY
  SUPPORT
}

enum MembershipStatus {
  ACTIVE
  ENDED
  SUSPENDED
}

// ===== V2 第一阶段批次 1:member_profiles =====
//
// 1:1 with Member;承载实名 / 联系方式 / 医疗类等敏感资料。
// 详见 docs:批次1_schema草案_member_profiles_emergency_contacts.md (v1.0 冻结版)。
//
// 设计选择(B 路径,2026-05-10):
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担(与 v0.2.0 现有模型一致)。
// - 纯日期字段(birthDate / joinedDate / privacyConsentSignedAt)统一 DateTime,
//   业务层按 00:00:00.000Z 规范化处理(不落 @db.Date)。
//
// NOT NULL 字段(草案 §7 第一档):realName / genderCode / birthDate / documentTypeCode /
//   documentNumber / mobile / joinedDate / joinSourceCode / privacyConsentSigned。
//   (email 招新二期 M-1 由 NOT NULL 放宽为可空,见下 email 字段注)
// 其余字段 schema 可空(兼容 3000+ 历史档案缺字段);DTO 层按"业务必填"严格校验。

model MemberProfile {
  id        String    @id @default(cuid())
  memberId  String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ===== 报名表必填基础信息 =====
  realName            String // MP-1
  genderCode          String // MP-2 字典 gender
  birthDate           DateTime // MP-3 业务层按日期 00:00:00.000Z 规范化
  documentTypeCode    String // MP-4 字典 document_type
  documentNumber      String // MP-5 高敏感
  ethnicityCode       String? // MP-6 字典 ethnicity(候选,运营层后录入)
  politicalStatusCode String? // MP-7 字典 political_status
  isVeteran           Boolean? // MP-8
  maritalStatusCode   String? // MP-9 字典 marital_status(候选)
  educationCode       String? // MP-10 字典 education(候选)
  major               String? // MP-11 自由文本
  workNatureCode      String? // MP-12 字典 work_nature(只存性质,不存单位)
  residenceArea       String? // MP-13 行政区粒度
  workArea            String? // MP-14 行政区粒度
  mobile              String // MP-15 高敏感
  landline            String? // MP-16 报名表选填
  email               String? // MP-17(招新二期 M-1 放宽:报名链路不采集,promote 建档可 null;admin DTO 仍 @IsEmail 必填)
  qq                  String? // MP-18a
  wechat              String? // MP-18b

  // ===== 报名表必填医疗类(高敏感) =====
  heightCm      Int? // MP-19a 自填,不强制体测核验
  weightKg      Int? // MP-19b
  bloodTypeCode String? // MP-19c 字典 blood_type
  eyesight      String? // MP-20 报名表选填
  medicalNotes  Json? // MP-21 JSON 数组,元素 {categoryCode, note}(Q-S01)

  // ===== 报名表必填能力特长 =====
  hasVehicle            Boolean? // MP-22a
  vehicleType           String? // MP-22b
  exerciseFrequencyCode String? // MP-23a 字典 exercise_frequency(候选)
  exerciseSportCode     String? // MP-23b 字典 exercise_sport(候选)
  exerciseMethods       String[] // MP-23c PG 原生数组,字典 exercise_method codes(Q-S02)
  firstAidKnowledgeCode String? // MP-24 字典 first_aid_knowledge(候选)
  firstAidSkills        String[] // MP-25 PG 原生数组,字典 first_aid_skill codes(Q-S03)
  otherSkills           String? // MP-26 长文本

  // ===== 内部档案补充 =====
  joinedDate             DateTime // MP-27 加入日期,业务层按日期规范化
  joinSourceCode         String // MP-28 字典 join_source(候选)
  noCriminalRecordSigned Boolean? // MP-29 是否签署无违法犯罪声明
  privacyConsentSigned   Boolean // MP-30a 是否授权(NOT NULL)
  privacyConsentSignedAt DateTime? // MP-30b 授权时间(Q-S05 保留)

  // ===== 外部记录字段 =====
  volunteerNo String? // MP-31 义工号,不参与登录/权限/身份识别(草案 §3)

  // 招新二期 promote 搬入(2026-06-19,wrinkle① / E-R2-3;评审稿 recruitment-phase2-review.md):
  // 证件照裸 storage key,镜像 User.avatarKey;不进 Attachment 多态表 / 不接 RBAC(不触 E-20 整包);
  // promote 从 recruitment_applications.idCardImageKey 搬入(同一 storage 对象),application 侧清空,blob 单一属主=member。
  idCardImageKey String? // MP-32 证件照 storage key

  // 招新可用性收口 F5(2026-07-11;评审稿 §2.8 R5;第 42 migration,additive 可空):
  // 签名图 = 责任文件长期留存——promote 从 recruitment_applications.signatureImageKey 搬入
  // (同一 storage 对象),application 侧清空,blob 单一属主=member;**不随任何脱敏/留存清除**(R5)。
  signatureImageKey String? // MP-33 申请人签名图 storage key(镜像 MP-32 搬运范式)

  // 十项收口刀E(2026-07-11;第 45 migration,additive 可空):promote 建档搬运落点——
  // 此前报名行 detailedAddress / profileExtra 在 promote 事务内被置空但未复制到任何表(真丢失);
  // 现搬入档案长期承载。detailedAddress 与 residenceArea(MP-13 行政区粒度)互补,为完整住址;
  // profileExtra 为报名自由填写项 JSON 原样归档(Q7 精简后冻结,当前无页面消费,仅留档)。
  detailedAddress String? // MP-34 详细住址(高敏感;promote 搬自 recruitment_applications.detailedAddress)
  profileExtra    Json? // MP-35 报名附加资料(promote 搬自 recruitment_applications.profileExtra)

  member Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([volunteerNo])
  @@index([deletedAt])
  @@index([createdAt])
}

// ===== V2 第一阶段批次 1:emergency_contacts =====
//
// N:1 with Member;不限数量,priority 整数排序(允许并列,Q-S09)。
// 联系人不视为系统用户,不需联系人单独签授权(EC-8 不做,Q025)。
// 软删走 deletedAt,不物理删(Q-S10)。

model EmergencyContact {
  id        String    @id @default(cuid())
  memberId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  contactName  String // EC-2
  relationCode String // EC-3 字典 emergency_relation
  phonePrimary String // EC-4
  phoneBackup  String? // EC-5
  address      String? // EC-6
  priority     Int     @default(0) // EC-7 0 = 最高;允许并列

  member Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([memberId])
  @@index([memberId, priority])
  @@index([deletedAt])
  @@index([createdAt])
}

// ===== V2 第一阶段批次 2:certificates =====
//
// N:1 with Member;承载外部资质 + 本会颁发证书(同表承载,CT-11)。
// 详见 docs:
//   - 批次2_schema草案_certificates.md (v1.0 冻结版)
//   - 批次2_schema草案评审决议表.md (Q-S1~Q-S10)
//   - 批次2_schema草案评审决议表_v0.1.md (Q-D1~Q-D8)
//
// 设计选择(沿批次 1 B 路径):
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担。
// - 纯日期字段(issuedAt / expiredAt / verifiedAt / expireNotifyDueAt)统一 DateTime,
//   业务层按 00:00:00.000Z 规范化处理(不落 @db.Date)。
// - 字典 code 字段(certTypeCode / certSubTypeCode / certStatusCode)schema 不做 FK,
//   业务层校验字典存在性(沿 v0.2.0 gradeCode / nodeTypeCode 模式)。
//
// FK(全部 ON DELETE Restrict,与 v0.2.0 + 批次 1 一致):
// - memberId           → Member.id            (CT-1)
// - verifiedBy         → Member.id            (CT-9a, Q-D1 已决议)
// - supersededByCertId → Certificate.id 自引用 (CT-12, Q-D2 已决议)
//
// 状态机:4 态闭集 (pending / verified / expired / rejected);
//   schema 不固化,由 service 层映射代码常量与 cert_status 字典 code。
//
// 索引:7 个单列;
//   Q-D6 不加 (expireNotifyDueAt) 单列索引;
//   Q-D8 不加 (memberId, certTypeCode, certStatusCode, expiredAt) 4 列复合索引;
//   Q-S6 不加 (memberId, certTypeCode) 联合索引。
//
// 业务唯一约束:无(草案 §11.2);仅 id 主键唯一。
//
// 软删:走 deletedAt;禁用 hard delete(R12)。
//
// CT-10 attachmentKey 字段已于 V2.x C-7 attachments 批次废弃(沿 D6 Q10 B / D7 v1.0 §4.6);
// 多态附件统一走 `attachments` 表(ownerType='certificate' + ownerId=certificate.id)。

model Certificate {
  id        String    @id @default(cuid())
  memberId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // ===== 业务字段(CT-2 ~ CT-12 + HK-1) =====
  certTypeCode       String // CT-2 字典 cert_type
  certSubTypeCode    String? // CT-3 字典 cert_sub_type;Q-D4 schema 可空
  issuingOrg         String // CT-4 自由文本;长度 128 由 DTO 约束
  certNumber         String? // CT-5 Q-D5 schema 可空;长度 128(Q-D3)由 DTO 约束
  issuedAt           DateTime // CT-6 业务层日期规范化
  expiredAt          DateTime? // CT-7 NULL = 终身有效(Q-S4)
  certStatusCode     String // CT-8 字典 cert_status;无 default,service 填 pending
  verifiedBy         String? // CT-9a FK→Member.id 可空(Q-D1)
  verifiedAt         DateTime? // CT-9b
  verifyNote         String? // CT-9c 长度 500(Q-S5)由 DTO 约束
  isInternal         Boolean   @default(false) // CT-11 是否本会颁发
  supersededByCertId String? // CT-12 自引用 FK 可空(Q-D2)
  expireNotifyDueAt  DateTime? // HK-1 60 天提醒 hook;Q-D6 不加索引
  // 招新可用性收口 F7(2026-07-11;评审稿 §2.9 R6;第 44 migration,additive 可空):
  // 证书图 storage keys(promote 从 recruitment_applications.certificateImages 按类别搬入;
  // blob 单一属主=certificate;app 侧 my/certificates DTO v1 不暴露——另议,NEXT_TASKS 登记)。
  imageKeys Json? // 证书图 storage keys(string[];招新自报材料,verify/reject 人工核验参考)

  member       Member        @relation("CertificateMember", fields: [memberId], references: [id], onDelete: Restrict)
  verifier     Member?       @relation("CertificateVerifier", fields: [verifiedBy], references: [id], onDelete: Restrict)
  supersededBy Certificate?  @relation("CertificateSupersession", fields: [supersededByCertId], references: [id], onDelete: Restrict)
  supersedes   Certificate[] @relation("CertificateSupersession")

  @@index([memberId])
  @@index([certTypeCode])
  @@index([certStatusCode])
  @@index([expiredAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([supersededByCertId])
}

// ===== V2 第一阶段批次 3:activities =====
//
// 详见 docs:
//   - 批次3_schema前评审.md v0.2.4 修正版
//   - 批次3_schema前评审决议表.md v1.0 定稿
//   - 批次3_schema草案_activities_attendances.md v0.5 草案版
//   - 批次3_schema草案评审决议表.md v1.4
//
// 设计选择(沿批次 1 / 批次 2 B 路径):
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担。
// - 字典 code 字段(activityTypeCode / statusCode 等)schema 不做 FK,
//   业务层校验字典存在性(沿 v0.2.0 范式)。
//
// FK(全部 ON DELETE Restrict):
// - organizationId  → Organization.id  (NOT NULL,service 校验禁根节点 R8 / D17)
// - publishedBy     → User.id          (可空,Q-S1 audit 字段落表)
// - cancelledBy     → User.id          (可空)
//
// 显式 @db.Decimal 注解(Q-D2 + Q-D19):
// - locationLongitude / locationLatitude → Decimal(10, 7)(WGS84 ~1.1 cm 精度)
//
// description 必须 String?(Q-D14 v1.4 必填性澄清,v0.5 修订):
// - 从 v0.1 沿用的 NOT NULL 改为 String? 可空
// - 语义:列表展示短说明 / 摘要;详情页正文走 content
//
// 索引:7 单列;v0.2 / v0.4 新增 5 字段(content / galleryImageUrls /
//   coverImageUrl / locationLongitude / locationLatitude)不加索引(沿 Q-D11/12/13/19)。
// 无唯一约束。

model Activity {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title                 String
  activityTypeCode      String
  organizationId        String
  startAt               DateTime
  endAt                 DateTime
  location              String
  description           String? // v0.5 修订(Q-D14 v1.4):NOT NULL → String? 可空
  capacity              Int?
  genderRequirementCode String?
  registrationDeadline  DateTime?
  registrationNotes     String?
  statusCode            String
  publishedBy           String?
  publishedAt           DateTime?
  startReminderSentAt   DateTime?
  cancelledBy           String?
  cancelledAt           DateTime?
  cancelReason          String?
  isPublicRegistration  Boolean   @default(true)
  // 保险模块(2026-06-13):报名保险门槛开关;default false = 迁移安全,既有活动 /
  // 测试零影响,新活动发布时显式开(评审稿 insurance-module-review.md D-INS-1)。
  requiresInsurance     Boolean   @default(false)
  registrationSchema    Json? // v0.2 D12 报名表自定义字段 schema 字段位预留

  // v0.2 展示内容字段(Q-D11 / Q-D12 / Q-D13)
  coverImageUrl    String?
  galleryImageUrls Json?
  content          Json?

  // v0.4 经纬度字段(Q-D19;显式 @db.Decimal(10, 7),WGS84 ~1.1 cm 精度)
  locationLongitude Decimal? @db.Decimal(10, 7)
  locationLatitude  Decimal? @db.Decimal(10, 7)

  organization      Organization           @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  publisher         User?                  @relation("ActivityPublisher", fields: [publishedBy], references: [id], onDelete: Restrict)
  canceller         User?                  @relation("ActivityCanceller", fields: [cancelledBy], references: [id], onDelete: Restrict)
  registrations     ActivityRegistration[]
  activityPositions ActivityPosition[]
  activityCheckIns  ActivityCheckIn[]
  activityFeedbacks ActivityFeedback[]
  attendanceSheets  AttendanceSheet[]

  @@index([deletedAt])
  @@index([createdAt])
  @@index([statusCode])
  @@index([organizationId])
  @@index([activityTypeCode])
  @@index([startAt])
  @@index([isPublicRegistration])
}

// ===== 活动岗位与时段 F1:activity_positions =====
//
// 活动岗位是 activities 模块内的嵌套子资源，与 organization_positions 组织职务无关。
// attendanceRoleCode / genderRequirementCode 沿字典 code 业务校验，不加 FK。
// live (activityId, name) partial unique 由 migration.sql 末尾手写；
// Prisma DSL 6.x 无法表达 WHERE "deletedAt" IS NULL。
// goal 明确要求物理表名 activity_positions，本模型使用 @@map 固定该名称。
model ActivityPosition {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityId            String
  name                  String
  attendanceRoleCode    String
  capacity              Int?
  startAt               DateTime?
  endAt                 DateTime?
  genderRequirementCode String?
  description           String?
  sortOrder             Int       @default(0)

  activity      Activity               @relation(fields: [activityId], references: [id], onDelete: Restrict)
  registrations ActivityRegistration[]

  @@index([activityId])
  @@index([attendanceRoleCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([sortOrder])
  @@map("activity_positions")
}

// ===== V2 第一阶段批次 3:activity_registrations =====
//
// statusCode 字典 4 态(Q-D15 v0.3):pending / pass / reject / cancelled
//
// FK(全部 ON DELETE Restrict):
// - activityId         → Activity.id           (NOT NULL)
// - memberId           → Member.id             (NOT NULL)
// - reviewedBy         → User.id               (可空,沿 Q-S4)
// - cancelledByUserId  → User.id               (可空,Q-D16 v0.3)
// - activityPositionId → activity_positions.id (可空,无岗位活动 / 存量报名)
//
// 业务唯一约束(partial unique;Q-D4 + Q-D17 v1.2 修订):
// - (activityId, memberId) WHERE deleted_at IS NULL AND status_code != 'cancelled'
// - 索引名 activity_registrations_activity_member_active_unique
// - Prisma DSL 不支持带 WHERE,migration.sql 末尾手动追加(沿 MemberDepartment 范式)
//
// extras Json?(D12 字段位预留)。
//
// 索引:7 单列(activityId / activityPositionId / memberId / statusCode / deletedAt / createdAt / registeredAt)。

model ActivityRegistration {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityId         String
  activityPositionId String?
  memberId           String
  statusCode         String
  registeredAt       DateTime  @default(now())
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNote         String?
  extras             Json?

  // v0.3 新增 取消留痕(Q-D16)
  cancelledByUserId String?
  cancelledAt       DateTime?
  cancelReason      String?

  activity          Activity           @relation(fields: [activityId], references: [id], onDelete: Restrict)
  activityPosition  ActivityPosition?  @relation(fields: [activityPositionId], references: [id], onDelete: Restrict)
  member            Member             @relation(fields: [memberId], references: [id], onDelete: Restrict)
  reviewer          User?              @relation("RegistrationReviewer", fields: [reviewedBy], references: [id], onDelete: Restrict)
  canceller         User?              @relation("RegistrationCanceller", fields: [cancelledByUserId], references: [id], onDelete: Restrict)
  attendanceRecords AttendanceRecord[]
  activityCheckIns  ActivityCheckIn[]
  insuranceEligibilityEvidences InsuranceEligibilityEvidence[]

  @@index([activityId])
  @@index([activityPositionId])
  @@index([memberId])
  @@index([statusCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([registeredAt])
}

// ===== 活动自助 GPS 签到 F1:activity_check_ins =====
//
// append-only 证据表；第一版不开放修改 / 删除端点，deletedAt 仅作 schema 预留。
// 三条 FK 均 Restrict：证据必须稳定锚定活动、队员与当次报名。
// live registrationId partial unique 由 migration.sql 末尾手写；Prisma DSL 6.x
// 无法表达 WHERE "deletedAt" IS NULL。
// 本模型获冻结稿一次性 @@map 例外，物理表名固定为 activity_check_ins。
model ActivityCheckIn {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityId     String
  memberId       String
  registrationId String
  checkInAt      DateTime
  checkOutAt     DateTime?

  checkInLongitude  Decimal? @db.Decimal(10, 7)
  checkInLatitude   Decimal? @db.Decimal(10, 7)
  checkInAccuracy   Decimal? @db.Decimal(10, 2)
  checkInDistance   Decimal? @db.Decimal(10, 2)
  checkOutLongitude Decimal? @db.Decimal(10, 7)
  checkOutLatitude  Decimal? @db.Decimal(10, 7)
  checkOutAccuracy  Decimal? @db.Decimal(10, 2)
  checkOutDistance  Decimal? @db.Decimal(10, 2)

  geoVerified Boolean
  outOfRange  Boolean @default(false)

  activity     Activity             @relation(fields: [activityId], references: [id], onDelete: Restrict)
  member       Member               @relation(fields: [memberId], references: [id], onDelete: Restrict)
  registration ActivityRegistration @relation(fields: [registrationId], references: [id], onDelete: Restrict)

  @@index([activityId])
  @@index([memberId])
  @@index([registrationId])
  @@index([checkInAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("activity_check_ins")
}

// ===== 活动评价 F1:activity_feedbacks =====
//
// 真到场者在 Activity.endAt + 配置窗口内对 completed 活动提交 1～5 星评价。
// 资格由业务层读取 approved AttendanceSheet 内未软删 AttendanceRecord 判定；
// 本表不保存 registrationId，也不影响考勤 / 贡献值 / 结算。
// live (activityId, memberId) partial unique 由 migration.sql 末尾手写；
// Prisma DSL 6.x 无法表达 WHERE "deletedAt" IS NULL。
// goal 明确要求物理表名 activity_feedbacks，本模型使用 @@map 固定该名称。
model ActivityFeedback {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityId String
  memberId   String
  rating     Int
  comment    String?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Restrict)
  member   Member   @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@index([activityId])
  @@index([memberId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([rating])
  @@map("activity_feedbacks")
}

// ===== V2 第一阶段批次 3:attendance_sheets =====
//
// statusCode 字典 3 态(D18):pending / approved / rejected。
// version Int @default(1)(Q-D8 不做乐观锁,仅展示用)。
// previousSnapshot Json?(D38 / Q-D1 后端事务内自动生成)。
//
// FK(全部 ON DELETE Restrict):
// - activityId       → Activity.id  (NOT NULL,D47 一 Activity 多 Sheet / R30)
// - submitterUserId  → User.id      (NOT NULL,Q-S4 系统操作人)
// - reviewerUserId   → User.id      (可空,APD 审核员)
//
// 索引:7 单列。

model AttendanceSheet {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  activityId          String
  submitterUserId     String
  submittedAt         DateTime  @default(now())
  statusCode          String
  reviewerUserId      String?
  reviewedAt          DateTime?
  reviewNote          String?
  // V2 第一阶段批次 4-A 新增三字段(D-S5):APD 部门部长 / 副部长终审。
  // 与 reviewer* 系列对称(沿 baseline §2.1 命名);均可空,在 final-approve / final-reject
  // service 内事务填入。APD 一级 approve 时 statusCode 进入 pending_final_review;
  // 终审通过 → approved(贡献值正式生效,触发 attendance.recorded);终审驳回 → final_rejected。
  finalReviewerUserId String?
  finalReviewedAt     DateTime?
  finalReviewNote     String?
  previousSnapshot    Json? // D38 后端事务内自动生成
  version             Int       @default(1) // Q-D8 不做乐观锁;服务端版本号

  activity      Activity           @relation(fields: [activityId], references: [id], onDelete: Restrict)
  submitter     User               @relation("SheetSubmitter", fields: [submitterUserId], references: [id], onDelete: Restrict)
  reviewer      User?              @relation("SheetReviewer", fields: [reviewerUserId], references: [id], onDelete: Restrict)
  finalReviewer User?              @relation("SheetFinalReviewer", fields: [finalReviewerUserId], references: [id], onDelete: Restrict)
  records       AttendanceRecord[]

  @@index([activityId])
  @@index([submitterUserId])
  @@index([reviewerUserId])
  @@index([finalReviewerUserId])
  @@index([statusCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([submittedAt])
}

// ===== V2 第一阶段批次 3:attendance_records =====
//
// attendanceStatusCode 字典 3 态(D44 / D51 v0.2.4 撤销 absent / leave):
//   present / late / early_leave。
//
// roleCode 字典 7 项(D13):member / instructor / assistant / coach /
//   front_command / back_command / info。
//
// 显式 @db.Decimal 注解(Q-D2):
// - serviceHours        → Decimal(5, 2) NOT NULL,业务必填且 > 0,允许 < 跨度(D46)
// - contributionPoints  → Decimal(5, 2)? 字段层可空,业务 approved 前必填(R31)
//
// FK:
// - sheetId         → AttendanceSheet.id        (NOT NULL, Restrict, R20)
// - memberId        → Member.id                 (NOT NULL, Restrict)
// - registrationId  → ActivityRegistration.id   (可空,**Restrict** 不是 SetNull,Q-S21)
//
// 索引:7 单列 + 1 复合(memberId, deletedAt)用于时间不重叠校验性能(R16)。
// 业务唯一约束:无(D8 撤销 v0.1 AT-9)。

model AttendanceRecord {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sheetId              String
  memberId             String
  roleCode             String
  checkInAt            DateTime
  checkOutAt           DateTime
  serviceHours         Decimal  @db.Decimal(5, 2) // Q-D2 显式注解;必填且 > 0(D45/D51)
  attendanceStatusCode String
  note                 String?
  registrationId       String? // Q-D26 / D27 可空(临时参加 / 非公开报名)
  contributionPoints   Decimal? @db.Decimal(5, 2) // Q-D2 + R31;字段层可空,APD approved 前必填

  sheet        AttendanceSheet       @relation(fields: [sheetId], references: [id], onDelete: Restrict)
  member       Member                @relation(fields: [memberId], references: [id], onDelete: Restrict)
  registration ActivityRegistration? @relation(fields: [registrationId], references: [id], onDelete: Restrict) // Q-S21:Restrict 不是 SetNull

  @@index([sheetId])
  @@index([memberId])
  @@index([registrationId])
  @@index([attendanceStatusCode])
  @@index([roleCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([memberId, deletedAt]) // R16 时间不重叠校验性能
}

// ===== V2 第一阶段批次 4-A:contribution_rules =====
//
// 详见 docs:
// - 批次4_贡献值业务规则前评审决议表.md v1.0 D14 候选 5.B
// - 批次4_贡献值业务规则_schema草案评审决议表.md v1.0 D-S1 / D-S3 / D-S4
// - 批次4_贡献值业务规则_字典扩展决议表.md v1.0 D-D5
// - 批次4_贡献值业务规则_API草案.md v1.0 D-A8
//
// 模型用途:承载 D14 5.B 系统预填 contributionPoints 的规则映射。
// service 在 POST /attendance-sheets 事务内查表预填;APD 一级 approve 时 R31 必填校验;
// APD 可现场修订(沿 D4 终决权)。第一版不暴露管理 API(D-A9),seed/运营后台维护。
//
// 关联(D-D5):
// - activityTypeCode → activity_type 字典 code(2 级树;关联叶子或无子父节点,运营自治)
// - attendanceRoleCode → attendance_role 字典 code(扁平结构)
// - 不引外键 FK(字典 code 字符串关联,运营后台决定取值;沿 v0.4.0 *Code 字段风格)
//
// 时长档位(D-S3 简化档位):
// - durationThreshold?:时长阈值(小时);null 表示无档位,直接按 pointsBelow 取值
// - pointsBelow:≤ durationThreshold(或无档位)的预填分值
// - pointsAbove?:> durationThreshold 的预填分值;无档位时不填
// - 救援 / 救助后方人员的"每 6h 0.5"线性公式不通过本字段集精确表达(D-S3 / D-A8 §5);
//   后方角色按简化档位预填(<6h = pointsBelow / >=6h = pointsAbove),APD 现场修订。
//
// 每日上限(D-S3 / D-D5):
// - dailyCap?:**已 deprecated(活动闭环硬化 2026-06-21)**。每日封顶语义由「每条记录各自封顶」
//   改为「全局每日上限」(一人单个北京日历日总分封顶 GLOBAL_DAILY_CONTRIBUTION_CAP=3),封顶落在
//   汇总处 team-join `computeContribution`,ContributionCalculator 不再读此列。列保留不删(免 migration);
//   旧值照旧存库、不参与计算。原行为:null 时由 service 兜底默认 1.5(Q-OPEN-7);R22 类填 0(D-S9 §6.3)。
//
// 启停字段(D-S1):沿 baseline §2.2.3 + v0.4.0 现有 enum 风格,用大写 ACTIVE/INACTIVE;
// 禁止使用 isActive / isEnabled / enabled。
//
// 审计字段:createdByUserId / updatedByUserId / deletedByUserId 可空 FK,运营后台维护时填入。
//
// 唯一约束(D-RULE-1):(activityTypeCode, attendanceRoleCode) 在 deletedAt IS NULL
// AND status = 'ACTIVE' 范围内唯一；同一 type × role 只能有一条生效规则，
// durationThreshold 是该规则内部的档位参数，不再参与 ACTIVE 槽位维度。Prisma DSL 至 6.x 不支持
// @@unique 内表达 WHERE 子句的 partial unique;沿 batch 3 active_unique 范式手动
// 追加 migration SQL(参见 migration.sql 末尾)。schema 仅声明普通 @@index。

model ContributionRule {
  id                 String                 @id @default(cuid())
  activityTypeCode   String
  attendanceRoleCode String
  durationThreshold  Decimal?               @db.Decimal(5, 2) // 时长档位阈值(小时);null 表示无档位
  pointsBelow        Decimal                @db.Decimal(5, 2) // ≤ 阈值(或无档位)的预填分值
  pointsAbove        Decimal?               @db.Decimal(5, 2) // > 阈值的预填分值;无档位时不填
  dailyCap           Decimal?               @db.Decimal(5, 2) // [deprecated 2026-06-21] 全局每日封顶改落 team-join computeContribution;calculator 不再读,列保留免 migration
  status             ContributionRuleStatus @default(ACTIVE)
  remark             String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deletedAt          DateTime?
  createdByUserId    String?
  updatedByUserId    String?
  deletedByUserId    String?

  createdBy User? @relation("ContributionRuleCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy User? @relation("ContributionRuleUpdater", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  deletedBy User? @relation("ContributionRuleDeleter", fields: [deletedByUserId], references: [id], onDelete: Restrict)

  @@index([activityTypeCode])
  @@index([attendanceRoleCode])
  @@index([activityTypeCode, attendanceRoleCode]) // 查表预填走 (activityTypeCode × attendanceRoleCode) 主路径
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

enum ContributionRuleStatus {
  ACTIVE
  INACTIVE
}

// ===== V2 第一阶段批次 6:audit_logs =====
//
// 详见 docs:
// - 批次6_audit_logs_业务确认稿.md(B1-B5)
// - 批次6_audit_logs_API前评审.md(D6 v1.1 §4 / §9 / §10)
//
// 设计选择(D6 v1.1 §4):
// - 单表 9 个业务字段 + 1 个 User relation;无 updatedAt / 无 deletedAt(R1 红线:写入后不可改不可删)
// - event / resourceType 用 String 不用 Prisma enum(union 在 audit-logs.types.ts / common/audit/audit-placeholder.ts 维护)
// - actorRoleSnap 用 Prisma Role enum(取自 currentUser.role 快照,D10)
// - context 用 Json,但运行时强约束为 AuditContext(6 字段:3 必填 + 3 可选,D7)
// - success 默认 true,BizException 回滚后不写入(D-B fail-fast)
//
// FK:
// - actorUserId → User.id  (可空;系统操作时为 null;onDelete: Restrict + onUpdate: Restrict,R14)
//
// 索引(D6 v1.1 §4.1;3 个复合索引,默认排序 [{ createdAt: 'desc' }, { id: 'desc' }] tie-breaker 用 PK):
// - (resourceType, resourceId):查某资源的全部审计记录(emergency_contact / certificate)
// - (actorUserId, createdAt):查某操作人的全部审计记录(管理员查自己)
// - (event, createdAt):按事件类型筛选(emergency-contact.write / certificate.create / ...)

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // 主体(D6 v1.1 §4.1;actorRoleSnap = 操作时角色快照,不查 user 表反向取最新角色)
  actorUserId   String?
  actorRoleSnap Role?

  // 客体(D6 v1.1 §4.1;create 失败时 resourceId 可为 null)
  resourceType String // 'emergency_contact' / 'certificate'(第一批 2 种)
  resourceId   String?

  // 动作(沿 AuditLogEvent union 同值,union 在 audit-logs.types.ts 维护)
  event String

  // 上下文(锁形 AuditContext,见 audit-logs.types.ts;D7)
  context Json

  // 状态(D-B fail-fast:audit 与业务同事务,失败回滚整体;成功路径默认 true)
  success Boolean @default(true)

  actorUser User? @relation(fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Restrict)

  @@index([resourceType, resourceId])
  @@index([actorUserId, createdAt])
  @@index([event, createdAt])
  @@map("audit_logs")
}

// ===== V2.x C-6 RBAC 4 表(沿 D7 v1.1 §4 schema 草案) =====
//
// 段位 BizCode 300xx + 301xx(F1 锁;baseline §1.1 已预留)。
// users.policy.ts 永久共存(D12 永不切换);RBAC 仅作新增 V2 接口业务级补充(F9)。
// v1 enum Role 保持不动(SUPER_ADMIN / ADMIN / USER 三层永远不变;沿 A-2 + A-4 红线)。
// v1.1 命名:RBAC role model 名为 RbacRole(避开 v1 enum Role 冲突);
//   DB 表名仍 @@map("roles") / @@map("permissions") / @@map("role_permissions") / @@map("user_roles")
//   保持 snake_case 复数风格(沿 audit_logs / API 路径风格)。
// 实施仅本 PR(C-6 实施 PR #1)落地 schema + migration;
// service / controller / DTO / seed / 判权已在 C-6 后续 PR(#2-#8)全部实装。
// 详见:
//   - docs/批次8_RBAC_API前评审.md §4(schema 草案;v1.1 修订稿)
//   - docs/批次8_RBAC_V2x立项记录.md §二(立项内容)

model RbacRole {
  id          String    @id @default(cuid())
  code        String    @unique // 业务 code,kebab-case;F7 锁定 3-32 字符
  displayName String // 显示名;真实名走 .env.seed.local(F6 / R13)
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // D4:RbacRole 软删

  rolePermissions RolePermission[]

  // 终态 scoped-authz PR6(2026-07-01;冻结稿 §3.6):带 scope 的角色绑定反向 relation(真 FK,Restrict)。
  // RoleBinding(principalType=USER, scopeType=GLOBAL)是旧 UserRole 表的无损升级 = 判权唯一读源;
  // UserRole 表已 DROP(冻结表 cleanup,第 39 migration)。
  roleBindings RoleBinding[]

  // 终态 scoped-authz PR7(2026-07-01;冻结稿 §3.7):职务→角色映射反向 relation(仅关系映射,无列)。
  // **本表纯配置,绝不被任何判权路径读**(消费方是 PR8 AuthzService);org-admin/group-manager/
  // org-supervisor 三管理角色本刀零 user 持有,不影响 RbacService.can() 判权语义。
  rolePolicies OrganizationPositionRolePolicy[]

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id           String   @id @default(cuid())
  code         String   @unique // <module>.<action>.<resource_type>(D2 锁定;kebab-case)
  module       String // 模块名(冗余,方便后台 UI 按 module 分组)
  action       String // 动作
  resourceType String // 资源类型
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // D4:Permission 物理删,无 deletedAt(seed-driven;运营不主动删)

  rolePermissions RolePermission[]

  @@index([module])
  @@index([resourceType])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())
  createdBy    String? // User.id;沿 D11 audit 字段

  role          RbacRole   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdByUser User?      @relation("RolePermissionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// 终态 scoped-authz PR6「RoleBinding」(2026-07-01 goal;冻结稿 §3.6 / §8.2 / §7.5 / §4.3;序列 PR6/12)。
//
// **带 scope 的角色绑定:终态替代 / 兼容旧 UserRole 表。** 每条 UserRole 已由第 37 migration 回填为
//   RoleBinding(principalType=USER, principalId=userId, scopeType=GLOBAL, status=ACTIVE);
//   旧 UserRole 表已 DROP(冻结表 cleanup,第 39 migration)。
// **判权唯一读源(行为锁,PR6 起):** RbacService.getUserPermissionCodes / getEffectiveRoles +
//   user-roles CRUD + rbac-cache 失效**全部只读 / 只写 scopeType=GLOBAL 的本表**。
// **🔴 scoped 绑定可存不判(PR8 边界):** ORGANIZATION / ORGANIZATION_TREE / ACTIVITY / RESOURCE / SELF 各型
//   经 role-bindings CRUD 入库,但 **RbacService 只读 GLOBAL、绝不判 scoped**(scoped 判权是 PR8 AuthzService)。
//
// **principalId 多态(沿 Attachment.ownerType/ownerId 范式):** 随 principalType 指向
//   user / member / position_assignment / system(SYSTEM 时可空),**不建通用 Prisma FK**
//   (会对 USER 主体误断言指向 position_assignment 而失败),由 service 按 principalType 校验存在性。
//   仅 roleId→RbacRole、scopeOrgId→Organization 是真 FK(非多态,Restrict)。
// **partial unique(手写,第 37 migration 末尾;PG16 NULLS NOT DISTINCT):**
//   (principalType,principalId,roleId,scopeType,scopeOrgId,scopeActivityId,scopeResourceType,scopeResourceId)
//   WHERE deletedAt IS NULL AND status='ACTIVE'(同一绑定不重复;NULLS NOT DISTINCT 令 GLOBAL 的 NULL scope 列
//   也参与去重 = 保住 UserRole 旧 @@unique(userId,roleId) 的并发去重行为锁;P2002 → ROLE_BINDING_ALREADY_EXISTS)。
model RoleBinding {
  id                String           @id @default(cuid())
  principalType     PrincipalType // USER / MEMBER / POSITION_ASSIGNMENT / SYSTEM
  principalId       String? // 多态、无 FK(SYSTEM 时可空);USER 时 = User.id
  roleId            String
  scopeType         BindingScopeType
  scopeOrgId        String? // ORGANIZATION / ORGANIZATION_TREE 时必填
  scopeActivityId   String? // ACTIVITY 时必填(多态 String,无 FK)
  scopeResourceType String? // RESOURCE 时必填(如 attendance_sheet)
  scopeResourceId   String? // RESOURCE 时必填(多态 String,无 FK)
  status            BindingStatus    @default(ACTIVE)
  startedAt         DateTime         @default(now())
  endedAt           DateTime? // 临时授权可设;过期不授权(PR8 判)
  createdByUserId   String?
  note              String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  role              RbacRole      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  scopeOrganization Organization? @relation("RoleBindingScopeOrg", fields: [scopeOrgId], references: [id], onDelete: Restrict)

  @@index([principalType, principalId])
  @@index([roleId])
  @@index([scopeType, scopeOrgId])
  @@index([scopeActivityId])
  @@index([status])
  @@index([deletedAt])
  @@map("role_bindings")
}

// 终态 scoped-authz PR6(2026-07-01;冻结稿 §3.6):RoleBinding 三枚举。
enum PrincipalType {
  USER
  MEMBER
  POSITION_ASSIGNMENT
  SYSTEM
}

enum BindingScopeType {
  GLOBAL
  ORGANIZATION
  ORGANIZATION_TREE
  ACTIVITY
  RESOURCE
  SELF
}

enum BindingStatus {
  ACTIVE
  ENDED
  SUSPENDED
}

// 终态 scoped-authz PR7「职务→角色 policy」(2026-07-01 goal;冻结稿 §3.7 / §2.4 BD-1/BD-3 / R5;序列 PR7/12)。
//
// **这是"职务不天然 = 管理员"的关键闸门:** 职务(§3.4 assignment)换算成什么角色、覆盖多大范围,
//   全在此显式声明、可审计、可调。**只为正职映射管理角色**(队长 team-leader / 部长 dept-leader →
//   org-admin;组长 group-leader → group-manager)。**本刀 goal 落地拍板**:合并冻结稿草案原提的
//   team-manager/dept-manager 二分为统一 org-admin(队长/部长合用一套业务面广角色),scope 相对
//   "任职组织"(TREE)天然区分 root(全组织)vs 非 root(本队/本部),无需 conditionJson 分流。
// **🔴 R5 安全红线 —— 副职默认不推导管理角色:** `vice-captain` / `dept-deputy` /
//   `deputy-group-leader` **零**本表行(seed 不写、CI 断言恒为 0)。副职实际管辖权只能来自
//   `OrganizationSupervisionAssignment`(分管)或显式 `RoleBinding`,绝不由头衔自动推导
//   (否则总队 6 名副队长各得近全组织管理 = goal 明禁的"部长=管理员")。`org-supervisor`
//   （分管推导用只读角色)**不是**本表映射目标 —— 它由 PR8 分管推导消费,不经职务 policy。
// **本表纯配置映射:只建 + seed 3 条(仅正职)+ CRUD 预留,绝不被任何判权路径读**
//   (职务→角色的动态推导消费方是 PR8 AuthzService;本刀 0 端点 / 0 新权限码 / 0 controller)。
model OrganizationPositionRolePolicy {
  id            String          @id @default(cuid())
  positionId    String
  roleId        String
  scopeMode     PolicyScopeMode @default(TREE) // 相对"任职所在组织"的 EXACT / TREE
  conditionJson Json? // 可选条件(本刀 seed 不用,留列位;如未来 { nodeTypeCode: 'functional-dept' })
  status        PolicyStatus    @default(ACTIVE)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  position OrganizationPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)
  role     RbacRole             @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([positionId, roleId])
  @@index([positionId])
  @@index([roleId])
  @@index([deletedAt])
  @@map("organization_position_role_policies")
}

// 终态 scoped-authz PR7(2026-07-01;冻结稿 §3.0):职务→角色映射的 scope 相对模式。
enum PolicyScopeMode {
  EXACT
  TREE
}

// ===== V2.x C-7 attachments 4 表(沿 D7 v1.0 §4 schema 草案) =====
//
// 段位 BizCode 130xx + 131xx(F5 锁;baseline §1.1 已预留)。
// attachments 是 0 → 1 接入 RBAC 的业务范本(F3:入口仅 JwtAuthGuard,
//   判权全部在 Service 层 rbac.can())。
// Permission code 正则已于 v1.2(PR #66)/ C-7 实施 PR #1(PR #70) 放宽至 3-4 段,
//   支持 attachment.upload.cert.self 等 4 段权限点(D7 v1.0 Q11)。
// 实施仅本 PR 落地 schema + migration + Certificate.attachmentKey drop column;
// service / controller / DTO / RBAC 集成 / audit 集成 / 配置三表 CRUD 已在 C-7 后续 PR 全部实装。
// 详见:
//   - docs/批次7_attachments_API前评审.md §4(schema 草案;v1.0 冻结稿)
//   - docs/批次7_attachments_V2x立项记录.md §二(立项内容)
//
// 设计选择(沿批次 1/2/3 B 路径):
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担
// - 硬删除(D6 Q5 B):主表无 deletedAt;配置三表沿 baseline §2.1 软删
// - 多态外键(D6 Q4 A):ownerType + ownerId,无 DB FK,Service 层校验
// - tags = String[] PG 原生数组(Q3 v1.0;沿 MemberProfile.exerciseMethods 范式)
// - accessLevel hint + 索引(Q2 v1.0);RBAC 仍是单一权威源

model Attachment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // 沿 D6 Q5 B 硬删除:无 deletedAt

  // ===== 基础字段(D7 v1.0 §4.1) =====
  // V2.x C-7.5 PR(attachment_key_unique):key 加 @unique(沿评审 §8.4.4 + PR #91 已知偏差修复)
  // confirm-upload 二次提交:findFirst 串行早返 13001 + P2002 catch 并发兜底(双层防御)
  key          String   @unique // Provider 侧文件唯一引用;长度由 DTO @MaxLength(256);@unique 全局唯一
  // D-STORAGE-CONSISTENCY expand phase:新 binary 运行时强制同 tx 建立 StorageObject invariant；
  // 本期刻意不声明 relation/FK，以兼容 migration 后尚未退场的旧 writer。backfill gate=0 且
  // 新 binary 全量稳定后，另立 contract migration 加 Attachment.key -> StorageObject.key RESTRICT。
  originalName String // 原始文件名;长度由 DTO @MaxLength(255)
  mime         String // MIME 类型;长度由 DTO @MaxLength(128);走 attachment_mime_configs 白名单
  size         Int // 文件大小(字节);非负;走 attachment_size_limit_configs 上限
  uploadedBy   String // Q4 v1.0:User.id(沿 V2 createdBy / publishedBy 风格)
  uploadedAt   DateTime @default(now())

  // ===== 多态归属(D6 Q3 A + Q4 A;无 DB FK,Service 层校验) =====
  ownerType String // 归属业务对象类型;走 attachment_type_configs 白名单
  ownerId   String // 归属对象 cuid

  // ===== 额外字段(D6 Q2 全字段) =====
  checksum             String? // SHA-256(64 hex);本期不做 unique
  etag                 String? // Provider 侧版本号;本期仅存,不约束格式
  description          String? // 用户备注;长度由 DTO @MaxLength(500)
  accessLevel          AttachmentAccessLevel? // Q2 v1.0:hint + 索引;权限走 RBAC 单一权威
  tags                 String[] // Q3 v1.0:PG 原生数组;不建关联表
  originalUploaderName String? // 冗余存上传者人名;长度由 DTO @MaxLength(50)
  expireAt             DateTime? // 附件本身有效期;本期不做主动清理

  uploader User @relation("AttachmentUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@index([ownerType, ownerId]) // 业务查询主路径:列出某业务对象的所有附件
  @@index([uploadedBy])
  @@index([mime]) // 按 MIME 筛选(后台用)
  @@index([createdAt])
  @@index([accessLevel]) // Q2 v1.0:hint 索引保留
  @@map("attachments")
}

enum AttachmentAccessLevel {
  PUBLIC // 公开;沿 Q7 活动封面 / 培训资料
  INTERNAL // 内部;沿 Q7 活动现场照
  SENSITIVE // 敏感;沿 Q7 队员证件照
}

// Attachment namespace 的 durable provider-object ledger(D-STORAGE-CONSISTENCY Phase 1)。
// state/source 使用 String + migration CHECK，避免把恢复态扩展变成 PostgreSQL enum DDL；
// 运行时只允许 available 进入普通严格读取/签名。历史回填绝不直接写 available。
// provider locator 只保存非秘密定位信息；credential/signed URL/token 永不入表。
model StorageObject {
  id  String @id @default(cuid())
  key String @unique

  // DB CHECK 见 20260718233000；integrity_mismatch 表示已固定对象的确定性 size/etag 冲突，
  // JIT/STRICT 均不可读，只能走双人 manual relocate 恢复。
  state  String @default("pending_upload")
  source String

  providerType  StorageProviderType?
  bucket        String?
  region        String?
  localNamespace String?

  // Provider/storage_settings 的对象上限是 BigInt；现有 Attachment.size 仍是 Int，写 ledger 时
  // 显式 BigInt(size)。这样本期不改 API/DTO，同时 ledger 不把未来 >2 GiB provider metadata 截断。
  expectedSize BigInt?
  actualSize   BigInt?
  expectedMime String?
  actualMime   String?
  etag         String?
  checksum     String?

  // available 后指向 Attachment 聚合；未绑定上传必须保持 null，供 orphan-delete 安全门判断。
  resourceType String?
  resourceId   String?
  version      Int     @default(0)

  unboundExpiresAt    DateTime? @db.Timestamptz(3)
  lastProviderCheckedAt DateTime? @db.Timestamptz(3)
  verifiedAt          DateTime? @db.Timestamptz(3)
  presentAt           DateTime? @db.Timestamptz(3)
  deleteRequestedAt   DateTime? @db.Timestamptz(3)
  absentAt            DateTime? @db.Timestamptz(3)
  missingAt           DateTime? @db.Timestamptz(3)

  lastErrorCode  String?
  lastErrorClass String?

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  operations StorageObjectOperation[]

  @@index([state])
  @@index([source, state])
  @@index([resourceType, resourceId])
  @@index([unboundExpiresAt])
  @@index([createdAt])
  @@map("storage_objects")
}

// Durable operation ledger。eventKey 幂等；leaseOwner + leaseGeneration 是 fencing token。
// migration 的 partial unique 保证每个 object 同时至多一条 pending/processing operation。
model StorageObjectOperation {
  id              String @id @default(cuid())
  eventKey        String @unique
  storageObjectId String
  replayOfId      String?

  kind        String
  status      String @default("pending")
  effectState String @default("not_started")

  payloadVersion Int
  payload        Json
  requestHash    String

  attempts    Int      @default(0)
  availableAt DateTime @default(now()) @db.Timestamptz(3)

  leaseOwner      String?
  leaseGeneration Int       @default(0)
  leaseAcquiredAt DateTime?  @db.Timestamptz(3)
  leaseRenewedAt  DateTime?  @db.Timestamptz(3)
  leaseExpiresAt  DateTime?  @db.Timestamptz(3)

  effectStartedAt   DateTime? @db.Timestamptz(3)
  effectCompletedAt DateTime? @db.Timestamptz(3)
  completedAt       DateTime? @db.Timestamptz(3)
  deadAt            DateTime? @db.Timestamptz(3)

  lastErrorCode  String?
  lastErrorClass String?

  responseSnapshotExpiresAt DateTime? @db.Timestamptz(3)
  responsePurgedAt          DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  storageObject StorageObject @relation(fields: [storageObjectId], references: [id], onDelete: Restrict)
  replayOf      StorageObjectOperation?  @relation("StorageObjectOperationReplay", fields: [replayOfId], references: [id], onDelete: Restrict)
  replays       StorageObjectOperation[] @relation("StorageObjectOperationReplay")

  @@index([status, availableAt, leaseExpiresAt])
  @@index([storageObjectId, createdAt])
  @@index([kind, status])
  @@index([leaseExpiresAt])
  @@index([responseSnapshotExpiresAt, responsePurgedAt])
  @@index([createdAt])
  @@map("storage_object_operations")
}

model AttachmentTypeConfig {
  id                   String                     @id @default(cuid())
  code                 String                     @unique // ownerType code;如 'member' / 'certificate' / 'activity'
  displayName          String // 后台 UI 显示名
  description          String?
  // ===== 关联业务表名(用于 Service 层 ownerId 真实性校验) =====
  ownerTable           String // 业务表名小写;如 'member' / 'certificate' / 'activity'
  // ===== 默认配置(覆盖至 mime / size 表为空时的兜底) =====
  defaultMaxSizeBytes  Int? // 默认单文件大小上限;null 走全局兜底
  defaultMimeWhitelist String[] // 默认允许 MIME 列表
  // ===== 启停(沿 baseline §2.2.3) =====
  status               AttachmentTypeConfigStatus @default(ACTIVE)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  deletedAt            DateTime? // 沿 baseline §2.1 软删

  mimeOverrides AttachmentMimeConfig[]
  sizeOverrides AttachmentSizeLimitConfig[]

  @@index([status])
  @@index([deletedAt])
  @@map("attachment_type_configs")
}

enum AttachmentTypeConfigStatus {
  ACTIVE
  INACTIVE
}

model AttachmentMimeConfig {
  id           String                     @id @default(cuid())
  typeConfigId String
  mime         String // 如 'image/jpeg' / 'application/pdf'
  status       AttachmentMimeConfigStatus @default(ACTIVE)
  remark       String?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  deletedAt    DateTime?

  typeConfig AttachmentTypeConfig @relation(fields: [typeConfigId], references: [id], onDelete: Restrict)

  @@unique([typeConfigId, mime]) // 同一 type 下 mime 不重复
  @@index([typeConfigId])
  @@index([status])
  @@index([deletedAt])
  @@map("attachment_mime_configs")
}

enum AttachmentMimeConfigStatus {
  ACTIVE
  INACTIVE
}

model AttachmentSizeLimitConfig {
  id           String    @id @default(cuid())
  typeConfigId String    @unique // 1:1 with AttachmentTypeConfig(每 type 至多一条 override)
  maxSizeBytes Int // 覆盖 AttachmentTypeConfig.defaultMaxSizeBytes
  remark       String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  typeConfig AttachmentTypeConfig @relation(fields: [typeConfigId], references: [id], onDelete: Restrict)

  @@index([deletedAt])
  @@map("attachment_size_limit_configs")
}

// =============================================================================
// V2.x C-7.5 Provider 选型实施 PR #6:storage_settings(沿 §6.5.2 + Q24)
//
// 单条记录(singleton row);系统级 Provider 配置;沿 Q4 锁腾讯 COS + Q18 单 bucket。
// 一次设计 15+ 字段;首期允许部分字段闲置(`null`);**严禁未来推翻 schema**。
// 加密字段 `secretIdEncrypted` / `secretKeyEncrypted` 由 StorageCryptoService 处理;
// 明文永不入库(沿 Q21 / Q22)。
// singleton 由第 49 migration 的 unique index on constant((true)) 在 DB 层强制;
// Prisma schema DSL 无法表达 expression index,故此处仅保留注释,不可误删 migration 索引。
// =============================================================================
model StorageSettings {
  id String @id @default(cuid())

  // Provider 选型(沿 Q4)
  providerType StorageProviderType
  enabled      Boolean             @default(true)

  // 运行参数(沿 Q11 / Q17 / Q18 / Q20)
  bucket                String?
  region                String?
  envPrefix             String?
  uploadUrlTtlSeconds   Int     @default(600)
  downloadUrlTtlSeconds Int     @default(300)
  lifecycleDays         Int     @default(30)

  // 能力开关(允许闲置;首期默认 true)
  enableSignedUrl  Boolean @default(true)
  enableVersioning Boolean @default(true)

  // CORS / 大小 / MIME 策略(沿 §6.5.3)
  corsAllowedOrigins    Json? // 首期闲置;运维 SOP 维护 COS bucket 侧
  maxObjectSizeBytes    BigInt? // 首期闲置;由 attachment_size_limit_configs 管业务侧
  allowedMimePolicyMode StorageMimePolicyMode @default(INHERIT) // 沿 Q-87-1 锁:首期固定 INHERIT

  // 凭证(加密存储;沿 Q21 / Q22)
  // 实际加密 = AES-256-GCM(沿 §6.6.1 + 立项记录 §四;Node 原生 crypto;0 新依赖)
  secretIdEncrypted    String? // 加密后的密文;明文永不入库
  secretKeyEncrypted   String? // 同上
  credentialConfigured Boolean @default(false) // DB 层简单事实;运行时 credentialStatus 三态由 Service 合成

  // 元信息
  remarks   String?
  updatedBy String? // User.id;沿 V2 范式;不建外键(沿 v1 软删 / RBAC 范式)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("storage_settings")
}

enum StorageProviderType {
  LOCAL
  COS
}

enum StorageMimePolicyMode {
  INHERIT // 沿 attachment_mime_configs(默认;首期锁定)
  OVERRIDE // 由 storage_settings 直接限定;留 v1.1+ 启用
}

// ===== V2.x P0-E PR-3 refresh_tokens 表 =====
//
// 沿 docs/first-release-p0e-refresh-token-review.md §5.2 schema 草案。
// rotation always + family revoke + absolute expiration(90d 不滑动);
// refresh token 明文绝不入库,只存 sha256 hash(沿 §5.1)。
//
// 撤销路径:
//   - rotation        → revokedReason='rotated' + replacedById 指向新 token
//   - logout          → revokedReason='logout'(只杀当前 row)
//   - logout-all      → revokedReason='logout'(updateMany where userId)
//   - 重放命中         → revokedReason='family-revoked'(updateMany where familyId)
//   - 改密 / 重置      → revokedReason='self-password-change' / 'admin-password-reset'
//   - 禁用 / 软删       → revokedReason='admin-disable' / 'admin-delete'
//
// revokedReason 不上 Prisma enum(沿 audit event 字符串风格;允许后续扩展不破坏 migration)。
// ipFirstSeen / uaFirstSeen 仅供审计,不出对外 API(沿 v1 §10 信息泄漏防御)。
model RefreshToken {
  id            String    @id @default(cuid())
  userId        String
  tokenHash     String    @unique // sha256(rawRefresh) hex 64 字符
  familyId      String // 同一登录链 rotation 串关联 id;login 时 cuid() 生成,rotation 继承
  expiresAt     DateTime // 绝对过期时刻;rotation 继承原 family 首个 token 的 expiresAt(不延长)
  createdAt     DateTime  @default(now())
  rotatedAt     DateTime? // 被 rotation 替换的时间
  revokedAt     DateTime? // 撤销时间;null = 仍有效
  revokedReason String? // 撤销原因(字符串枚举)
  replacedById  String?   @unique // rotation 后产生的新 token id
  ipFirstSeen   String? // 仅供审计;login 时写入,不对外
  uaFirstSeen   String? // 仅供审计;login 时写入,不对外

  user       User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  replacedBy RefreshToken? @relation("ReplacedBy", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces   RefreshToken? @relation("ReplacedBy")

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

// =============================================================================
// ===== SMS 基础设施 T1(2026-06-10)三表 + 三 enum =====
//
// 沿评审稿 docs/archive/reviews/sms-verification-infra-review.md §3.1(冻结文本;
// 维护者 2026-06-10 goal 拍板)。一次设计,允许部分字段首期闲置(null);严禁未来推翻 schema。
// - sms_settings 镜像 StorageSettings 范式:singleton 由第 49 migration 的
//   unique index on constant((true)) 在 DB 层强制(Prisma schema DSL 无法表达 expression index);
//   凭证 AES-256-GCM 加密(SmsCryptoService,T2),明文永不入库。
// - sms_verification_codes:明文验证码永不入库,只存
//   HMAC-SHA256(scrypt(SMS_ENCRYPTION_KEY,独立 salt),phone:purpose:code) hex(第七刀 F2);
//   同 phone+purpose 单活码由 supersededAt 实现(E-9);userId / codeId 不建外键(E-28)。
// - sms_send_logs:append-only 发送留痕,无更新/删除路径;响应层手机号一律掩码(E-20/E-21)。
// - retention:两表本期不清理,待办挂 NEXT_TASKS P2-6。
// =============================================================================
model SmsSettings {
  id String @id @default(cuid())

  // 通道选型(评审稿 D-SMS-2;production-like 禁 DEV_STUB,写入与运行时双重校验,E-15)
  providerType SmsProviderType
  enabled      Boolean         @default(true)

  // 腾讯云 SMS 运行参数(非 secret,明文;DEV_STUB 下闲置)
  sdkAppId               String?
  signName               String? // 短信签名(须先过审;运维 SOP 见 docs/ops/sms-production-rollout-checklist.md)
  region                 String? // 如 ap-guangzhou
  templateIdVerifyCode   String? // 验证码模板 ID(须先过审;templateKey='verify-code' 的 provider 侧映射)
  templateIdBirthday     String? // 生日祝福模板 ID(须先过审,零变量模板;templateKey='birthday-greeting' 的 provider 侧映射;queue-b 评审稿 §6.2)
  templateIdNotification String? // 通知兜底模板 ID(须先过审,零变量模板;templateKey='notification' 的 provider 侧映射;统一通知 S5 评审稿 §4)

  // 凭证(加密存储;明文永不入库;响应永不回显——密文也不回显)
  secretIdEncrypted    String?
  secretKeyEncrypted   String?
  credentialConfigured Boolean @default(false) // DB 层简单事实;运行时 credentialStatus 三态由 Service 合成

  // 元信息(沿 StorageSettings 范式;updatedBy 不建外键)
  remarks   String?
  updatedBy String? // User.id
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("sms_settings")
}

enum SmsProviderType {
  DEV_STUB // 非生产联调通道:固定码 888888 + debug 日志(评审稿 E-29;production-like 不可达)
  TENCENT_SMS
}

model SmsVerificationCode {
  id String @id @default(cuid())

  phone    String
  purpose  SmsPurpose
  codeHash String // HMAC-SHA256(pepper, phone:purpose:code) hex;明文码/pepper 永不入库
  userId   String? // 签发归属用户;PHONE_BIND=当前登录用户,PASSWORD_RESET=按 phone 解析的目标用户(password-reset 评审稿 E-7);字段可空留未来消费者;不建外键

  expiresAt    DateTime // 签发 +5min(常量,T3)
  consumedAt   DateTime? // 验证成功即消费
  supersededAt DateTime? // 同 phone+purpose 新码签发时旧码作废
  attempts     Int       @default(0) // 错误尝试计数;≥5 作废(统一 SMS_CODE_INVALID,防枚举)
  ip           String? // 签发请求 IP(防刷取证)
  createdAt    DateTime  @default(now())

  // 单活码定位 + 间隔/日限按 phone 前缀查询(评审稿 §3.1)
  @@index([phone, purpose])
  @@map("sms_verification_codes")
}

enum SmsPurpose {
  PHONE_BIND // 手机号绑定 / 换绑(登录态;sms-verification-infra 评审稿)
  PASSWORD_RESET // 找回密码(pre-auth;password-reset-by-sms 评审稿 §3.1)
  LOGIN // OTP 验证码登录(pre-auth;queue-b 评审稿 §5.1;通知用途不占 purpose——生日批走 send_logs.templateKey)
  WECHAT_BIND // 微信 openid 绑定锚点(pre-auth;wechat-mini-login 评审稿 D-W1)
  RECRUITMENT_BIND // H5 招新报名前手机身份链(pre-auth 匿名;recruitment-phase4 评审稿 §3.2 E-P4-3;userId 形参放宽 null,E-P4-4)
  IDENTITY_STEP_UP // 当前绑定手机号作为高危身份换绑的 step-up 因子(identity-session P0 PR1)
}

model SmsSendLog {
  id String @id @default(cuid())

  phone        String // 明文存储(对账需要);响应层一律掩码 138****1234
  templateKey  String // 逻辑模板键:'verify-code'(E-22)/ 'birthday-greeting'(B 队列 F5 生日批,2026-06-11);均非 provider 模板 ID
  providerType SmsProviderType
  status       SmsSendStatus

  providerMsgId String? // provider 回执 ID
  errCode       String? // 失败时 provider 错误码(不含 secret)
  errMsg        String? // 失败时 provider 错误信息(不含 secret)
  codeId        String? // 关联 sms_verification_codes.id;不建外键(retention 清理不受 FK 牵制)

  createdAt DateTime @default(now())

  // 按号排错 + 列表查询
  @@index([phone, createdAt])
  @@map("sms_send_logs")
}

enum SmsSendStatus {
  SENT
  FAILED
}

// =========================================================================
// 微信小程序登录基础设施 T1(2026-06-12;冻结评审稿
// docs/archive/reviews/wechat-mini-login-review.md §3.1,镜像 SmsSettings 范式)
//
// 凭证单例表(singleton 由第 49 migration 的 unique index on constant((true)) 在 DB 层强制;
// Prisma schema DSL 无法表达 expression index,E-3 的 Service WARN/取最早旧策略已退役);
// 与 SmsSettings 的差异:凭证仅 appSecret **一段**加密(SMS 是 secretId+secretKey 两段);
// 无 send-logs 对应物(code2session 免费查询类 API,无资费无触达,E-8)。
// =========================================================================

model WechatSettings {
  id String @id @default(cuid())

  // 通道选型(评审稿 E-6/E-10;production-like 禁 DEV_STUB,写入与运行时双重校验)
  providerType WechatProviderType
  enabled      Boolean            @default(true)

  // 小程序运行参数(非 secret,明文;DEV_STUB 下闲置;镜像 sdkAppId 地位)
  appId String?

  // 凭证(加密存储;明文永不入库;响应永不回显——密文也不回显;L3)
  appSecretEncrypted   String?
  credentialConfigured Boolean @default(false) // DB 层简单事实;运行时 credentialStatus 三态由 Service 合成

  // 元信息(沿 SmsSettings 范式;updatedBy 不建外键)
  remarks   String?
  updatedBy String? // User.id
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("wechat_settings")
}

enum WechatProviderType {
  DEV_STUB // 非生产联调通道:确定性假 openid dev-openid-<code>(评审稿 E-10;production-like 不可达)
  WECHAT
}

// =============================================================================
// ===== 保险模块 T1(2026-06-13)三表 + Activity.requiresInsurance =====
//
// 沿冻结评审稿 docs/archive/reviews/insurance-module-review.md §3.1(maintainer
// 2026-06-12 goal「保险模块」拍板)。业务依据:报名"无保险信息不予通过" + 志愿者
// 自购 + 队统一买(需求 :687/:698/:422/:452 + 顶层设计 §8 + C015)。
// - member_insurances:自购保险,每队员多条,App 自助 CRUD(self-scope 不接 RBAC);
//   coverageEnd 是有效性唯一依据(D-INS-5,自报即可 v1 无核验);policyNumber 无唯一约束(E-2)。
// - team_insurance_policies:队统一保单,一张 = 一条,admin CRUD;软删不级联覆盖行
//   (门槛查询 join p.deletedAt IS NULL,被删保单下覆盖行自然失效,E-4)。
// - team_insurance_coverages:保单 × 队员 join;partial unique (policyId, memberId)
//   WHERE "deletedAt" IS NULL 由 migration.sql 末尾手写(E-3,沿 activity_registrations 范式);
//   service 用 P2002 兜底转 26004。
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担(沿批次 1/2/3 B 路径)。
// - 保单图不占 schema 字段:attachments 多态(ownerType + ownerId)天然支持,
//   接线(enum 分支 + 8 权限码)挂 NEXT_TASKS 单独立项(E-20)。
// =============================================================================

model MemberInsurance {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberId      String
  insurerName   String // 保险公司;长度 128 由 DTO 约束(沿 Certificate.issuingOrg 范式)
  policyNumber  String // 保单号;长度 128 由 DTO 约束(沿 certNumber;无唯一约束,E-2)
  coverageStart DateTime? // 起保日(可选;有值时门槛校验 coverageStart <= 活动 startAt,E-11)
  coverageEnd   DateTime // 到期时间(必填;有效性唯一依据,D-INS-5)
  expireNotifiedAt DateTime? // v0.47.0 到期提醒幂等 marker;首次命中 30 天窗口后置 now,不因改期自动清空

  // D-INSURANCE v3 PR1 expand。legacy(含软删)统一 pending/v0，不推断 verified。
  reviewStatusCode String @default("pending") // pending / verified / rejected；PR1 runtime 尚不消费
  version          Int    @default(0)
  reviewedByUserId String?
  reviewedAt       DateTime?

  member                       Member                         @relation(fields: [memberId], references: [id], onDelete: Restrict)
  reviewer                     User?                          @relation("MemberInsuranceReviewer", fields: [reviewedByUserId], references: [id], onDelete: Restrict)
  insuranceEligibilityEvidences InsuranceEligibilityEvidence[]

  @@index([memberId])
  @@index([reviewStatusCode])
  @@index([reviewedByUserId])
  @@index([coverageEnd])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("member_insurances")
}

model TeamInsurancePolicy {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  insurerName   String // 保险公司;长度 128 由 DTO 约束
  policyNumber  String // 保单号;长度 128 由 DTO 约束
  coverageStart DateTime // 起保(必填,goal ②)
  coverageEnd   DateTime // 到期
  expireNotifiedAt DateTime? // v0.47.0 管理面到期提醒幂等 marker;首次命中 30 天窗口后置 now
  note          String? // 备注;长度 500 由 DTO 约束

  coverages TeamInsuranceCoverage[]

  @@index([coverageEnd])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("team_insurance_policies")
}

model TeamInsuranceCoverage {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  policyId String
  memberId String

  policy TeamInsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Restrict)
  member Member              @relation(fields: [memberId], references: [id], onDelete: Restrict)
  insuranceEligibilityEvidences InsuranceEligibilityEvidence[]

  // 业务唯一约束(partial unique;E-3):
  // - (policyId, memberId) WHERE "deletedAt" IS NULL
  // - 索引名 team_insurance_coverages_policy_member_active_unique
  // - Prisma DSL 不支持带 WHERE,migration.sql 末尾手动追加(沿 ActivityRegistration 范式)
  @@index([policyId])
  @@index([memberId])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("team_insurance_coverages")
}

// D-INSURANCE v3 PR1 expand-only compatibility skeleton.
// 双 source / 双 owner FK 与快照字段在兼容期全部可空；PR4 才加入 exactly-one、
// kind 对齐、区间、审核快照、跨 member、全局单 owner 与 immutable 约束。
// 本表刻意不含 updatedAt/deletedAt，也不存保单号、图片/附件/key/URL 或自由文本。
model InsuranceEligibilityEvidence {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  sourceKind              String?
  memberInsuranceId       String?
  teamInsuranceCoverageId String?
  ownerKind               String?
  activityRegistrationId  String?
  teamJoinApplicationId   String?
  sourceRevision          Int?
  sourceReviewedByUserId  String?
  sourceReviewedAt        DateTime?
  requiredFrom            DateTime?
  requiredThrough         DateTime?
  sourceCoverageStart     DateTime?
  sourceCoverageEnd       DateTime?

  memberInsurance       MemberInsurance?       @relation(fields: [memberInsuranceId], references: [id], onDelete: Restrict)
  teamInsuranceCoverage TeamInsuranceCoverage? @relation(fields: [teamInsuranceCoverageId], references: [id], onDelete: Restrict)
  activityRegistration  ActivityRegistration?  @relation(fields: [activityRegistrationId], references: [id], onDelete: Restrict)
  teamJoinApplication   TeamJoinApplication?    @relation(fields: [teamJoinApplicationId], references: [id], onDelete: Restrict)
  sourceReviewer        User?                   @relation("InsuranceEvidenceSourceReviewer", fields: [sourceReviewedByUserId], references: [id], onDelete: Restrict)

  @@index([memberInsuranceId])
  @@index([teamInsuranceCoverageId])
  @@index([activityRegistrationId])
  @@index([teamJoinApplicationId])
  @@index([sourceReviewedByUserId])
  @@index([createdAt])
  @@map("insurance_eligibility_evidences")
}

// =============================================================================
// ===== 招新一期(招新前段)T1(2026-06-18)3 表 + RealnameProviderType enum =====
//
// 沿冻结评审稿 docs/archive/reviews/recruitment-phase1-review.md §3.1(maintainer
// 2026-06-18 goal「招新一期(招新前段)」拍板 + §0.5 四分叉元核验冻结 + 3 配套)。
// 业务依据:招新需求会(讨论稿 v1 + 技术就绪度对照 v1)。报名者不建 User / 不进 members,
// 身份全由 recruitment_applications 承载,临时编号绑报名记录、永不进 members(D-R-1)。
// - recruitment_cycles:招新轮次,后台开/关 + 容量(可临时增容)+ tempNoSeq 临时编号原子
//   计数器(发号时 update +1,行级自增天然串行,E-R-9)+ 通知配置(后填,E-R-17)。
// - recruitment_applications:报名记录;openid 锚点(code2session 复用,E-R-7);敏感资料
//   (留存 SOP 30 天后 NULL 化 + 按 idCardImageKey 删 storage blob,配套②)与脱敏留存字段
//   (永久行级)共存(D-R-7 / E-R-14);statusCode String 沿 activity_registrations 范式(4 态);
//   tempNo 仅 verified 有值、≠ memberNo;**仅 FK→cycle(无 Member FK,D-R-1 的 schema 保证)**。
//   partial unique ×2 由 migration.sql 末尾手写(E-R-9/10,Prisma DSL 不支持带 WHERE)。
// - realname_verification_settings:实名核验单例,镜像 SmsSettings;凭证两段(secretId+
//   secretKey)AES-256-GCM(RealnameCryptoService,T2)明文永不入库;singleton 由 Service 保证。
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担(沿近期惯例)。
// =============================================================================

model RecruitmentCycle {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  year        Int // 招新年份(临时编号 T{year}{seq} 的 year)
  name        String // 轮次名(如「2026 年度招新」);长度由 DTO 约束
  statusCode  String // open / closed(后台开关;String 沿 activity_registrations.statusCode 范式)
  capacity    Int? // 容量上限(可临时增容;null=不限)
  tempNoSeq   Int       @default(0) // 临时编号原子计数器(发号时 update +1,E-R-9)
  // 招新二期(2026-06-19,评审稿 recruitment-phase2-review.md E-R2-6):永久编号当年流水原子计数器
  // (批量 promote 单事务内 +N,镜像 tempNoSeq 行级自增);{YY}{NNN} 的 NNN。
  memberNoSeq Int       @default(0)
  openedAt    DateTime?
  closedAt    DateTime?

  // 通知配置(后填;小程序展示 + 可选短信文案;E-R-17)
  meetingInfo    String? // 见面会信息
  qqGroup        String? // QQ 群
  notifyTemplate Json? // 可配置通知模板(各节点文案)

  applications     RecruitmentApplication[]
  identitySessions RecruitmentIdentitySession[]

  // 业务唯一约束(partial unique;migration.sql 手写,Prisma DSL 不支持带 WHERE;十项收口刀B):
  // - recruitment_cycles_single_open_unique ON ("statusCode")
  //   WHERE "statusCode" = 'open' AND "deletedAt" IS NULL —— 至多一个 open 轮 DB 兜底
  //   (开轮 count-then-update 在 READ COMMITTED 下可并发穿透);service P2002 兜底转 28032
  @@index([year])
  @@index([statusCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("recruitment_cycles")
}

model RecruitmentApplication {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cycleId    String
  statusCode String // pending_verification / verified / manual_review / rejected
  tempNo     String? // 临时编号 T{year}{seq};仅 verified 有值;≠ memberNo(永不进 members)

  openid String? // 微信 openid(code2session;再查询 + 同轮去重次级键;掩码回显)

  // ===== 敏感资料(留存 SOP:rejected 或 本轮 closed 满 30 天后 NULL 化 + 按 idCardImageKey 删 blob)=====
  realName          String?
  idCardNumber      String? // 身份证号(高敏感;同轮去重键;留存清)
  birthDate         DateTime? // 精确生日(从身份证号提取;留存清)
  phone             String? // 手机(仅通知联系方式,非身份证据,配套③;留存清)
  detailedAddress   String? // 详细住址(留存清)
  idCardImageKey    String? // 证件照 storage key(分叉③A;留存按 key 删 storage blob)
  emergencyContacts Json? // 紧急联系人 ≥2:[{name, relation, phone}](留存清)
  profileExtra      Json? // 其余报名字段(Q7 精简后冻结,本期最小;留存清)
  // 招新可用性收口 F5(2026-07-11;评审稿 §2.8 R5;第 42 migration,全 additive 可空):
  // 签名图 = 责任文件——promote 搬 member_profiles.signatureImageKey 长期留存 + 报名行清空
  // (镜像 idCardImageKey 搬运范式);未发号(rejected/withdrawn)行的 blob 随既有留存 SOP 按 key 删。
  signatureImageKey String? // 申请人签名图 storage key(multipart 必填文件位 signatureImage;存量可为 null)
  // 招新可用性收口 F7(2026-07-11;评审稿 §2.9 R6;第 44 migration,additive 可空):
  // 申请人证书图(公开上传,双通道凭证;category ∈ cert_type 既有码 first_aid/bsafe,每类 ≤3 张
  // 重传覆盖)。promote 时按类别自动建 pending Certificate 行 + 图 key 搬 Certificate.imageKeys,
  // 本列清空;未发号行的 blob 随既有留存 SOP 清理。形如 { [category]: string[] }。
  certificateImages Json? // 证书图 storage keys(按类别分组;R6 长期档案的暂存位)
  // 招新证书审核闭环:按类别记录 approved/rejected + at/by/note(无 PII);promote 时与证书图一并清空。
  certificateReviewStatus Json?
  // 招新证书发证信息:按类别记录 { issuingOrg, issuedAt:'YYYY-MM-DD' }(无 PII)。
  // promote 时搬入 Certificate 真值并清空;存量 null 由 promote 沿既有占位机构/当天日期回退。
  certificateIssuanceInfo Json?

  // ===== 脱敏留存字段(永久行级保留)=====
  documentTypeCode String // 证件类型(判非大陆证件/人工核验;非高敏)
  isForeigner      Boolean @default(false) // 历史 DB 列:非大陆证件(不代表国籍;列改名另行挂账)
  genderCode       String?
  ageGroup         String? // 年龄段(提交时从生日派生)
  cityDistrict     String? // 城市到区(提交时从住址派生)
  sourceChannel    String? // 来源渠道
  eliminationStage String? // 淘汰环节(rejected 时记)

  // 核验 / 人工记账
  verifiedAt        DateTime?
  verifyOutcome     String? // matched / mismatch / manual / skipped
  reviewedByUserId  String? // 人工 resolve 操作人(admin;不建外键,沿 SmsSettings.updatedBy)
  reviewedAt        DateTime?
  reviewNote        String?
  sensitivePurgedAt DateTime? // 留存清理(字段 NULL + blob 删)执行时刻

  // 业务唯一约束(partial unique;migration.sql 手写,Prisma DSL 不支持带 WHERE):
  // - (cycleId,idCardNumber/openid/phone) 各自 WHERE deletedAt IS NULL AND
  //   statusCode NOT IN ('rejected','withdrawn') AND 身份列 IS NOT NULL —— 同轮每个身份键至多
  //   一条活跃报名；service 预检负责友好失败，DB 约束兜底并发穿透后按 target 分流 28003/28004/28005。

  // 招新可用性收口 F5(2026-07-11;评审稿 §2.8;第 42 migration,全 additive 可空):
  // 知情同意留痕——submit 必填 privacyConsentAccepted=true(⚠️ 契约收紧)落时间戳 + 前端传版本号;
  // promote 的 member_profiles.privacyConsentSigned 由硬编码 true 改搬真值(acceptedAt != null)。
  // 本组为脱敏留存字段(非 PII,永久行级保留,不随留存 SOP 清)。
  privacyConsentAcceptedAt DateTime? // 勾选知情同意的时刻(submit 落 now;存量历史行 null)
  privacyConsentVersion    String? // 同意文本版本号(前端传,如 '2026-07';后端只存不校验内容)

  // ===== 招新二期(后段;2026-06-19,评审稿 recruitment-phase2-review.md)=====
  // 状态机扩展为 +3 String 态(pending_evaluation / publicity / promoted),沿 statusCode String 范式无 migration;
  // eliminationStage +2 值(evaluation / threshold-timeout)。以下为新增列(全可空,纯加列无破坏):
  thresholdMarks    Json? // 门槛标记(M-3 / E-R2-2):{ patrol1:{at,by}, patrol2, training, redCross, bsafe };仅 verified/pending_evaluation 态可标
  evaluatedByUserId String? // 综合评定操作人(不建外键,沿 reviewedByUserId / SmsSettings.updatedBy)
  evaluatedAt       DateTime?
  evaluationNote    String? // 综合评定备注(D-R2-3)
  promotedMemberId  String? // 报名→Member 链(E-R2-8;不建外键,保 phase-1 D-R-1「报名行无 Member FK」字面)

  // ===== 招新四期 S4a(H5 + 手机身份链;2026-06-24,评审稿 recruitment-phase4-loop-optimization-review.md §3.4)=====
  // 手机号上调为身份链锚(原仅通知用途);以下全可空、纯加列无破坏。phone 明文仍存 phone 列(留存清),
  // 本组为身份链元数据:验证方式 / 换绑轨迹 / 风险标记。掩码三不:audit/日志/snapshot 不出明文手机。
  phoneVerifiedAt         DateTime? // H5 验码成功时刻(小程序链恒 null);submit/rebind-phone 落
  phoneVerificationMethod String? // sms(H5 验码)/ wechat(小程序辅);提交时落
  phoneChangedAt          DateTime? // 自助换手机换绑时刻(rebind-phone)
  phoneChangeReason       String? // 换手机原因(自由短串,可含 PII;rebind-phone;留存/promote 清——十项收口刀C)
  phoneBindingHistory     Json? // 换绑历史追加 [{from,to,at,reason,method}](rebind-phone;DB 内可存明文,沿 phone 列同敏感级;留存/promote 清——十项收口刀C)
  phoneRiskFlag           String? // 风险标记(后台解绑纠错切片用;本刀仅建列不写)

  // ===== 招新四期 S4b(OCR 六分流 + 重拍计数;2026-06-24,评审稿 recruitment-phase4-loop-optimization-review.md §2)=====
  // 把现「5 分支全塞 manual_review」拆为六分流;以下 4 列全 additive(可空/有默认,纯加列无破坏,无 enum)。
  // verifyOutcome(机器判定原因,既有)保留并复用;manualReviewReason(后台人工队列分类)+ riskLevel(三栏分流)并存(§2.2 E-P4-2)。
  // 重拍计数落 §3 报名前身份会话行(recruitment_identity_sessions,Q-P4-1);submit 落库时把会话行最近 OCR 结论快照进 lastOcrOutcome。
  manualReviewReason         String? // 后台人工原因分类:ocr_mismatch_confirmed / forgery_suspected / system_ocr_error / special_document(§2.2/§2.4)
  riskLevel                  String? // 复核风险级:normal / high(防伪/篡改)/ system(上游异常)——驱动后台三栏(§2.4);**申请人侧不暴露**
  applicantConfirmedOcrWrong Boolean @default(false) // mismatch 三选一之③:申请人确认 OCR 错、坚持填写为准 → 落普通人工(§2.1)
  lastOcrOutcome             String? // 最近一次 OCR 结论快照(= 某 verifyOutcome 值;submit 落库时从会话行结转,§2.2/§2.3)

  // ===== OCR 鉴伪版充分利用(2026-06-29,评审稿 recruitment-ocr-anti-forgery-enrichment-review.md §3.1/§4)=====
  // 仅 mainland_id RecognizeValidIDCardOCR 充分利用:扩展字段入库 + 主体/头像裁剪图入库。以下 6 列全 additive
  // (可空,纯加列无破坏,无 enum、无默认、无回填)。OCR 读取值 = **顾问式存档,非权威**;gender/birth 仍由身份证号
  // 推导(genderCode/birthDate),本组**不参与**派生、OCR 的 Sex/Birth 仅 recognize 回显不持久。住址为高敏感 PII,
  // 与 idCardNumber 同级、纳入 read.sensitive 门控(masked→null)。裁剪图仅 submit 解码入库,base64 不入响应/日志(L3)。
  // 十项收口刀C(2026-07-11):本组 6 列 promote 时即时清(OCR 4 列置 NULL;主体裁剪图先删 blob 再清 key;
  // 头像裁剪图搬 User.avatarKey 后清 key)——promote 置 sensitivePurgedAt 会使留存 SOP 永久跳过该行,漏清即永久残留。
  ocrAddress             String? // OCR 住址(顾问式存档;≠ applicant 自填 detailedAddress;高敏感,read.sensitive 门控;留存/promote 清)
  ocrNation              String? // OCR 民族(民族属敏感个人信息;留存/promote 清)
  ocrAuthority           String? // OCR 签发机关(留存/promote 清)
  ocrValidDate           String? // OCR 有效期(腾讯返串,如 2010.07.21-2020.07.21 / 2010.07.21-长期;不解析 DateTime;留存/promote 清)
  idCardCropImageKey     String? // 主体框裁剪图 storage key(CardImage;后台人工复核查看;留存/promote 按 key 删 blob 后清)
  idCardPortraitImageKey String? // 头像裁剪图 storage key(PortraitImage;十项收口刀E:promote 搬 User.avatarKey 设为队员头像,同一 blob 属主转 user、本列清空;未发号行留存按 key 删 blob)

  cycle RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)

  // 业务唯一约束(partial unique;migration.sql 末尾手写,E-R-9/10;Prisma DSL 不支持带 WHERE):
  // - recruitment_applications_cycle_idcard_active_unique ON (cycleId, idCardNumber)
  //   WHERE "deletedAt" IS NULL AND "statusCode" NOT IN ('rejected','withdrawn') —— 防重复报名
  //   (同轮同人),允许 rejected / withdrawn(F6 自助撤销,R4)后同轮重试;service P2002 兜底转
  //   28003(沿 activity_registrations 范式;排除集 F6 第 43 migration 重建)
  // - recruitment_applications_cycle_tempno_unique ON (cycleId, tempNo)
  //   WHERE "tempNo" IS NOT NULL —— 临时编号同轮唯一(配合 tempNoSeq 原子自增兜底并发)
  @@index([cycleId])
  @@index([statusCode])
  @@index([openid])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("recruitment_applications")
}

// 招新四期 S4a(H5 + 手机身份链;2026-06-24,评审稿 recruitment-phase4-loop-optimization-review.md §3.3 / E-P4-5)。
// 报名前身份会话行(净新建):承载「H5 验码 → 短时一次性 token → 提交」的有时间差身份链。
// **不进 recruitment_applications,不参与去重/统计/容量**;TTL 过期由留存 SOP 清(expiresAt 索引)。
// 临时凭证(沿 sms_verification_codes / refresh_tokens 范式):token 入库只存 sha256 hex,
// consumedAt 标一次性消费(非 deletedAt 软删);明文 token 仅验码响应一次性返客户端,永不入库/日志。
// ocrAttemptCount/lastOcrOutcome/requiresRetake 为 S4b(OCR 六分流重拍计数)**预建列,本刀不写逻辑**(Q-P4-1)。
model RecruitmentIdentitySession {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime // 签发 + TTL(30min);过期即不可消费

  cycleId String // 轮次锚(token 限定本轮);真实 FK

  phone                      String // 验证过的手机(身份链锚)
  phoneVerifiedAt            DateTime // 验码成功时刻
  phoneVerificationMethod    String // sms(H5)/ wechat(小程序辅)
  phoneVerificationTokenHash String    @unique // sha256(raw) hex;明文 token 永不入库,验码一次性返客户端
  consumedAt                 DateTime? // submit 原子消费即作废(一次性;镜像 sms_verification_codes.consumedAt)
  openid                     String? // 可选(小程序链 code2session 得)

  // S4b 预建(OCR 六分流重拍计数;本刀仅建列、不写逻辑;Q-P4-1)
  ocrAttemptCount Int     @default(0)
  lastOcrOutcome  String?
  requiresRetake  Boolean @default(false)

  cycle RecruitmentCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@index([phone, cycleId]) // 手机 + 轮次查(§3.3)
  @@index([cycleId])
  @@index([expiresAt]) // TTL 清理(留存 SOP)
  @@map("recruitment_identity_sessions")
}

// 招新可用性收口 F1(2026-07-11;评审稿 recruitment-usability-closeout-review.md §2.5/E-U-1)。
// 付费 OCR 调用(recognize + submit 共享)按 IP × 北京自然日(UTC+8)封顶的持久化计数表:
// 独立于内存态限流器(重启不清零),env `RECRUITMENT_OCR_DAILY_IP_LIMIT`(默认 30)判限。
// 纯基建计数行(非业务行):无 deletedAt / 无 FK;原子 upsert increment 后判限(先加后判,
// 拒者恒拒,超限尝试也计数 = 保守防滥用,沿 sms 日限「含失败行」口径 E-11)。
// 旧日期行由留存 SOP 按 dateKey 清理(不建 cron)。
model RecruitmentOcrDailyCounter {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ip      String // 请求出口 IP(req.ip;缺省归一 'unknown' 桶,不可绕计)
  dateKey String // 北京自然日 YYYY-MM-DD(固定 UTC+8 日界,沿 sms/stats 各模块级实现口径)
  count   Int    @default(0) // 当日该 IP 已发起的付费 OCR 调用数(含被上游拒/失败的尝试)

  @@unique([ip, dateKey])
  @@index([dateKey])
  @@map("recruitment_ocr_daily_counters")
}

// singleton 由第 49 migration 的 unique index on constant((true)) 在 DB 层强制;
// Prisma schema DSL 无法表达 expression index,故此处仅保留注释,不可误删 migration 索引。
model RealnameVerificationSettings {
  id String @id @default(cuid())

  // 通道选型(production-like 禁 DEV_STUB,写入与运行时双重校验,镜像 sms E-15)
  providerType RealnameProviderType
  enabled      Boolean              @default(true)

  // 腾讯云实名核验运行参数(非 secret,明文;DEV_STUB 下闲置)
  region String? // 如 ap-guangzhou

  // 凭证(两段 secretId+secretKey;AES-256-GCM 加密,RealnameCryptoService T2;明文永不入库,密文也不回显)
  secretIdEncrypted    String?
  secretKeyEncrypted   String?
  credentialConfigured Boolean @default(false) // DB 层简单事实;运行时 credentialStatus 三态由 Service 合成

  // 元信息(沿 SmsSettings 范式;updatedBy 不建外键)
  remarks   String?
  updatedBy String? // User.id
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("realname_verification_settings")
}

enum RealnameProviderType {
  DEV_STUB // 非生产联调通道:确定性两路(身份证校验位 偶=matched / 奇=mismatch,E-R-6;production-like 不可达)
  TENCENT_CLOUD
}

// =============================================================================
// 招新三期(入队:志愿者 → 队员)—— 第 27 模块 team-join(2026-06-19)
// 冻结评审稿 docs/archive/reviews/recruitment-phase3-review.md §3.1。
// - team_join_cycles:入队轮(annual,admin 开/关,至多一个 open);比 recruitment_cycles
//   更简(无发号 seq / capacity / 通知配置 —— member 已有 memberNo,本期不发号)。
// - team_join_applications:入队申请,**有真实 memberId FK**(申请人已是 member,与
//   recruitment_applications「无 Member FK」相反);gateMarks Json 落 8 通用 + 0~4 专业队 gate
//   (contribution 实时算不落库);partial unique 由 migration.sql 末尾手写(E-J-2,Prisma DSL
//   不支持带 WHERE);selectedOrganizationId 一键入队时定最终单部门。
// - 字段长度上限不落 @db.VarChar,由 DTO + class-validator 承担(沿近期惯例)。
// =============================================================================

model TeamJoinCycle {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  year       Int // 入队年份(贡献值 cutoff = {year}-03-31 北京日界;级别/编号无关)
  name       String // 轮次名(长度由 DTO 约束)
  statusCode String // open / closed(后台开关;至多一个 open:service 预检 + partial unique DB 兜底)
  openedAt   DateTime?
  closedAt   DateTime?
  requiresInsurance Boolean @default(false) // PR1 dormant flag；PR3 gate cutover 前不参与入队判断

  // 入队候选部门配置(PR-4 才接业务):null/空=全部 ACTIVE;max null=默认 8。
  openOrganizationIds Json?
  maxTargetOrgs        Int?

  applications TeamJoinApplication[]

  // 业务唯一约束(partial unique;migration.sql 手写,Prisma DSL 不支持带 WHERE;十项收口刀B):
  // - team_join_cycles_single_open_unique ON ("statusCode")
  //   WHERE "statusCode" = 'open' AND "deletedAt" IS NULL —— 至多一个 open 轮 DB 兜底
  //   (镜像 recruitment_cycles_single_open_unique);service P2002 兜底转 28231
  @@index([year])
  @@index([statusCode])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("team_join_cycles")
}

model TeamJoinApplication {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  cycleId  String
  memberId String // 申请人(phase-2 promote 出的已转正志愿者);真实 FK,与 recruitment_applications 相反

  statusCode             String // joining / pending_evaluation / approved / joined / rejected
  targetOrganizationIds  Json // 候选目标部门 orgId 数组(志愿者自助选,可多;joining 态可改)
  gateMarks              Json? // { [gateCode]: { at, by, passed, completionDate, extendedUntil? } };8 通用 + 0~4 专业队;contribution 不在此(实时算)
  selectedOrganizationId String? // 一键入队时 admin 定的最终单部门

  evaluatedByUserId       String? // 综合评估操作人(不建外键,沿 reviewedByUserId / SmsSettings.updatedBy)
  evaluatedAt             DateTime?
  evaluationNote          String?
  evaluationExtendedUntil DateTime? // 综合评估延长期(自本版起仅存档;approved 不随轮关闭失效)

  eliminationStage String? // evaluation / gate-timeout(rejected 时记)
  joinedAt         DateTime? // 一键入队执行时刻

  cycle        TeamJoinCycle @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  member       Member        @relation(fields: [memberId], references: [id], onDelete: Restrict)
  organization Organization? @relation(fields: [selectedOrganizationId], references: [id], onDelete: Restrict)
  insuranceEligibilityEvidences InsuranceEligibilityEvidence[]

  // 业务唯一约束(partial unique;migration.sql 末尾手写,E-J-2;Prisma DSL 不支持带 WHERE):
  // - team_join_applications_member_cycle_active_unique ON (memberId, cycleId)
  //   WHERE "deletedAt" IS NULL AND "statusCode" <> 'rejected' —— 同轮同人至多一活跃申请,
  //   允许 rejected 后同轮重试;service P2002 兜底转 28203(沿 recruitment 范式)
  @@index([cycleId])
  @@index([memberId])
  @@index([statusCode])
  @@index([selectedOrganizationId])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("team_join_applications")
}

// CMS 内容发布模块(第 28 模块,2026-06-21;冻结评审稿 docs/archive/reviews/content-module-review.md)。
// 公告 / 公示 / 简报 / 推文统一一表;正文 Markdown 原文;5 级可见(每篇选一档);立即发布无 cron。
// 封面 / 正文图 / 文件附件统一为 Attachment 行(ownerType='content-image'|'content-file' + ownerId=content.id),
// 不在本表;content 读取面自签下载 URL 并按文章可见级闸控(评审稿 §5 + attachments/CLAUDE.md 范围例外 a)。
model Content {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title           String // 标题(DTO ≤ 200)
  summary         String? // 摘要(DTO ≤ 500)
  body            String // 正文 Markdown 原文(PG text);含 ![](attachment:<attachmentId>) 占位,读时改写为签名 URL;DTO ≤ 50000
  contentTypeCode String // ∈ content_type 字典 item(announcement / publicity / briefing / post)
  statusCode      String // draft / published / archived(String 常量,无 enum,沿 recruitment 范式)
  visibilityCode  String // public / member / formal_member / department / management(每篇选一档)

  visibleOrganizationIds String[] @default([]) // department 档可见部门 orgId;String[] 供 list where hasSome 过滤(沿 attachments.tags 范式)
  tags                   String[] @default([]) // 标签;读取面 hasSome 筛选(无 GIN,沿 attachments.tags / MemberProfile.exerciseMethods 无索引惯例,v1 顺扫)

  coverImageKey     String? // 封面反范式 storage key(列表缩略图直签,免 per-row Attachment 查询)
  coverAttachmentId String? // 封面对应 content-image 附件 id(标记 / 换 / 清;不建外键)

  viewCount Int @default(0) // 累计 PV(详情打开原子自增;列表 / 预览 / 404 不计)

  pinned       Boolean   @default(false) // 置顶
  publishedAt  DateTime? // publish 时置 now;unpublish 保留;draft 从未发布为 null
  authorUserId String? // 创建 / 操作 admin;不建外键(沿 reviewedByUserId / SmsSettings.updatedBy)

  @@index([statusCode])
  @@index([visibilityCode])
  @@index([contentTypeCode])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([statusCode, publishedAt]) // 公开 / 会员列表:published 按发布时间序常用复合
  @@map("contents")
}

// ===== 统一通知模块 S1:站内信渠道(第 28 模块 notifications 扩 controller,非新模块)=====
//
// 冻结评审稿:docs/archive/reviews/unified-notification-dispatcher-review.md(T0 修订;统一形状 §2/§5/§11)
//   supersede 原 docs/archive/reviews/member-notification-review.md §3(站内信 schema 本切片照建)。
// 镜像 Content(状态机 draft/published/archived + 可见性分档〔去 public = 4 档〕+ 软删 + readCount 反范式);
// 额外一张轻量已读表 NotificationRead(站内信核心差异)。**首切片一次建成统一形状**:audienceType /
// sourceType / channels 前向兼容列本切片即加(S1 仅用 broadcast / admin / in-app 值),后续 S2 微信 quota /
// S3 producer 定向(recipientMemberId / producerModule)只 additive 扩列扩表,站内状态机 / 可见性 / 已读语义零返工。
model Notification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  title                String // 标题(DTO ≤ 200)
  body                 String // 站内信正文(PG text;纯文本 / 轻 Markdown;DTO ≤ 5000,v1 无正文图 / 附件)
  notificationTypeCode String // ∈ notification_type 字典 item(activity-reminder / recruitment / emergency / general / expiry-reminder)
  statusCode           String // draft / published / archived(String 常量,无 enum,镜像 content)
  visibilityCode       String // member / formal_member / department / management(4 档;去 public,会员面专属)

  visibleOrganizationIds String[] @default([]) // department 档可见部门 orgId 数组(hasSome;镜像 content)

  // ===== 统一通知形状前向兼容列(S1 即加默认值;S2/S3 additive 不返工)=====
  audienceType String   @default("broadcast") // broadcast(S1/S2 admin 广播)| directed(S3 producer 定向)(D-N9)
  sourceType   String   @default("admin") // admin(S1/S2 撰写)| system(S3 producer 自动)(D-N1)
  channels     String[] @default(["in-app"]) // 目标渠道声明(§7;in-app 恒发,wechat = S2,sms = S5)

  // 定向收件人(统一通知 S3;评审稿 §2.1 / §9.1;migration 第 29)。
  // 广播 = null;directed = 单一收件人 member。FK onDelete Restrict(沿仓内惯例;收件人软删后定向行成无害孤儿)。
  // feed 仅本人可见(notification-read.service 扩 where:广播可见 ∪ 本人定向;他人 → 31001 防枚举)。
  recipientMemberId String?

  readCount    Int       @default(0) // 反范式已读人数(首次 mark-read 原子 increment;镜像 content.viewCount)
  pinned       Boolean   @default(false) // 置顶
  publishedAt  DateTime? // publish 时置 now;unpublish 保留;draft 从未发布为 null
  authorUserId String? // 发布 admin;不建外键(沿 content.authorUserId / reviewedByUserId);system 定向为 null

  reads      NotificationRead[]
  deliveries NotificationDelivery[] // 推送渠道(微信/短信)per-recipient 投递态(S2 起;站内不落)
  recipient  Member?                @relation(fields: [recipientMemberId], references: [id], onDelete: Restrict)

  @@index([statusCode])
  @@index([visibilityCode])
  @@index([notificationTypeCode])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([statusCode, publishedAt]) // 会员 feed:published 按发布时间序常用复合
  @@index([audienceType, recipientMemberId]) // 定向 feed:某 member 的 directed 通知(S3)
  @@map("notifications")
}

// 已读回执(notificationId × memberId,append-once;无 updatedAt / 无 deletedAt = immutable)。
// plain unique([notificationId, memberId])——已读不软删,无需 partial-unique-WHERE(与 TeamInsuranceCoverage 刻意差异)。
// FK 全 onDelete: Restrict(沿仓内惯例);通知软删后已读行成无害孤儿(retention SOP 手动清,不解锁 cron)。
model NotificationRead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) // = 首次已读时刻(readAt)

  notificationId String
  memberId       String

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Restrict)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Restrict)

  @@unique([notificationId, memberId]) // 一会员对一通知至多一条(plain unique;mark-read upsert 幂等键)
  @@index([memberId]) // 会员未读查询主路径(NOT EXISTS 子查询)
  @@index([notificationId])
  @@map("notification_reads")
}

// =============================================================================
// 统一通知模块 S2 微信订阅 quota 渠道(2026-06-25;冻结评审稿
// docs/archive/reviews/unified-notification-dispatcher-review.md §3/§9.1,D-N2/D-N3/D-N6)。
// 三张净新增表(全 additive,无破坏、无回填、无 enum;migration 第 28);站内 S1 语义零返工。
// =============================================================================

// 推送渠道 per-recipient 投递态(§2.1 核心张力解法:fan-out 只发生在推送渠道,站内不落)。
// S2 仅 wechat 渠道;短信 = S5。流水语义(沿 sms_send_logs append-only;notificationId FK Restrict 串父记录,
// memberId 松引用不建 FK——投递日志不应被会员软删牵制,镜像 sms_send_logs 零 FK 取舍)。
// recipientRef = 掩码后 openid / phone(maskOpenid / maskPhone;明文永不入库,L3/L2 纪律)。
model NotificationDelivery {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  notificationId String
  channel        String // wechat(S2 唯一)| sms(S5);代码常量非字典
  memberId       String // 收件人 member(松引用,不建 FK;openid 可换绑故按 memberId 留痕)
  recipientRef   String // 掩码 openid / phone(回显安全;明文不入库)
  status         String // pending | sent | failed | skipped
  reasonCode     String? // no-quota / no-openid / need-resubscribe / invalid-openid / template-param / token-failed / no-template
  providerMsgId  String? // provider 回执 ID(微信 msgid;不含 secret)
  errCode        String? // 失败时 provider 错误码(微信 errcode 字符串;不含 secret)
  attemptedAt    DateTime? // 实际发起外部调用时刻(skipped = null,未发起外部调用)

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Restrict)

  @@index([notificationId])
  @@index([memberId, channel])
  @@index([status])
  @@map("notification_deliveries")
}

// 微信订阅消息配额(memberId × templateId → availableCount;D-N2 上限默认 5)。
// 按 memberId 存(非 openid)——openid 可换绑(招新 S4a rebind),memberId 稳定;发送时 member→user→openid 现取。
// +1(ack)= upsert increment 配上限;-1(发送)= 条件原子扣减 updateMany(availableCount>0),count===1 才发。
// 松引用 memberId 不建 FK(状态表,会员软删不应牵制;镜像 sms_send_logs / wechat 流水取舍)。
model WechatSubscriptionQuota {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberId       String
  templateId     String
  availableCount Int    @default(0) // ≥ 0(条件原子扣减杜绝越扣为负)

  @@unique([memberId, templateId]) // 一会员一模板至多一行(ack upsert 键 + count 查询主路径)
  @@index([templateId]) // 派发:按 templateId 取有配额会员(availableCount > 0)
  @@map("wechat_subscription_quotas")
}

// 微信订阅消息模板配置(notificationTypeCode → templateId;运营可配,D-N3)。
// 镜像 sms_settings.templateIdBirthday「模板 ID 存配置、运营改不重部署」先例,但一类型一模板故独立表(1:1)。
// 字段映射(payload → 微信 data key)= 内置代码(随类型固定,不入本表;见 notification.wechat-data.ts)。
// templateId 可空:小程序后台审批后由 admin 填;未填 / disabled = 该类型微信渠道不可发(派发 skip no-template)。
model WechatSubscribeTemplate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notificationTypeCode String  @unique // ∈ notification_type 字典;一类型一模板
  templateId           String? // 微信订阅消息模板 ID(运维上线后台审批后填)
  enabled              Boolean @default(true)
  remarks              String?
  updatedBy            String? // User.id(不建外键,沿 settings 范式)

  @@map("wechat_subscribe_templates")
}

// PostgreSQL durable notification outbox(D-Outbox;2026-07-18)。
// status 使用代码常量而非 enum，worker 以 SKIP LOCKED + lease/fencing 多实例领取；
// payload 只保存内部引用与安全文案，手机号/openid/token/secret/credential/signed URL
// 及 provider 原始请求/响应均不得进入本表。成功/死信 retention 仅走人工 SOP。
// migration 另有手写 partial unique：微信 delivery / admin SMS 各自同
// aggregateId/destinationRef 同时至多一条 pending/processing；Prisma DSL 无法表达 partial
// unique，勿用普通 @@unique 误伤 terminal generation history。
model NotificationOutboxIntent {
  id        String   @id @default(cuid())
  eventKey  String   @unique
  eventType String
  payloadVersion Int
  payload   Json

  aggregateType String
  aggregateId   String
  destinationType String
  destinationRef  String

  status      String   @default("pending")
  attempts    Int      @default(0)
  availableAt DateTime @default(now()) @db.Timestamptz(3)

  leaseOwner    String?
  lockedAt      DateTime? @db.Timestamptz(3)
  leaseExpiresAt DateTime? @db.Timestamptz(3)

  preparedAt DateTime? @db.Timestamptz(3)
  sentAt     DateTime? @db.Timestamptz(3)
  completedAt DateTime? @db.Timestamptz(3)

  lastErrorCode  String?
  lastErrorClass String?
  deadAt         DateTime? @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([status, availableAt, leaseExpiresAt])
  @@index([leaseExpiresAt])
  @@index([aggregateType, aggregateId])
  @@index([status, completedAt])
  @@index([status, deadAt])
  @@index([createdAt])
  @@map("notification_outbox_intents")
}

// PostgreSQL shared throttler storage(D-Throttle;2026-07-18):10 个命名 throttler
// 共用数据库桶，(throttlerName,key) 物理隔离。hitExpiresAt 保存每次未 blocked hit
// 的独立滚动过期点；过期桶仅走手动 retention SOP，刻意不新增第 3 个 cron。
model ThrottlerBucket {
  id String @id @default(cuid())

  throttlerName String
  key           String

  hitExpiresAt    DateTime[] @default([]) @db.Timestamptz(3)
  windowExpiresAt DateTime   @default(now()) @db.Timestamptz(3)
  blockedUntil    DateTime?  @db.Timestamptz(3)
  retentionAt     DateTime   @default(now()) @db.Timestamptz(3)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@unique([throttlerName, key])
  @@index([retentionAt])
  @@map("throttler_buckets")
}
