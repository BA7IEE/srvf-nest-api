# 第 3 阶段(Prisma 接入)所需,Prisma CLI 自动从 .env 读取
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public

# 第 4 阶段(公共基础件 / 应用配置)所需
APP_PORT=3000
# APP_ENV 必须 ∈ { development | test | production | smoke }
# - smoke 是 CI Docker smoke job 专用环境(沿 V2.x production storage_settings fail-fast):
#   除 storage_settings fail-fast 外行为同 production(JSON 日志 / 严格 CORS / 默认禁 Swagger /
#   STORAGE_ENCRYPTION_KEY 必填 / 隐藏异常 message)。**不得用于真实部署**。
APP_ENV=development
# 多个 origin 用英文逗号分隔;production 下禁止为空,禁止 *
APP_CORS_ORIGIN=http://localhost:5173
# 留空表示:开发环境开启,生产环境关闭;production 下设 'true' 才开启 /api/docs
# 必须严格字符串判断 === 'true',禁止 truthy 判断
ENABLE_SWAGGER=

# 第 7 阶段(auth/JWT)所需
# JWT_SECRET 必须 ≥ 32 字符;production 下不能等于此默认值
# 推荐生成命令:openssl rand -base64 48
JWT_SECRET=please-change-me-in-production-min-32-chars
# P0-E PR-3(2026-05-18):由 7d 收敛到 15m(沿 docs/first-release-p0e-refresh-token-review.md §3.5 D-5)
# 配合 refresh token 模式;到期由前端调 POST /api/auth/refresh 续期(rotation always + absolute expiration)
JWT_EXPIRES_IN=15m
# P0-E PR-3(2026-05-18):refresh token TTL(absolute expiration,90d 不滑动续期;沿评审稿 §3.5 D-5)
# - 字符串支持 ms 兼容字符串(`90d` / `30d` / `1h` 等);本项目锁定 `90d`(内部系统低频用户友好)
# - rotation 后新 refresh token expiresAt **严格继承**原 family 首个 token 时刻,不延长
# - 到达 refreshExpiresAt 后必须重新登录(POST /api/auth/login);refresh 接口对已过期 family
#   返 REFRESH_TOKEN_INVALID=10007;前端不应也不能"自动续期"绕过此约束
# - 响应字段叫 `refreshExpiresAt`(ISO 8601 UTC),由 service 内 toISOString() 计算后返客户端
JWT_REFRESH_EXPIRES_IN=90d

# 第 9 阶段(prisma/seed.ts)默认 super admin
# - SUPER_ADMIN_USERNAME 必须符合 ^[a-z0-9_-]{3,32}$;production 下禁止 'admin'
# - SUPER_ADMIN_PASSWORD 必须设置;production 下禁止默认值 'ChangeMe123456'
# - SUPER_ADMIN_EMAIL 可选,留空则不写入 email 字段(不要写空字符串入库)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=ChangeMe123456
SUPER_ADMIN_EMAIL=

# V1.1 §11.5:结构化日志 pino 级别
# 允许值:fatal | error | warn | info | debug | trace
# 留空时按 APP_ENV 自动推断:production=info,非 production=debug
LOG_LEVEL=

# V1.1 §11.5 / TASKS.md 15.7:POST /api/auth/login IP 维度限流参数
# 内存 storage,不引入 Redis(多实例不共享配额,V1.1 单实例够用)
# LOGIN_THROTTLE_LIMIT:单窗口内允许的最大尝试次数,留空默认 5,推荐区间 [1, 100]
# LOGIN_THROTTLE_TTL_SECONDS:TTL 窗口秒数,留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
LOGIN_THROTTLE_LIMIT=
LOGIN_THROTTLE_TTL_SECONDS=

# P0-D PR-3(2026-05-17):PUT /api/users/me/password IP 维度限流参数
# 沿 docs/first-release-p0d-change-my-password-review.md §5.4
# 与 LOGIN_THROTTLE_* 物理隔离的独立 throttler 实例(name: 'password-change');
# 计数器互不影响:登录失败爆破不消耗改密配额,反之亦然。
# POST /api/auth/logout-all 也走此 throttler(沿评审稿 §3.7 D-7 复用范式;
# "高危操作低频限流"语义对称)。
# PASSWORD_CHANGE_THROTTLE_LIMIT:留空默认 5,推荐区间 [1, 100]
# PASSWORD_CHANGE_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
PASSWORD_CHANGE_THROTTLE_LIMIT=
PASSWORD_CHANGE_THROTTLE_TTL_SECONDS=

# P0-E PR-3(2026-05-18):POST /api/auth/refresh IP 维度限流参数
# 沿 docs/first-release-p0e-refresh-token-review.md §3.7 D-7 + §5.8
# 与 LOGIN_THROTTLE_* / PASSWORD_CHANGE_THROTTLE_* 物理隔离的独立 throttler 实例(name: 'refresh');
# 计数器互不影响:登录失败爆破不消耗 refresh 配额,反之亦然。
# REFRESH_THROTTLE_LIMIT:留空默认 30(比登录 / 改密放宽,允许多 tab 并发 refresh),推荐区间 [1, 100]
# REFRESH_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
# 注:POST /api/auth/logout **不限流**(刻意;避免攻击者吃光合法用户 logout 配额)
REFRESH_THROTTLE_LIMIT=
REFRESH_THROTTLE_TTL_SECONDS=

# SMS 基础设施 T3(2026-06-10):POST /api/app/v1/me/phone/send-code IP 维度限流参数
# 沿 docs/archive/reviews/sms-verification-infra-review.md D-SMS-6 / E-23
# 与上述各 throttler 物理隔离的第 4 个独立实例(name: 'sms-send');
# 防刷三层的 IP 层:同号 60s 间隔 + 同号自然日上限在 DB 层(SmsCodeService)承接。
# SMS_SEND_THROTTLE_LIMIT:留空默认 5,推荐区间 [1, 100]
# SMS_SEND_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
SMS_SEND_THROTTLE_LIMIT=
SMS_SEND_THROTTLE_TTL_SECONDS=

# SMS 基础设施 T3(2026-06-10):PUT /api/app/v1/me/phone(验码绑定 / 换绑)IP 维度限流参数
# 沿 docs/archive/reviews/sms-verification-infra-review.md D-SMS-6 / E-23
# 与上述各 throttler 物理隔离的第 5 个独立实例(name: 'sms-verify');
# 验码侧默认较发码放宽(10/60):正常用户可能连续输错;错 5 次作废由验证码服务(DB 层)承接。
# SMS_VERIFY_THROTTLE_LIMIT:留空默认 10,推荐区间 [1, 100]
# SMS_VERIFY_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
SMS_VERIFY_THROTTLE_LIMIT=
SMS_VERIFY_THROTTLE_TTL_SECONDS=

# 找回密码 T2(2026-06-11):POST /api/auth/v1/password-reset{,/send-code} IP 维度限流参数
# 沿 docs/archive/reviews/password-reset-by-sms-review.md D-PR-4 / E-10
# 与上述各 throttler 物理隔离的第 6 个独立实例(name: 'password-reset');
# 默认刻意严于 sms-send(5/60):pre-auth 公开端点,是防枚举侧信道采样与费用滥用的第一道闸。
# PASSWORD_RESET_THROTTLE_LIMIT:留空默认 3,推荐区间 [1, 100]
# PASSWORD_RESET_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
PASSWORD_RESET_THROTTLE_LIMIT=
PASSWORD_RESET_THROTTLE_TTL_SECONDS=

# OTP 登录 F4-T2(2026-06-11):POST /api/auth/v1/login-sms{,/send-code} IP 维度限流参数
# 沿 docs/archive/reviews/queue-b-otp-birthday-infra-review.md E-O3
# 与上述各 throttler 物理隔离的第 7 个独立实例(name: 'login-sms');
# 默认 5/60(goal 拍板值;登录为高频正常操作,较 password-reset 3/60 放宽一档)。
# LOGIN_SMS_THROTTLE_LIMIT:留空默认 5,推荐区间 [1, 100]
# LOGIN_SMS_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
LOGIN_SMS_THROTTLE_LIMIT=
LOGIN_SMS_THROTTLE_TTL_SECONDS=

# 微信小程序登录 T3(2026-06-12):POST /api/auth/v1/login-wechat + wechat-bind{,/send-code}
# 三个 pre-auth 端点 IP 维度限流参数(沿 docs/archive/reviews/wechat-mini-login-review.md E-17)
# 与上述各 throttler 物理隔离的第 8 个独立实例(name: 'login-wechat');默认 5/60(镜像 login-sms)。
# LOGIN_WECHAT_THROTTLE_LIMIT:留空默认 5,推荐区间 [1, 100]
# LOGIN_WECHAT_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
LOGIN_WECHAT_THROTTLE_LIMIT=
LOGIN_WECHAT_THROTTLE_TTL_SECONDS=

# 招新一期 T3(2026-06-18):POST /api/open/v1/recruitment/... 报名公开两端点 IP 维度限流参数
# 沿 docs/archive/reviews/recruitment-phase1-review.md E-R-25
# 与上述各 throttler 物理隔离的第 9 个独立实例(name: 'recruitment');
# 默认 10/3600(名额有限场景防重复提交/高频刷接口)。
# RECRUITMENT_THROTTLE_LIMIT:留空默认 10,推荐区间 [1, 100]
# RECRUITMENT_THROTTLE_TTL_SECONDS:留空默认 3600,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
RECRUITMENT_THROTTLE_LIMIT=
RECRUITMENT_THROTTLE_TTL_SECONDS=

# 招新可用性收口 F1(2026-07-11):付费 OCR 调用(recognize + submit 共享)按 IP × 北京自然日封顶
# 沿 docs/archive/reviews/recruitment-usability-closeout-review.md §2.5/E-U-1
# 持久化计数表(独立于上面的内存限流器,进程重启不清零);超限返 28060(HTTP 429)。
# RECRUITMENT_OCR_DAILY_IP_LIMIT:留空默认 30,推荐区间 [1, 100000]
RECRUITMENT_OCR_DAILY_IP_LIMIT=

# CMS 内容发布模块 T3(2026-06-21):GET /api/open/v1/content/... 内容读取公开两端点 IP 维度限流参数
# 沿 docs/archive/reviews/content-module-review.md §7
# 与上述各 throttler 物理隔离的第 10 个独立实例(name: 'content-public');
# 默认 60/60(公开只读端点,较报名类更宽松)。
# CONTENT_PUBLIC_THROTTLE_LIMIT:留空默认 60,推荐区间 [1, 100]
# CONTENT_PUBLIC_THROTTLE_TTL_SECONDS:留空默认 60,推荐区间 [1, 3600]
# 任一非正整数或越界,启动报错退出(禁止 fallback)
CONTENT_PUBLIC_THROTTLE_LIMIT=
CONTENT_PUBLIC_THROTTLE_TTL_SECONDS=

# 终态 scoped-authz PR9(2026-07-02;冻结稿 §5.3):考勤终审「一级审核人 == 终审人」同人开关
# - 留空 / 任意非 'true' 值(默认,推荐):禁止同人 —— 一级审核人不得再终审同一张考勤单
# - 显式 'true'(严格字符串,沿 ENABLE_SWAGGER 范式):放开同人(小团队单审批链场景)
# - 自审禁止(submitter == 终审人)是域不变量,**不受本开关影响、永不可放开**(SUPER_ADMIN 亦拒)
ATTENDANCE_ALLOW_SAME_REVIEWER=

# 活动考勤时间窗容差(小时):checkInAt >= startAt-容差 且 checkOutAt <= endAt+容差
# 留空默认 2；允许 0-168 的整数，越界或非整数启动报错退出
ATTENDANCE_WINDOW_TOLERANCE_HOURS=

# 活动自助 GPS 签到 geofence 半径(米)
# 留空默认 500；只接受 50-10000 的正整数，越界或非整数启动报错退出
ATTENDANCE_CHECKIN_RADIUS_METERS=

# 已完结活动评价窗口(从 Activity.endAt 起算的自然天数)
# 留空默认 30；只接受 1-365 的正整数，越界或非整数启动报错退出
ATTENDANCE_FEEDBACK_WINDOW_DAYS=

# V2.x C-6 RBAC 实施 PR #8:RBAC bootstrap 首个 ops-admin 持有者(沿 D7 v1.1 §10.4)
# - 留空(推荐):seed 自动 fallback 到现有 SUPER_ADMIN(优先 createdAt 最早的活跃 SUPER_ADMIN)
# - 显式指定 User.id:seed 校验该 user 存在 / 未禁用 / 未软删,作为 ops-admin 首批持有者
# - 强校验:seed 完成后至少 1 个活跃 user_role 持有 ops-admin,否则 seed throw 退出
# - 本变量仅 seed 使用,**不**进入运行时 ConfigService(沿 SUPER_ADMIN_* 范式,§14 显式例外)
RBAC_INITIAL_OPS_ADMIN_USER_ID=

# V2.x C-7.5 Provider 选型实施 PR #6:storage_settings 凭证加密 key(沿 §6.6.1 + Q23 例外)
# - 用途:AES-256-GCM 加密 SecretId / SecretKey 落库;明文永不入 DB(沿 Q21 / Q22)
# - production:**必填**;留空 / 长度 < 32 启动报错退出
# - dev / test:留空允许;StorageCryptoService.isAvailable()=false,凭证字段读写均抛
# - 推荐生成:`openssl rand -base64 32`(44 字符 base64 = 32 字节随机数)
# - 与 JWT_SECRET 同等防护级别(沿 v1 §14;不进仓库;由运维 / 部署平台注入)
# - **Key 自身 ≠ 凭证**:env 可承载加密 key,但不承载 SecretId / SecretKey 本身(沿 Q23 例外)
STORAGE_ENCRYPTION_KEY=

# SMS 基础设施 T2(2026-06-10):sms_settings 凭证加密 key(评审稿 D-SMS-8;沿 STORAGE 范式)
# - production / smoke:**必填**;留空 / 长度 < 32 启动报错退出;dev / test 留空允许
# - 与 STORAGE_ENCRYPTION_KEY 互不复用(独立 key + 独立派生 salt);推荐 `openssl rand -base64 32`
SMS_ENCRYPTION_KEY=

# 微信小程序登录 T2(2026-06-12):wechat_settings 凭证(AppSecret)加密 key(评审稿 E-5;沿 SMS 范式)
# - production / smoke:**必填**;留空 / 长度 < 32 启动报错退出;dev / test 留空允许
# - 与 STORAGE / SMS 两把 key 互不复用(独立 key + 独立派生 salt);推荐 `openssl rand -base64 32`
WECHAT_ENCRYPTION_KEY=

# 招新一期 · 实名核验通道 T2(2026-06-18):realname_verification_settings 凭证(secretId/secretKey)加密 key(评审稿 E-R-4;沿 SMS 范式)
# - production / smoke:**必填**;留空 / 长度 < 32 启动报错退出;dev / test 留空允许
# - 与 STORAGE / SMS / WECHAT 三把 key 互不复用(独立 key + 独立派生 salt);推荐 `openssl rand -base64 32`
REALNAME_ENCRYPTION_KEY=

# V2.x C-7.5 Provider 选型实施 PR #7:LocalStorageProvider 根目录(dev / test 主路径)
# - 留空(推荐):默认 './tmp/storage'(相对仓库根目录;.gitignore 已排除 tmp/)
# - 显式指定:绝对路径 或 相对仓库根目录的路径
# - production 环境不应使用 LocalProvider(沿 F2);Provider 选型由 storage_settings.providerType 决定
STORAGE_LOCAL_ROOT=
